/* ==================== CSS 变量体系（亮色模式默认值） ==================== */
page {
  --pageBg: #F8FAFC;
  --cardBg: #FFFFFF;
  --surfaceBg: #F1F5F9;
  --elevatedBg: #FFFFFF;

  --textPrimary: #1E293B;
  --textSecondary: #64748B;
  --textTertiary: #94A3B8;
  --textMuted: #CBD5E1;

  --borderLight: #E2E8F0;
  --borderFaint: #F1F5F9;
  --borderDark: rgba(148,163,184,0.15);

  --inputBg: #FFFFFF;
  --inputBorder: #E2E8F0;
  --searchBg: #F1F5F9;
  --searchBorder: transparent;

  --primaryColor: #3B82F6;
  --primaryLight: rgba(59,130,246,0.1);
  --dangerColor: #EF4444;
  --successColor: #10B981;
  --warningColor: #F59E0B;

  --shadowSm: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
  --shadowMd: 0 4px 12px rgba(0,0,0,0.08);
  --shadowLg: 0 10px 30px rgba(0,0,0,0.1);

  background-color: var(--pageBg);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  color: var(--textPrimary);
}

/* ==================== 暗黑模式：一键覆盖所有变量 ==================== */
.dark-mode,
.dark-mode page {
  --pageBg: #0F172A;
  --cardBg: #1E293B;
  --surfaceBg: #1E293B;
  --elevatedBg: #1E293B;

  --textPrimary: #F1F5F9;
  --textSecondary: #94A3B8;
  --textTertiary: #64748B;
  --textMuted: #475569;

  --borderLight: #334155;
  --borderFaint: #1E293B;
  --borderDark: rgba(71,85,105,0.25);

  --inputBg: #0F172A;
  --inputBorder: #334155;
  --searchBg: #1E293B;
  --searchBorder: rgba(148,163,184,0.2);

  --primaryColor: #60A5FA;
  --primaryLight: rgba(96,165,250,0.15);
  --dangerColor: #F87171;
  --successColor: #34D399;
  --warningColor: #FBBF24;

  --shadowSm: 0 1px 3px rgba(0,0,0,0.3);
  --shadowMd: 0 4px 12px rgba(0,0,0,0.35);
  --shadowLg: 0 10px 30px rgba(0,0,0,0.4);

  background-color: var(--pageBg) !important;
  color: var(--textPrimary);
}

/* ==================== 基础布局 ==================== */
.container {
  max-width: 500px;
  margin: 0 auto;
  padding: 0 20px;
}

.page-container,
.tool-page {
  background-color: var(--pageBg);
}

/* ==================== 卡片/区块（统一使用变量） ==================== */
.section-block,
.card,
.tool-item,
.input-card,
.result-card,
.tips-card,
.advice-card,
.color-preview-section,
.text-areas,
.action-buttons,
.action-row,
.history-section,
.settings-list,
.banner-ad,
.empty-state,
.bottom-info,
.nav-placeholder {
  background-color: var(--cardBg);
  box-shadow: var(--shadowSm);
}

/* 白色背景的输入框容器 */
.input-box,
.password-display,
.deduction-grid,
.deduction-item,
.deduction-value-box,
.text-area-wrapper,
.bmi-value-display,
.result-detail-item,
.diff-header,
.diff-line {
  background-color: var(--elevatedBg);
  border: 1px solid var(--borderDark);
}

/* ==================== 输入框 ==================== */
input,
textarea {
  background-color: transparent;
  color: var(--textPrimary);
  border: none;
  caret-color: var(--primaryColor);
}

.search-input {
  background-color: transparent;
  color: var(--textPrimary);
  border: none !important;
  padding: 0 !important;
  margin: 0 !important;
}

.search-input-wrapper::after,
.search-input-wrapper .search-input::after {
  display: none !important;
  border: none !important;
}

/* ==================== 文字颜色（统一变量） ==================== */
.page-title,
.tool-title,
.app-title,
.section-title,
.item-name,
.recent-name,
.tool-name,
.card-title,
.result-main-label,
.result-main-value,
.detail-label,
.detail-value,
.input-field,
.password-display,
.text-area,
.greeting-text,
.user-nickname,
.setting-name,
.fav-names,
.picker-hex-text,
.status-text,
.advice-text,
.tips-title,
.tips-text,
.tip-text,
.banner-text,
.empty-text,
.tool-desc,
.item-desc,
.card-desc,
.section-subtitle,
.page-subtitle,
.user-stats,
.input-label,
.area-label,
.deduction-name,
.deduction-unit,
.text-placeholder,
.diff-added,
.diff-removed,
.line-same,
.setting-value,
.empty-subtext,
.tip-icon {
  color: var(--textPrimary);
}

.tool-desc,
.item-desc,
.recent-time,
.setting-value,
.section-subtitle,
.page-subtitle,
.user-stats,
.input-label,
.area-label,
.deduction-name,
.deduction-unit,
.text-placeholder,
.empty-subtext,
.tip-icon,
.card-desc {
  color: var(--textSecondary);
}

/* ==================== 边框/分割线 ==================== */
.section-block,
.card,
.tool-item,
.input-card,
.search-bar,
.input-box,
.text-area,
.password-display,
.deduction-grid .deduction-item,
.deduction-value-box,
.result-card,
.tips-card,
.advice-card,
.color-preview-section,
.banner-ad,
.tools-grid .tool-card,
.see-all-btn,
.settings-list .setting-item {
  border-color: var(--borderDark);
}

.section-header,
.diff-header,
.result-header {
  border-bottom-color: var(--borderDark);
}

/* ==================== 按钮 ==================== */
.compare-btn,
.calc-btn,
.swap-btn,
.empty-btn,
.action-btn,
.category-tab.active {
  opacity: 0.95;
}

.category-tab {
  color: var(--textSecondary);
  background-color: transparent;
}

.category-tab.active {
  color: var(--primaryColor);
  background-color: var(--primaryLight);
}

/* ==================== 收藏星标 ==================== */
.card-favorite text {
  color: var(--textTertiary);
}
.tool-card.favorite .card-favorite text {
  color: var(--warningColor);
}

/* ==================== 收藏夹提示条 ==================== */
.favorite-tip {
  background: rgba(245,158,11,0.1);
  border-left-color: var(--warningColor);
}
.tip-icon { font-size: 16px; }
.tip-text {
  color: var(--warningColor);
}

/* ==================== 底部安全区 ==================== */
.bottom-safe-area {
  background-color: var(--pageBg);
}

/* ==================== 导航栏组件 ==================== */
/* 注意：不在此处设置导航栏背景色，由各页面自行控制 */

/* ==================== icon wrapper ==================== */
.icon-wrapper {
  filter: none;
}
.dark-mode .icon-wrapper {
  filter: brightness(0.85);
}

/* ==================== 暗黑模式兜底（仅处理极少数无法用变量覆盖的场景） ==================== */
.dark-mode {
  background-color: var(--pageBg) !important;
}

.dark-mode .page-container,
.dark-mode .container,
.dark-mode .tool-page,
.dark-mode .section-block,
.dark-mode .card,
.dark-mode .tool-item,
.dark-mode .input-card,
.dark-mode .result-card,
.dark-mode .tips-card,
.dark-mode .advice-card,
.dark-mode .color-preview-section,
.dark-mode .text-areas,
.dark-mode .action-buttons,
.dark-mode .action-row,
.dark-mode .history-section,
.dark-mode .settings-list,
.dark-mode .banner-ad,
.dark-mode .empty-state,
.dark-mode .bottom-info,
.dark-mode .nav-placeholder,
.dark-mode .bottom-safe-area {
  background-color: var(--cardBg) !important;
  box-shadow: none !important;
}

.dark-mode input,
.dark-mode textarea {
  color: var(--textPrimary) !important;
  -webkit-appearance: none !important;
  caret-color: var(--primaryColor) !important;
}

.dark-mode navigation-bar,
.dark-mode .weui-navigation-bar {
  background-color: var(--pageBg) !important;
}

.dark-mode .weui-navigation-bar__inner {
  background-color: var(--pageBg) !important;
}
