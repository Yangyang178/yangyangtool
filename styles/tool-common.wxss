/* ===================================
   🃏 工具页面通用样式系统 v2
   文件: styles/tool-common.wxss
   用途: 所有工具页面的统一UI组件
   依赖: app.wxss (全局设计令牌)
   =================================== */

/* ===================================
   📦 工具页面容器
   =================================== */
.tool-page {
  min-height: 100vh;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* ===================================
   🎯 工具头部区域
   =================================== */
.tool-header {
  display: flex;
  align-items: center;
  gap: var(--space-md, 16px);
  margin-bottom: var(--space-lg, 24px);
  padding: var(--space-lg, 24px);
  background: linear-gradient(135deg, rgba(59,130,246,0.08) 0%, rgba(139,92,246,0.06) 100%);
  border-radius: var(--radiusXl, 20px);
}

.tool-icon-large {
  width: 72px;
  height: 72px;
  border-radius: var(--radiusLg, 16px);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36px;
  position: relative;
  z-index: 2;
}

.tool-icon-decoration {
  position: absolute;
  width: 90px;
  height: 90px;
  border-radius: 50%;
  background: inherit;
  opacity: 0.15;
  filter: blur(15px);
  z-index: 1;
}

.tool-info {
  flex: 1;
}

.tool-title-main {
  font-size: var(--fontSizeLg, 20px);
  font-weight: var(--fontWeightBold, 700);
  color: var(--textPrimary, #1E293B);
  margin-bottom: var(--space-2xs, 2px);
  line-height: 1.3;
}

.tool-desc-main {
  font-size: var(--fontSizeSm, 13px);
  color: var(--textSecondary, #64748B);
  line-height: 1.4;
}

/* ===================================
   📥 输入框通用样式 v2
   =================================== */
.input-wrapper {
  background: var(--elevatedBg, #FFFFFF);
  border-radius: var(--radiusLg, 16px);
  padding: var(--space-md, 16px) var(--space-lg, 24px);
  border: 2px solid transparent;
  transition: all var(--durationNormal, 0.25s) var(--easeDefault, ease);
  position: relative;
}

.input-wrapper:focus-within {
  border-color: var(--primaryColor, #3B82F6);
  box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
  transform: scaleX(1.02);
}

.input-label-text {
  font-size: var(--fontSizeSm, 13px);
  font-weight: var(--fontWeightMedium, 500);
  color: var(--textSecondary, #64748B);
  margin-bottom: var(--space-xs, 4px);
  display: block;
}

.input-field-common {
  font-size: var(--fontSizeBase, 15px);
  color: var(--textPrimary, #1E293B);
  background: transparent;
  width: 100%;
  height: 44px;
  line-height: 44px;
}

.input-field-common::placeholder {
  color: var(--textMuted, #CBD5E1);
}

/* 多行文本输入 */
.textarea-wrapper {
  background: var(--elevatedBg, #FFFFFF);
  border-radius: var(--radiusLg, 16px);
  padding: var(--space-md, 16px) var(--space-lg, 24px);
  border: 2px solid transparent;
  transition: all var(--durationNormal, 0.25s) var(--easeDefault, ease);
}

.textarea-wrapper:focus-within {
  border-color: var(--primaryColor, #3B82F6);
  box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
}

.textarea-field-common {
  font-size: var(--fontSizeBase, 15px);
  color: var(--textPrimary, #1E293B);
  background: transparent;
  width: 100%;
  min-height: 120px;
  line-height: 1.5;
}

/* ===================================
   🔘 按钮通用样式 v2
   =================================== */
.btn-primary {
  background: linear-gradient(135deg, var(--primaryColor, #3B82F6) 0%, var(--primaryDark, #2563EB) 100%);
  color: #FFFFFF;
  border-radius: var(--radiusLg, 16px);
  padding: var(--space-md, 16px) var(--space-xl, 32px);
  font-size: var(--fontSizeBase, 15px);
  font-weight: var(--fontWeightSemibold, 600);
  border: none;
  box-shadow: 0 4px 14px rgba(59, 130, 246, 0.35);
  transition: all var(--durationNormal, 0.25s) var(--easeBounce, cubic-bezier(0.34, 1.56, 0.64, 1));
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.btn-primary::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 60%);
  transform: translate(-50%, -50%) scale(0);
  transition: transform var(--durationSlow, 0.4s) var(--easeDefault, ease);
}

.btn-primary:active {
  transform: scale(0.96);
  box-shadow: 0 2px 8px rgba(59, 130, 246, 0.25);
}

.btn-primary:active::before {
  transform: translate(-50%, -50%) scale(1);
}

.btn-secondary {
  background: var(--surfaceBg, #F1F5F9);
  color: var(--textPrimary, #1E293B);
  border-radius: var(--radiusLg, 16px);
  padding: var(--space-md, 16px) var(--space-xl, 32px);
  font-size: var(--fontSizeBase, 15px);
  font-weight: var(--fontWeightMedium, 500);
  border: none;
  transition: all var(--durationNormal, 0.25s) var(--easeDefault, ease);
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-secondary:active {
  background: var(--borderLight, #E2E8F0);
  transform: scale(0.98);
}

.btn-sm {
  padding: var(--space-sm, 8px) var(--space-md, 16px);
  font-size: var(--fontSizeSm, 13px);
  border-radius: var(--radiusMd, 12px);
}

.btn-icon {
  width: 44px;
  height: 44px;
  border-radius: var(--radiusMd, 12px);
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
}

/* ===================================
   📊 结果展示区域
   =================================== */
.result-container {
  background: var(--cardBg, #FFFFFF);
  border-radius: var(--radiusXl, 20px);
  padding: var(--space-lg, 24px);
  margin-top: var(--space-md, 16px);
  box-shadow: var(--shadowCardDay, 0 4px 12px rgba(0,0,0,0.06));
  animation: resultFadeIn var(--durationSlow, 0.4s) var(--easeDefault, ease);
}

@keyframes resultFadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

.result-label {
  font-size: var(--fontSizeSm, 13px);
  font-weight: var(--fontWeightMedium, 500);
  color: var(--textSecondary, #64748B);
  margin-bottom: var(--space-xs, 4px);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.result-value {
  font-size: var(--fontSize2xl, 32px);
  font-weight: var(--fontWeightBlack, 900);
  color: var(--primaryColor, #3B82F6);
  line-height: 1.2;
  margin-bottom: var(--space-sm, 8px);
}

.result-unit {
  font-size: var(--fontSizeMd, 17px);
  font-weight: var(--fontWeightSemibold, 600);
  color: var(--textSecondary, #64748B);
  margin-left: var(--space-xs, 4px);
}

.result-detail {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: var(--space-md, 16px);
  border-top: 1px solid var(--borderFaint, #F1F5F9);
  margin-top: var(--space-md, 16px);
}

.detail-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}

.detail-number {
  font-size: var(--fontSizeMd, 17px);
  font-weight: var(--fontWeightBold, 700);
  color: var(--textPrimary, #1E293B);
}

.detail-name {
  font-size: var(--fontSizeXs, 11px);
  color: var(--textSecondary, #64748B);
}

/* ===================================
   💡 提示/建议卡片
   =================================== */
.tips-card-common {
  background: linear-gradient(135deg, rgba(245,158,11,0.05) 0%, rgba(245,158,11,0.02) 100%);
  border-radius: var(--radiusLg, 16px);
  padding: var(--space-md, 16px) var(--space-lg, 24px);
  margin-top: var(--space-md, 16px);
  border-left: 4px solid var(--warningColor, #F59E0B);
}

.tips-title-common {
  font-size: var(--fontSizeSm, 13px);
  font-weight: var(--fontWeightSemibold, 600);
  color: var(--warningColor, #F59E0B);
  margin-bottom: var(--space-xs, 4px);
  display: flex;
  align-items: center;
  gap: var(--space-xs, 4px);
}

.tips-content-common {
  font-size: var(--fontSizeSm, 13px);
  color: var(--textSecondary, #64748B);
  line-height: 1.5;
}

/* ===================================
   📋 历史记录区域
   =================================== */
.history-section-common {
  margin-top: var(--space-lg, 24px);
}

.history-title-common {
  font-size: var(--fontSizeMd, 17px);
  font-weight: var(--fontWeightSemibold, 600);
  color: var(--textPrimary, #1E293B);
  margin-bottom: var(--space-md, 16px);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.history-list-common {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm, 8px);
}

.history-item-common {
  background: var(--cardBg, #FFFFFF);
  border-radius: var(--radiusMd, 12px);
  padding: var(--space-md, 16px);
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: var(--shadowSm, 0 1px 3px rgba(0,0,0,0.06));
  transition: all var(--durationFast, 0.15s) var(--easeDefault, ease);
}

.history-item-common:active {
  transform: scale(0.98);
  background: var(--surfaceBg, #F1F5F9);
}

.history-input-common {
  font-size: var(--fontSizeBase, 15px);
  color: var(--textPrimary, #1E293B);
  font-weight: var(--fontWeightMedium, 500);
}

.history-output-common {
  font-size: var(--fontSizeBase, 15px);
  color: var(--primaryColor, #3B82F6);
  font-weight: var(--fontWeightSemibold, 600);
}

.history-time-common {
  font-size: var(--fontSizeXs, 11px);
  color: var(--textTertiary, #94A3B8);
  margin-top: var(--space-2xs, 2px);
}

/* ===================================
   🎨 分类选择器
   =================================== */
.category-selector {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm, 8px);
  margin-bottom: var(--space-md, 16px);
}

.category-chip {
  padding: var(--space-sm, 8px) var(--space-md, 16px);
  border-radius: var(--radiusFull, 9999px);
  font-size: var(--fontSizeSm, 13px);
  font-weight: var(--fontWeightMedium, 500);
  color: var(--textSecondary, #64748B);
  background: var(--surfaceBg, #F1F5F9);
  border: 1.5px solid transparent;
  transition: all var(--durationNormal, 0.25s) var(--easeDefault, ease);
}

.category-chip.active {
  color: #FFFFFF;
  background: linear-gradient(135deg, var(--primaryColor, #3B82F6) 0%, var(--primaryDark, #2563EB) 100%);
  border-color: transparent;
  box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
  transform: translateY(-1px);
}

.category-chip:active {
  transform: scale(0.95);
}

/* ===================================
   🔄 切换/开关组件
   =================================== */
.switch-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-md, 16px) 0;
  border-bottom: 1px solid var(--borderFaint, #F1F5F9);
}

.switch-label {
  font-size: var(--fontSizeBase, 15px);
  color: var(--textPrimary, #1E293B);
  font-weight: var(--fontWeightMedium, 500);
}

.switch-description {
  font-size: var(--fontSizeSm, 13px);
  color: var(--textSecondary, #64748B);
  margin-top: var(--space-2xs, 2px);
}

/* ===================================
   📱 空状态提示
   =================================== */
.empty-state-common {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-2xl, 48px) var(--space-lg, 24px);
  text-align: center;
}

.empty-icon-common {
  font-size: 64px;
  margin-bottom: var(--space-md, 16px);
  opacity: 0.5;
}

.empty-title-common {
  font-size: var(--fontSizeMd, 17px);
  font-weight: var(--fontWeightSemibold, 600);
  color: var(--textPrimary, #1E293B);
  margin-bottom: var(--space-xs, 4px);
}

.empty-desc-common {
  font-size: var(--fontSizeSm, 13px);
  color: var(--textSecondary, #64748B);
  line-height: 1.5;
  max-width: 280px;
}

/* ===================================
   ⚡ 加载动画
   =================================== */
.loading-spinner {
  width: 40px;
  height: 40px;
  border: 3px solid var(--borderLight, #E2E8F0);
  border-top-color: var(--primaryColor, #3B82F6);
  border-radius: 50%;
  animation: spin var(--durationSlow, 0.6s) linear infinite;
  margin: var(--space-xl, 32px) auto;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.skeleton-box {
  background: linear-gradient(90deg, var(--surfaceBg, #F1F5F9) 25%, var(--cardBg, #FFFFFF) 50%, var(--surfaceBg, #F1F5F9) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: var(--radiusMd, 12px);
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

/* ===================================
   🌙 夜间模式适配
   =================================== */
.dark-mode .tool-header {
  background: linear-gradient(135deg, rgba(96,165,250,0.08) 0%, rgba(167,139,250,0.06) 100%);
}

.dark-mode .tool-title-main {
  color: var(--textPrimary, #F1F5F9);
}

.dark-mode .tool-desc-main {
  color: var(--textSecondary, #94A3B8);
}

.dark-mode .input-wrapper,
.dark-mode .textarea-wrapper {
  background: var(--elevatedBg, #232d42);
}

.dark-mode .input-field-common,
.dark-mode .textarea-field-common {
  color: var(--textPrimary, #F1F5F9);
}

.dark-mode .input-field-common::placeholder,
.dark-mode .textarea-field-common::placeholder {
  color: var(--textMuted, #475569);
}

.dark-mode .btn-primary {
  box-shadow: 0 4px 14px rgba(59, 130, 246, 0.25);
}

.dark-mode .btn-secondary {
  background: var(--elevatedBg, #232d42);
  color: var(--textPrimary, #F1F5F9);
}

.dark-mode .btn-secondary:active {
  background: var(--cardBg, #1a2035);
}

.dark-mode .result-container {
  background: var(--cardBg, #1a2035);
  box-shadow: var(--shadowCardNight, 0 4px 12px rgba(0,0,0,0.3));
}

.dark-mode .result-detail {
  border-top-color: var(--borderDark, rgba(71,85,105,0.25));
}

.dark-mode .detail-number {
  color: var(--textPrimary, #F1F5F9);
}

.dark-mode .tips-card-common {
  background: linear-gradient(135deg, rgba(251,191,36,0.05) 0%, rgba(251,191,36,0.02) 100%);
}

.dark-mode .history-item-common {
  background: var(--cardBg, #1a2035);
}

.dark-mode .history-item-common:active {
  background: var(--elevatedBg, #232d42);
}

.dark-mode .category-chip {
  background: var(--elevatedBg, #232d42);
  color: var(--textSecondary, #94A3B8);
}

.dark-mode .switch-container {
  border-bottom-color: var(--borderDark, rgba(71,85,105,0.25));
}

.dark-mode .switch-label {
  color: var(--textPrimary, #F1F5F9);
}

.dark-mode .empty-title-common {
  color: var(--textPrimary, #F1F5F9);
}

.dark-mode .skeleton-box {
  background: linear-gradient(90deg, var(--elevatedBg, #232d42) 25%, var(--cardBg, #1a2035) 50%, var(--elevatedBg, #232d42) 75%);
  background-size: 200% 100%;
}
