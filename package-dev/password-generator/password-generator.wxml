<navigation-bar title="密码生成器" back="{{true}}" color="black" background="#F8FAFC"></navigation-bar>

<scroll-view class="tool-page" scroll-y>
  <view class="container">
    <view class="tool-header">
      <view class="icon-wrapper">
        <view class="icon-decoration"></view>
        <text class="tool-icon">🔐</text>
      </view>
      <text class="tool-title">密码生成器</text>
      <text class="tool-desc">自定义长度/字符类型，一键生成强密码</text>
    </view>

    <view class="result-card">
      <view class="password-display">{{password}}</view>
      
      <view class="password-strength-bar">
        <view class="password-strength-fill strength-{{strengthLevel}}"></view>
      </view>
      <view class="strength-text {{strengthLevel}}">{{strengthText}} · {{length}}位</view>

      <view class="action-row">
        <button class="copy-btn" bindtap="copyPassword" hover-class="btn-hover">
          <text class="btn-icon">📋</text>复制
        </button>
        <button class="refresh-btn" bindtap="refreshPassword" hover-class="btn-hover">
          <text class="btn-icon">🔄</text>换一个
        </button>
      </view>
    </view>

    <view class="settings-card">
      <text class="section-title">密码长度</text>
      <view class="length-section">
        <view class="length-header">
          <text class="length-label">长度</text>
          <text class="length-value">{{length}} 位</text>
        </view>
        <view class="slider-container">
          <slider class="length-slider" min="6" max="32" value="{{length}}" step="1"
            show-value="{{false}}" block-size="16" activeColor="#8B5CF6"
            backgroundColor="#E2E8F0" bindchange="onLengthChange"/>
        </view>
        <view class="length-presets">
          <view class="length-preset {{length === 8 ? 'active' : ''}}" data-len="8" bindtap="selectLength">8</view>
          <view class="length-preset {{length === 12 ? 'active' : ''}}" data-len="12" bindtap="selectLength">12</view>
          <view class="length-preset {{length === 16 ? 'active' : ''}}" data-len="16" bindtap="selectLength">16</view>
          <view class="length-preset {{length === 24 ? 'active' : ''}}" data-len="24" bindtap="selectLength">24</view>
          <view class="length-preset {{length === 32 ? 'active' : ''}}" data-len="32" bindtap="selectLength">32</view>
        </view>
      </view>

      <text class="section-title">字符类型</text>
      <view class="options-grid">
        <view class="option-item {{options.uppercase ? 'active' : ''}}" data-key="uppercase" bindtap="toggleOption">
          <view class="option-left">
            <text class="option-icon">🔤</text>
            <view>
              <text class="option-name">大写字母</text>
              <text class="option-desc">A B C ... Z</text>
            </view>
          </view>
          <view class="toggle-switch {{options.uppercase ? 'active' : ''}}">
            <view class="toggle-knob"></view>
          </view>
        </view>

        <view class="option-item {{options.lowercase ? 'active' : ''}}" data-key="lowercase" bindtap="toggleOption">
          <view class="option-left">
            <text class="option-icon">🔡</text>
            <view>
              <text class="option-name">小写字母</text>
              <text class="option-desc">a b c ... z</text>
            </view>
          </view>
          <view class="toggle-switch {{options.lowercase ? 'active' : ''}}">
            <view class="toggle-knob"></view>
          </view>
        </view>

        <view class="option-item {{options.numbers ? 'active' : ''}}" data-key="numbers" bindtap="toggleOption">
          <view class="option-left">
            <text class="option-icon">🔢</text>
            <view>
              <text class="option-name">数字</text>
              <text class="option-desc">0 1 2 ... 9</text>
            </view>
          </view>
          <view class="toggle-switch {{options.numbers ? 'active' : ''}}">
            <view class="toggle-knob"></view>
          </view>
        </view>

        <view class="option-item {{options.symbols ? 'active' : ''}}" data-key="symbols" bindtap="toggleOption">
          <view class="option-left">
            <text class="option-icon">★</text>
            <view>
              <text class="option-name">特殊符号</text>
              <text class="option-desc">! @ # $ % ^ & *</text>
            </view>
          </view>
          <view class="toggle-switch {{options.symbols ? 'active' : ''}}">
            <view class="toggle-knob"></view>
          </view>
        </view>
      </view>

      <button class="generate-btn" bindtap="generatePassword" hover-class="btn-hover">
        <text class="btn-icon-lg">🎲</text>生成新密码
      </button>
    </view>

    <view class="tips-section">
      <text class="tips-title">💡 安全提示</text>
      <view class="tips-list">
        <text class="tip-item">• 建议使用 16 位以上包含大小写、数字和符号的强密码</text>
        <text class="tip-item">• 不同平台请使用不同密码，避免一个泄露全部暴露</text>
        <text class="tip-item">• 密码仅在本地生成，不会上传到任何服务器</text>
      </view>
    </view>
  </view>
</scroll-view>
