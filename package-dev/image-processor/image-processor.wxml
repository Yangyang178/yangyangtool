<scroll-view scroll-y class="container">
  <navigation-bar title="图片处理" />

  <view class="tool-content">
    <!-- 工具头部 -->
    <view class="tool-header">
      <view class="icon-wrapper purple-gradient">
        <view class="icon-decoration"></view>
        <text class="tool-icon">🖼️</text>
      </view>
      <text class="tool-title">智能图片处理器</text>
      <text class="tool-desc">压缩 · 尺寸 · 拼接 · 裁剪 · 旋转</text>
    </view>

    <!-- 功能选项卡 -->
    <view class="function-tabs">
      <view wx:for="{{functions}}" wx:key="id" class="tab-item {{currentFunction === item.id ? 'active' : ''}}" data-id="{{item.id}}" bindtap="switchFunction">
        <text>{{item.icon}} {{item.name}}</text>
      </view>
    </view>

    <!-- 图片选择区域 -->
    <view class="image-section" wx:if="{{currentFunction !== 'stitch'}}">
      <block wx:if="{{images.length > 0}}">
        <!-- 当前图片预览 -->
        <view class="current-image-container">
          <image 
            class="preview-image" 
            src="{{images[currentImageIndex].path}}" 
            mode="aspectFit"
          />
          <view class="image-info-overlay" wx:if="{{images[currentImageIndex]}}">
            <text>{{images[currentImageIndex].width}}×{{images[currentImageIndex].height}}</text>
            <text>{{images[currentImageIndex].sizeText}}</text>
          </view>
        </view>

        <!-- 多图切换 -->
        <view class="image-thumbnails" wx:if="{{images.length > 1}}">
          <view 
            wx:for="{{images}}" 
            wx:key="path"
            class="thumbnail {{index === currentImageIndex ? 'active' : ''}}"
            data-index="{{index}}"
            bindtap="switchCurrentImage"
          >
            <image src="{{item.path}}" mode="aspectFill" />
            <view class="remove-thumb" data-index="{{index}}" catchtap="removeImage">✕</view>
          </view>
          <view class="add-more" bindtap="chooseImage">
            <text>+</text>
          </view>
        </view>

        <!-- 操作按钮 -->
        <view class="image-actions">
          <button class="action-btn secondary" size="mini" bindtap="chooseImage">
            <text>📷 更换图片</text>
          </button>
          <button class="action-btn danger" size="mini" bindtap="clearAllImages">
            <text>🗑️ 清除全部</text>
          </button>
        </view>
      </block>

      <block wx:else>
        <view class="upload-area" bindtap="chooseImage">
          <text class="upload-icon">📷</text>
          <text class="upload-text">点击选择图片</text>
          <text class="upload-hint">支持 JPG/PNG/WebP 格式</text>
        </view>
      </block>
    </view>

    <!-- ========== 压缩功能 ========== -->
    <view class="panel" wx:if="{{currentFunction === 'compress'}}">
      <!-- 质量预设 -->
      <view class="section">
        <text class="section-title">质量预设</text>
        <view class="preset-grid">
          <view 
            wx:for="{{qualityPresets}}" 
            wx:key="value"
            class="preset-btn {{quality === item.value ? 'active' : ''}}"
            data-value="{{item.value}}"
            bindtap="selectQualityPreset"
          >
            <text class="preset-label">{{item.label}}</text>
            <text class="preset-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>

      <!-- 精确质量控制 -->
      <view class="section">
        <text class="section-title">精确质量调节 ({{quality}}%)</text>
        <slider 
          class="quality-slider" 
          min="10" max="100" 
          value="{{quality}}"
          activeColor="#8B5CF6"
          show-value
          bindchange="onQualityChange"
        />
        <view class="slider-labels">
          <text>高压缩</text>
          <text>原始画质</text>
        </view>
      </view>

      <!-- 输出格式 -->
      <view class="section">
        <text class="section-title">输出格式</text>
        <view class="format-options">
          <view 
            wx:for="{{outputFormats}}" 
            wx:key="value"
            class="format-opt {{outputFormat === item.value ? 'active' : ''}}"
            style="--color: {{item.color}}"
            data-value="{{item.value}}"
            bindtap="selectOutputFormat"
          >
            <text>{{item.label}}</text>
          </view>
        </view>
      </view>

      <!-- 压缩按钮 -->
      <button 
        class="primary-btn purple" 
        disabled="{{!images[currentImageIndex].path || isProcessing}}"
        loading="{{isProcessing}}"
        bindtap="compressImage"
      >
        {{isProcessing ? '压缩中...' : '🗜️ 开始压缩'}}
      </button>

      <!-- 压缩结果 -->
      <view class="result-card success" wx:if="{{compressResult}}">
        <view class="result-header">
          <text class="result-icon">✅</text>
          <text class="result-title">压缩完成！</text>
        </view>
        <view class="result-grid">
          <view class="result-item">
            <text class="result-label">原始大小</text>
            <text class="result-value">{{compressResult.originalSize}}</text>
          </view>
          <view class="result-item">
            <text class="result-label">压缩后</text>
            <text class="result-value highlight">{{compressResult.compressedSize}}</text>
          </view>
          <view class="result-item">
            <text class="result-label">节省空间</text>
            <text class="result-value success">{{compressResult.savedSize}}</text>
          </view>
          <view class="result-item highlight">
            <text class="result-label">压缩比例</text>
            <text class="result-value big">{{compressResult.ratio}}%</text>
          </view>
        </view>
        <view class="result-actions">
          <button class="action-btn primary" bindtap="saveImage">💾 保存到相册</button>
          <button class="action-btn secondary" bindtap="previewProcessedImage">👁️ 预览效果</button>
        </view>
      </view>
    </view>

    <!-- ========== 尺寸调整功能 ========== -->
    <view class="panel" wx:if="{{currentFunction === 'resize'}}">
      <!-- 百分比缩放 -->
      <view class="section">
        <text class="section-title">百分比缩放 ({{scalePercent}}%)</text>
        <slider 
          class="scale-slider" 
          min="10" max="200" 
          value="{{scalePercent}}"
          activeColor="#8B5CF6"
          show-value
          bindchange="onScalePercentChange"
        />
        <view class="scale-presets">
          <text class="scale-preset" data-percent="25" bindtap="onScalePercentChange" data-detail-value="25">25%</text>
          <text class="scale-preset" data-percent="50" bindtap="onScalePercentChange" data-detail-value="50">50%</text>
          <text class="scale-preset active" data-percent="100" bindtap="onScalePercentChange" data-detail-value="100">100%</text>
          <text class="scale-preset" data-percent="150" bindtap="onScalePercentChange" data-detail-value="150">150%</text>
          <text class="scale-preset" data-percent="200" bindtap="onScalePercentChange" data-detail-value="200">200%</text>
        </view>
      </view>

      <!-- 精确尺寸 -->
      <view class="section">
        <text class="section-title">精确尺寸设置</text>
        <view class="size-inputs">
          <view class="size-box">
            <text class="size-label">宽度 (px)</text>
            <input 
              class="size-input" 
              type="number" 
              placeholder="{{images[currentImageIndex].width || '自动'}}"
              value="{{targetWidth}}"
              bindinput="onTargetWidthInput"
            />
          </view>
          <text class="size-separator">×</text>
          <view class="size-box">
            <text class="size-label">高度 (px)</text>
            <input 
              class="size-input" 
              type="number" 
              placeholder="{{images[currentImageIndex].height || '自动'}}"
              value="{{targetHeight}}"
              bindinput="onTargetHeightInput"
            />
          </view>
        </view>
        <view class="lock-ratio" bindtap="toggleLockRatio">
          <text class="lock-icon">{{isLockedRatio ? '🔒' : '🔓'}}</text>
          <text class="lock-text">{{isLockedRatio ? '锁定宽高比' : '自由调整'}}</text>
        </view>
      </view>

      <!-- 快捷预设 -->
      <view class="section">
        <text class="section-title">快捷尺寸预设</text>
        <view class="preset-grid-2col">
          <view 
            wx:for="{{presetSizes}}" 
            wx:key="label"
            class="preset-card"
            data-width="{{item.width}}"
            data-height="{{item.height}}"
            bindtap="selectPresetSize"
          >
            <text class="preset-name">{{item.label}}</text>
            <text class="preset-size">{{item.width}}×{{item.height}}</text>
          </view>
        </view>
      </view>

      <!-- 调整按钮 -->
      <button 
        class="primary-btn purple" 
        disabled="{{!images[currentImageIndex].path || isProcessing}}"
        loading="{{isProcessing}}"
        bindtap="resizeImage"
      >
        {{isProcessing ? '处理中...' : '📐 调整尺寸'}}
      </button>
    </view>

    <!-- ========== 拼接功能 ========== -->
    <view class="panel" wx:if="{{currentFunction === 'stitch'}}">
      <!-- 拼接模式选择 -->
      <view class="section">
        <text class="section-title">拼接模式</text>
        <view class="mode-cards">
          <view 
            wx:for="{{stitchModes}}" 
            wx:key="id"
            class="mode-card {{stitchMode === item.id ? 'active' : ''}}"
            data-id="{{item.id}}"
            bindtap="switchStitchMode"
          >
            <text class="mode-icon">{{item.icon}}</text>
            <text class="mode-name">{{item.name}}</text>
          </view>
        </view>
      </view>

      <!-- 已选图片列表 -->
      <view class="section">
        <view class="section-header">
          <view class="header-left">
            <text class="section-title">已选图片 ({{stitchImages.length}}张)</text>
            <text class="count-hint" wx:if="{{stitchImages.length < 2}}">至少需要2张</text>
          </view>
          <view 
            class="clear-all-btn" 
            wx:if="{{stitchImages.length > 0}}"
            bindtap="clearStitchImages"
          >
            <text>🗑️ 清除全部</text>
          </view>
        </view>
        
        <view class="stitch-images-list" wx:if="{{stitchImages.length > 0}}">
          <view 
            wx:for="{{stitchImages}}" 
            wx:key="path"
            class="stitch-img-item"
          >
            <image src="{{item.path}}" mode="aspectFill" class="stitch-thumb" />
            <view class="stitch-img-info">
              <text>{{item.sizeText}}</text>
              <text wx:if="{{item.width}}">{{item.width}}×{{item.height}}</text>
            </view>
            <view class="remove-stitch-btn" data-index="{{index}}" catchtap="removeStitchImage">✕</view>
          </view>
        </view>

        <view class="add-images-btn" bindtap="chooseImage">
          <text>➕ 添加图片 (最多9张)</text>
        </view>
      </view>

      <!-- 拼接设置 -->
      <view class="section">
        <text class="section-title">拼接设置</text>
        <view class="stitch-settings">
          <view class="setting-row">
            <text class="setting-label">间距 (px)</text>
            <slider 
              class="gap-slider"
              min="0" max="20"
              value="{{stitchGap}}"
              bindchange="onStitchGapChange"
              show-value
            />
          </view>
          <view class="setting-row">
            <text class="setting-label">背景颜色</text>
            <view class="color-options">
              <view 
                class="color-dot white {{stitchBgColor === '#FFFFFF' ? 'active' : ''}}"
                data-color="#FFFFFF"
                bindtap="setStitchBgColor"
              ></view>
              <view 
                class="color-dot black {{stitchBgColor === '#000000' ? 'active' : ''}}"
                data-color="#000000"
                bindtap="setStitchBgColor"
              ></view>
              <view 
                class="color-dot transparent {{stitchBgColor === 'transparent' ? 'active' : ''}}"
                data-color="transparent"
                bindtap="setStitchBgColor"
              ></view>
            </view>
          </view>
        </view>
      </view>

      <!-- 预览信息 -->
      <view class="info-box" wx:if="{{stitchImages.length >= 2}}">
        <text class="info-text">💡 {{stitchMode === 'horizontal' ? '水平拼接' : stitchMode === 'vertical' ? '垂直拼接' : '网格拼接'}}将把{{stitchImages.length}}张图片合并为一张</text>
      </view>

      <!-- 拼接按钮 -->
      <button 
        class="primary-btn purple" 
        disabled="{{stitchImages.length < 2 || isProcessing}}"
        loading="{{isProcessing}}"
        bindtap="stitchImages"
      >
        {{isProcessing ? '拼接中...' : '🧩 开始拼接'}}
      </button>
    </view>

    <!-- ========== 裁剪功能 ========== -->
    <view class="panel" wx:if="{{currentFunction === 'crop'}}">
      <view class="section">
        <text class="section-title">裁剪模式</text>
        <view class="crop-modes">
          <view 
            wx:for="{{cropModes}}" 
            wx:key="id"
            class="crop-mode {{cropMode === item.id ? 'active' : ''}}"
            data-id="{{item.id}}"
            bindtap="selectCropMode"
          >
            <text class="crop-icon">{{item.icon}}</text>
            <text class="crop-name">{{item.name}}</text>
          </view>
        </view>
      </view>

      <view class="info-box">
        <text class="info-text">ℹ️ 选择裁剪模式后点击按钮，将自动按该模式裁剪图片</text>
      </view>

      <button 
        class="primary-btn purple" 
        disabled="{{!images[currentImageIndex].path || isProcessing}}"
        loading="{{isProcessing}}"
        bindtap="cropImage"
      >
        {{isProcessing ? '裁剪中...' : '✂️ 执行裁剪'}}
      </button>
    </view>

    <!-- ========== 旋转/翻转功能 ========== -->
    <view class="panel" wx:if="{{currentFunction === 'rotate'}}">
      <!-- 旋转选项 -->
      <view class="section">
        <text class="section-title">旋转角度</text>
        <view class="rotation-options">
          <view 
            wx:for="{{rotationOptions}}" 
            wx:key="angle"
            class="rotation-btn"
            data-angle="{{item.angle}}"
            bindtap="rotateImage"
          >
            <text class="rot-icon">{{item.icon}}</text>
            <text class="rot-name">{{item.name}}</text>
          </view>
        </view>
      </view>

      <!-- 翻转选项 -->
      <view class="section">
        <text class="section-title">镜像翻转</text>
        <view class="flip-options">
          <view class="flip-btn" data-direction="horizontal" bindtap="flipImage">
            <text class="flip-icon">↔️</text>
            <text>水平翻转</text>
          </view>
          <view class="flip-btn" data-direction="vertical" bindtap="flipImage">
            <text class="flip-icon">↕️</text>
            <text>垂直翻转</text>
          </view>
        </view>
      </view>

      <view class="info-box">
        <text class="info-text">🔄 旋转和翻转操作会生成新的图片，原图保持不变</text>
      </view>

      <button 
        class="primary-btn purple" 
        disabled="{{!images[currentImageIndex].path || isProcessing}}"
        loading="{{isProcessing}}"
        bindtap="rotateImage"
        data-angle="90"
      >
        {{isProcessing ? '处理中...' : '🔄 左转90° (默认)'}}
      </button>
    </view>

    <!-- ========== 格式转换功能 ========== -->
    <view class="panel" wx:if="{{currentFunction === 'convert'}}">
      <view class="section">
        <text class="section-title">目标格式</text>
        <view class="format-cards">
          <view 
            wx:for="{{allFormats}}" 
            wx:key="value"
            class="fmt-card {{targetFormat === item.value ? 'selected' : ''}}"
            data-value="{{item.value}}"
            bindtap="selectTargetFormat"
          >
            <text class="fmt-ext">{{item.ext}}</text>
            <text class="fmt-name">{{item.name}}</text>
            <text class="fmt-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>

      <view class="format-detail" wx:if="{{formatInfo}}">
        <text class="detail-title">{{formatInfo.name}} 格式说明</text>
        <text class="detail-desc">{{formatInfo.description}}</text>
        <view class="feature-tags">
          <text wx:for="{{formatInfo.features}}" wx:key="*this" class="tag">{{item}}</text>
        </view>
      </view>

      <button 
        class="primary-btn purple" 
        disabled="{{!images[currentImageIndex].path || isProcessing}}"
        loading="{{isProcessing}}"
        bindtap="convertFormat"
      >
        {{isProcessing ? '转换中...' : '🔀 转换格式'}}
      </button>
    </view>

    <!-- ========== 图片信息功能 ========== -->
    <view class="panel" wx:if="{{currentFunction === 'info'}}">
      <view class="info-cards" wx:if="{{images[currentImageIndex] && images[currentImageIndex].info}}">
        <view class="info-card">
          <text class="card-label">文件名</text>
          <text class="card-value">{{images[currentImageIndex].path.split('/').pop()}}</text>
        </view>
        <view class="info-card">
          <text class="card-label">文件大小</text>
          <text class="card-value">{{images[currentImageIndex].sizeText}}</text>
        </view>
        <view class="info-card">
          <text class="card-label">像素尺寸</text>
          <text class="card-value">{{images[currentImageIndex].width}} × {{images[currentImageIndex].height}}</text>
        </view>
        <view class="info-card">
          <text class="card-label">格式类型</text>
          <text class="card-value">{{images[currentImageIndex].info.type}}</text>
        </view>
        <view class="info-card full">
          <text class="card-label">文件路径</text>
          <text class="card-value small">{{images[currentImageIndex].path}}</text>
        </view>
      </view>

      <view class="empty-state" wx:else>
        <text class="empty-icon">🖼️</text>
        <text class="empty-text">请先选择一张图片查看详细信息</text>
      </view>
    </view>

    <!-- 结果预览区 -->
    <view class="result-section" wx:if="{{processedImagePath || stitchResult}}">
      <text class="section-title">✨ 处理结果</text>
      
      <view class="result-preview">
        <image 
          class="result-image" 
          src="{{processedImagePath || stitchResult}}" 
          mode="widthFix"
          bindtap="previewProcessedImage"
        />
      </view>

      <view class="result-actions">
        <button class="action-btn primary" bindtap="saveImage">💾 保存到相册</button>
        <button class="action-btn secondary" bindtap="previewProcessedImage">👁️ 全屏预览</button>
      </view>
    </view>

    <!-- Canvas (隐藏，用于绘制) -->
    <canvas type="2d" id="imageCanvas" style="position: fixed; left: -9999px; top: -9999px;"></canvas>

    <!-- 使用提示 -->
    <view class="tips-section">
      <text class="tips-title">💡 使用技巧</text>
      <view class="tips-list">
        <text class="tip-item">• 压缩：质量70-80%可显著减小体积且保持较好画质</text>
        <text class="tip-item">• WebP格式比JPG小25-35%，比PNG小80%</text>
        <text class="tip-item">• 拼接：适合制作长图、对比图、拼图墙</text>
        <text class="tip-item">• 裁剪：圆形裁剪适合制作头像和图标</text>
        <text class="tip-item">• 所有处理均在本地完成，不会上传服务器</text>
      </view>
    </view>
  </view>
</scroll-view>
