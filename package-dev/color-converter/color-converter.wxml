<navigation-bar title="颜色转换" back="{{true}}" color="black" background="#F8FAFC"></navigation-bar>

<scroll-view class="tool-page" scroll-y>
  <view class="container">
    <view class="tool-header">
      <view class="icon-wrapper" style="background: linear-gradient(135deg, #F472B633 0%, #F472B666 100%);">
        <view class="icon-decoration"></view>
        <text class="tool-icon">🎨</text>
      </view>
      <text class="tool-title">颜色转换</text>
      <text class="tool-desc">HEX / RGB / HSL 互转工具</text>
    </view>

    <!-- 颜色预览区域 -->
    <view class="color-preview-section">
      <view class="color-preview-large" style="background-color: {{currentColor}};" bindtap="showColorPicker">
        <text class="preview-hex">{{hexValue}}</text>
        <view class="pick-hint">点击取色</view>
      </view>
      
      <view class="color-info-row">
        <view class="color-sample-item" style="background: {{currentColor}};" bindtap="copyColor">
          <text class="sample-label">点击复制</text>
        </view>
        <view class="color-text-info">
          <text class="color-name-text">{{colorName}}</text>
          <text class="contrast-text">对比度: {{contrastRatio}}</text>
        </view>
      </view>
    </view>

    <!-- HEX 输入 -->
    <view class="input-card">
      <view class="input-header">
        <text class="input-label">🎯 HEX 颜色</text>
        <view class="format-badge hex">#RRGGBB</view>
      </view>
      <view class="input-row">
        <text class="input-prefix">#</text>
        <input 
          class="color-input"
          placeholder="FF5733"
          value="{{hexInput}}"
          bindinput="onHexInput"
          maxlength="6"
          type="text"
        />
      </view>
      <view class="quick-colors">
        <view 
          class="quick-color-dot" 
          wx:for="{{presetColors}}" 
          wx:key="value"
          style="background: {{item.value}};"
          data-value="{{item.value}}"
          bindtap="selectPresetColor"
        ></view>
      </view>
    </view>

    <!-- RGB 输入 -->
    <view class="input-card">
      <view class="input-header">
        <text class="input-label">🔴 RGB 颜色</text>
        <view class="format-badge rgb">R,G,B (0-255)</view>
      </view>
      <view class="rgb-inputs">
        <view class="rgb-input-group">
          <text class="rgb-label">R</text>
          <input 
            class="rgb-input red"
            type="number"
            placeholder="255"
            value="{{rValue}}"
            bindinput="onRInput"
            maxlength="3"
          />
        </view>
        <view class="rgb-input-group">
          <text class="rgb-label green-text">G</text>
          <input 
            class="rgb-input green"
            type="number"
            placeholder="128"
            value="{{gValue}}"
            bindinput="onGInput"
            maxlength="3"
          />
        </view>
        <view class="rgb-input-group">
          <text class="rgb-label blue-text">B</text>
          <input 
            class="rgb-input blue"
            type="number"
            placeholder="0"
            value="{{bValue}}"
            bindinput="onBInput"
            maxlength="3"
          />
        </view>
      </view>
    </view>

    <!-- HSL 输入 -->
    <view class="input-card">
      <view class="input-header">
        <text class="input-label">🌈 HSL 颜色</text>
        <view class="format-badge hsl">H,S,L (0-360, 0-100%)</view>
      </view>
      <view class="hsl-inputs">
        <view class="hsl-input-group">
          <text class="hsl-label h-text">H</text>
          <input 
            class="hsl-input h-input"
            type="digit"
            placeholder="0"
            value="{{hValue}}"
            bindinput="onHInput"
            maxlength="3"
          />
          <text class="hsl-unit">°</text>
        </view>
        <view class="hsl-input-group">
          <text class="hsl-label s-text">S</text>
          <input 
            class="hsl-input s-input"
            type="digit"
            placeholder="100"
            value="{{sValue}}"
            bindinput="onSInput"
            maxlength="3"
          />
          <text class="hsl-unit">%</text>
        </view>
        <view class="hsl-input-group">
          <text class="hsl-label l-text">L</text>
          <input 
            class="hsl-input l-input"
            type="digit"
            placeholder="50"
            value="{{lValue}}"
            bindinput="onLInput"
            maxlength="3"
          />
          <text class="hsl-unit">%</text>
        </view>
      </view>
    </view>

    <!-- 转换结果 -->
    <view class="result-section">
      <text class="result-title">📋 所有格式</text>
      
      <view class="result-grid">
        <view class="result-item" bindtap="copyHex">
          <text class="result-format">HEX</text>
          <text class="result-value">{{hexValue}}</text>
        </view>
        
        <view class="result-item" bindtap="copyRgb">
          <text class="result-format">RGB</text>
          <text class="result-value">{{rgbValue}}</text>
        </view>
        
        <view class="result-item" bindtap="copyHsl">
          <text class="result-format">HSL</text>
          <text class="result-value">{{hslValue}}</text>
        </view>
        
        <view class="result-item" bindtap="copyCmyk">
          <text class="result-format">CMYK</text>
          <text class="result-value cmyk-small">{{cmykValue}}</text>
        </view>
      </view>

      <!-- CSS格式 -->
      <view class="css-output">
        <text class="css-label">CSS 格式</text>
        <scroll-view scroll-x class="css-scroll">
          <view class="css-items">
            <view class="css-item" bindtap="copyCssHex">
              <text class="css-code">color: {{hexValue}};</text>
            </view>
            <view class="css-item" bindtap="copyCssRgb">
              <text class="css-code">rgb({{rValue}}, {{gValue}}, {{bValue}});</text>
            </view>
            <view class="css-item" bindtap="copyCssHsl">
              <text class="css-code">hsl({{hValue}}, {{sValue}}%, {{lValue}}%);</text>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>

    <!-- 常用颜色列表 -->
    <view class="palette-section">
      <text class="palette-title">🎨 常用颜色面板</text>
      <view class="palette-grid">
        <view 
          class="palette-item"
          wx:for="{{colorPalette}}"
          wx:key="name"
          style="background: {{item.hex}};"
          data-color="{{item}}"
          bindtap="selectPaletteColor"
        >
          <text class="palette-name">{{item.name}}</text>
          <text class="palette-hex">{{item.hex}}</text>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-buttons">
      <view class="action-btn random" bindtap="generateRandomColor">
        <text>🎲 随机颜色</text>
      </view>
      <view class="action-btn invert" bindtap="invertColor">
        <text>🔄 反转颜色</text>
      </view>
    </view>

    <!-- 颜色选择器弹窗 -->
    <view class="color-picker-mask" wx:if="{{showPicker}}" bindtap="hideColorPicker"></view>
    <view class="color-picker-panel {{showPicker ? 'show' : ''}}">
      <view class="picker-header">
        <text class="picker-title">🎨 选择颜色</text>
        <text class="picker-close" bindtap="hideColorPicker">✕</text>
      </view>

      <!-- SV色板 - 使用CSS渐变 -->
      <view class="sv-container">
        <view class="sv-canvas-css" style="--hue-color: hsl({{pickerHue}}, 100%, 50%);" bindtouchstart="onSvTouchStart" bindtouchmove="onSvTouchMove">
          <view class="sv-indicator" style="left: {{pickerS}}%; top: {{100 - pickerV}}%; background: {{pickerColor}};"></view>
        </view>
      </view>

      <!-- 色相条 - 使用CSS渐变 -->
      <view class="hue-container">
        <view class="hue-canvas-css" bindtouchstart="onHueTouchStart" bindtouchmove="onHueTouchMove">
          <view class="hue-indicator" style="left: {{pickerHuePos}}%;"></view>
        </view>
      </view>

      <!-- 当前颜色预览 -->
      <view class="picker-preview-row">
        <view class="picker-color-box" style="background: {{currentColor}};"></view>
        <text class="picker-hex-text">{{hexValue}}</text>
      </view>

      <!-- 快捷颜色 -->
      <view class="picker-quick-colors">
        <view class="quick-pick-item" style="background:#EF4444;" data-hex="#EF4444" bindtap="pickQuickColor"></view>
        <view class="quick-pick-item" style="background:#F97316;" data-hex="#F97316" bindtap="pickQuickColor"></view>
        <view class="quick-pick-item" style="background:#F59E0B;" data-hex="#F59E0B" bindtap="pickQuickColor"></view>
        <view class="quick-pick-item" style="background:#10B981;" data-hex="#10B981" bindtap="pickQuickColor"></view>
        <view class="quick-pick-item" style="background:#3B82F6;" data-hex="#3B82F6" bindtap="pickQuickColor"></view>
        <view class="quick-pick-item" style="background:#8B5CF6;" data-hex="#8B5CF6" bindtap="pickQuickColor"></view>
        <view class="quick-pick-item" style="background:#EC4899;" data-hex="#EC4899" bindtap="pickQuickColor"></view>
        <view class="quick-pick-item" style="background:#000000;" data-hex="#000000" bindtap="pickQuickColor"></view>
      </view>
    </view>
  </view>
</scroll-view>