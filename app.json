{
  "pages": [
    "pages/index/index",
    "pages/favorites/favorites",
    "pages/recent/recent"
  ],
  
  "subpackages": [
    {
      "root": "package-calculator",
      "name": "calculator",
      "pages": [
        "exchange-rate/exchange-rate",
        "unit-converter/unit-converter",
        "mortgage-calculator/mortgage-calculator",
        "tip-calculator/tip-calculator",
        "bmi-calculator/bmi-calculator",
        "tax-calculator/tax-calculator",
        "age-calculator/age-calculator"
      ]
    },
    {
      "root": "package-text",
      "name": "text",
      "pages": [
        "word-count/word-count",
        "case-converter/case-converter",
        "base64-tool/base64-tool",
        "text-diff/text-diff",
        "url-encoder/url-encoder",
        "regex-tester/regex-tester"
      ]
    },
    {
      "root": "package-life",
      "name": "life",
      "pages": [
        "pomodoro/pomodoro",
        "water-reminder/water-reminder",
        "random-decision/random-decision",
        "garbage-sorting/garbage-sorting",
        "date-calculator/date-calculator",
        "countdown/countdown",
        "world-clock/world-clock"
      ]
    },
    {
      "root": "package-dev",
      "name": "dev",
      "pages": [
        "json-formatter/json-formatter",
        "color-converter/color-converter",
        "image-processor/image-processor",
        "password-generator/password-generator"
      ]
    }
  ],
  
  "preloadRule": {
    "pages/index/index": {
      "network": "all",
      "packages": ["calculator", "text", "life", "dev"]
    },
    "pages/favorites/favorites": {
      "network": "all",
      "packages": ["calculator", "text", "life", "dev"]
    },
    "pages/recent/recent": {
      "network": "all",
      "packages": ["calculator", "text", "life", "dev"]
    }
  },

  "window": {
    "navigationBarTextStyle": "black",
    "navigationStyle": "custom",
    "backgroundColor": "#F8FAFC"
  },
  "tabBar": {
    "color": "#94A3B8",
    "selectedColor": "#3B82F6",
    "backgroundColor": "#FFFFFF",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "工具集",
        "iconPath": "images/tab-tools.png",
        "selectedIconPath": "images/tab-tools-active.png"
      },
      {
        "pagePath": "pages/favorites/favorites",
        "text": "收藏夹",
        "iconPath": "images/tab-fav.png",
        "selectedIconPath": "images/tab-fav-active.png"
      },
      {
        "pagePath": "pages/recent/recent",
        "text": "我的",
        "iconPath": "images/tab-recent.png",
        "selectedIconPath": "images/tab-recent-active.png"
      }
    ]
  },
  "style": "v2",
  "darkmode": true,
  "themeLocation": "theme.json",
  "sitemapLocation": "sitemap.json",
  "lazyCodeLoading": "requiredComponents"
}