@import "../../styles/tool-common.wxss";

page {
  background-color: var(--pageBg,#F8FAFC);
}

.tool-page {
  height: 100vh;
}

.container {
  padding: var(--space-lg, 20px);
  padding-bottom: calc(var(--space-xl, 40px) + env(safe-area-inset-bottom));
}

/* ===================================
   🎯 工具头部 - 居中布局（保留特色）
   =================================== */
.tool-header {
  text-align: center;
  margin-bottom: var(--space-xl, 32px);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
  padding: var(--space-lg, 24px);
}

.icon-wrapper {
  width: 80px;
  height: 80px;
  border-radius: var(--radiusXl, 24px);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto var(--space-md, 16px);
  background: linear-gradient(135deg, var(--accentBlue,#3B82F6) 0%, var(--primaryDark,#2563EB) 100%);
  box-shadow: 0 8px 24px rgba(59, 130, 246, 0.3);
  position: relative;
  z-index: 2;
}

.icon-decoration {
  position: absolute;
  width: 100px;
  height: 100px;
  border-radius: 50%;
  background: var(--accentBlue,#3B82F6);
  opacity: 0.15;
  filter: blur(20px);
  z-index: 1;
}

.blue-gradient {
  background: linear-gradient(135deg, var(--accentBlue,#3B82F6) 0%, var(--primaryDark,#2563EB) 100%);
}

.tool-icon {
  font-size: 40px;
  position: relative;
  z-index: 2;
}

.tool-title {
  font-size: var(--fontSizeXl, 24px);
  font-weight: var(--fontWeightBold, 700);
  color: var(--textPrimary,#1E293B);
  display: block;
  margin-bottom: var(--space-sm, 8px);
  line-height: 1.3;
}

.tool-desc {
  font-size: var(--fontSizeSm, 14px);
  color: var(--textSecondary,#64748B);
  line-height: 1.4;
}

.rate-source-tag {
  display: inline-flex;
  align-items: center;
  gap: var(--space-sm, 6px);
  margin-top: var(--space-md, 12px);
  padding: var(--space-sm, 8px) var(--space-md, 16px);
  border-radius: var(--radiusFull, 20px);
  font-size: var(--fontSizeXs, 12px);
  transition: all var(--durationFast, 0.2s) var(--easeDefault, ease);
}
.rate-source-tag:active {
  transform: scale(0.97);
}
.rate-source-tag.demo {
  background: #FEF3C7;
  color: #92400E;
}
.rate-source-tag.cache {
  background: #DBEAFE;
  color: #1E40AF;
}
.rate-source-tag.real {
  background: #D1FAE5;
  color: #065F46;
}
.source-icon { font-size: 14px; }
.source-text { font-weight: var(--fontWeightSemibold, 600); }
.refresh-hint {
  opacity: 0.7;
  font-size: 11px;
}

/* ===================================
   📥 输入区域 - 使用通用样式增强
   =================================== */
.input-section {
  margin-bottom: var(--space-lg, 24px);
}

.input-label {
  font-size: var(--fontSizeSm, 14px);
  font-weight: var(--fontWeightSemibold, 600);
  color: var(--textPrimary,#1E293B);
  display: block;
  margin-bottom: var(--space-md, 12px);
}

.amount-input-wrapper {
  background: var(--cardBg,#FFFFFF);
  border-radius: var(--radiusLg, 16px);
  padding: var(--space-md, 18px) var(--space-lg, 20px);
  box-shadow: var(--shadowSm, 0 2px 8px rgba(0, 0, 0, 0.04));
  display: flex;
  align-items: center;
  border: 2px solid transparent;
  transition: all var(--durationNormal, 0.25s) var(--easeDefault, ease);
}

.amount-input-wrapper:focus-within {
  border-color: var(--accentBlue,#3B82F6);
  box-shadow: 0 4px 16px rgba(59, 130, 246, 0.15);
  transform: scaleX(1.01);
}

.currency-symbol {
  font-size: var(--fontSizeXl, 28px);
  color: var(--accentBlue,#3B82F6);
  font-weight: var(--fontWeightBold, 700);
  margin-right: var(--space-md, 12px);
}

.amount-input {
  flex: 1;
  font-size: var(--fontSizeXl, 20px);
  font-weight: var(--fontWeightSemibold, 600);
  color: var(--textPrimary,#1E293B);
  background: transparent;
  height: 44px;
  line-height: 44px;
}

.amount-input::placeholder {
  color: var(--textMuted,#CBD5E1);
}

/* ===================================
   💱 货币选择器（页面特有组件）
   =================================== */
.currency-section {
  margin-bottom: var(--space-xl, 28px);
}

.currency-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md, 16px);
}

.selector-box {
  flex: 1;
  background: var(--cardBg,#FFFFFF);
  border-radius: var(--radiusLg, 16px);
  padding: var(--space-lg, 20px);
  box-shadow: var(--shadowSm, 0 2px 8px rgba(0, 0, 0, 0.04));
  text-align: center;
  transition: all var(--durationNormal, 0.25s) var(--easeDefault, ease);
}

.selector-box:active {
  transform: scale(0.98);
  box-shadow: var(--shadowMd, 0 4px 12px rgba(0, 0, 0, 0.08));
}

.currency-code {
  font-size: var(--fontSizeXl, 22px);
  font-weight: var(--fontWeightBold, 700);
  color: var(--textPrimary,#1E293B);
  display: block;
  margin-bottom: var(--space-xs, 6px);
}

.currency-name {
  font-size: var(--fontSizeSm, 13px);
  color: var(--textSecondary,#64748B);
}

.swap-btn {
  width: 52px;
  height: 52px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--accentBlue,#3B82F6) 0%, var(--primaryDark,#2563EB) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4px 16px rgba(59, 130, 246, 0.35);
  transition: all var(--durationNormal, 0.25s) var(--easeBounce, cubic-bezier(0.34, 1.56, 0.64, 1));
}

.swap-btn:active {
  transform: scale(0.92) rotate(180deg);
}

.swap-icon {
  font-size: 24px;
  color: #FFFFFF;
}

/* ===================================
   📊 结果展示区域 - 保留渐变特色
   =================================== */
.result-section {
  margin-bottom: var(--space-xl, 28px);
}

.result-card {
  background: linear-gradient(135deg, var(--accentBlue,#3B82F6) 0%, var(--primaryDark,#2563EB) 100%);
  border-radius: var(--radiusXl, 20px);
  padding: var(--space-xl, 32px) var(--space-lg, 24px);
  text-align: center;
  margin-bottom: var(--space-lg, 20px);
  box-shadow: 0 8px 32px rgba(59, 130, 246, 0.35);
  animation: resultGlow var(--durationSlow, 0.5s) var(--easeDefault, ease);
}

@keyframes resultGlow {
  from {
    opacity: 0;
    transform: translateY(10px) scale(0.98);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.result-amount {
  font-size: var(--fontSizeHero, 32px);
  font-weight: var(--fontWeightBlack, 900);
  color: #FFFFFF;
  display: block;
  margin-bottom: var(--space-sm, 10px);
  text-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
}

.result-label {
  font-size: var(--fontSizeMd, 16px);
  color: rgba(255, 255, 255, 0.95);
  display: block;
  margin-bottom: var(--space-md, 12px);
}

.rate-info {
  font-size: var(--fontSizeSm, 13px);
  color: rgba(255, 255, 255, 0.8);
  background: rgba(255, 255, 255, 0.18);
  padding: var(--space-sm, 8px) var(--space-md, 16px);
  border-radius: var(--radiusFull, 20px);
  display: inline-block;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.quick-rates {
  background: var(--cardBg,#FFFFFF);
  border-radius: var(--radiusLg, 16px);
  padding: var(--space-lg, 20px);
  box-shadow: var(--shadowSm, 0 2px 8px rgba(0, 0, 0, 0.04));
}

.section-title {
  font-size: var(--fontSizeBase, 15px);
  font-weight: var(--fontWeightSemibold, 600);
  color: var(--textPrimary,#1E293B);
  display: block;
  margin-bottom: var(--space-md, 16px);
}

.rate-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-md, 12px);
}

.rate-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-md, 14px) var(--space-md, 16px);
  background: var(--pageBg,#F8FAFC);
  border-radius: var(--radiusMd, 12px);
  transition: all var(--durationFast, 0.2s) var(--easeDefault, ease);
}

.rate-item:active {
  transform: scale(0.98);
  background: var(--bgTipBlue,#EFF6FF);
}

.rate-left {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs, 4px);
}

.rate-right {
  display: flex;
  align-items: center;
  gap: var(--space-sm, 8px);
}

.rate-code {
  font-size: var(--fontSizeBase, 15px);
  font-weight: var(--fontWeightBold, 700);
  color: var(--textPrimary,#1E293B);
}

.rate-name {
  font-size: var(--fontSizeXs, 12px);
  color: var(--textSecondary,#64748B);
}

.rate-symbol {
  font-size: var(--fontSizeSm, 14px);
  color: var(--accentBlue,#3B82F6);
  font-weight: var(--fontWeightSemibold, 600);
}

.rate-value {
  font-size: var(--fontSizeBase, 15px);
  color: var(--accentBlue,#3B82F6);
  font-weight: var(--fontWeightBold, 700);
}

/* ===================================
   🔘 操作按钮 - 使用统一按钮系统
   =================================== */
.action-btns {
  display: flex;
  gap: var(--space-md, 12px);
  margin-top: var(--space-lg, 24px);
}

/* ===================================
   🌙 夜间模式完整适配
   =================================== */
.dark-mode page {
  background-color: var(--pageBgNight,#0f1419);
}

.dark-mode .container {
  /* 保持默认 */
}

.dark-mode .icon-wrapper {
  box-shadow: 0 8px 24px rgba(59, 130, 246, 0.25);
}

.dark-mode .icon-decoration {
  opacity: 0.1;
}

.dark-mode .tool-title {
  color: var(--textPrimary,#F1F5F9);
}

.dark-mode .tool-desc {
  color: var(--textSecondary,#94A3B8);
}

.dark-mode .rate-source-tag.demo {
  background: rgba(245, 158, 11, 0.15);
  color: #FBBF24;
}

.dark-mode .rate-source-tag.cache {
  background: rgba(59, 130, 246, 0.15);
  color: #60A5FA;
}

.dark-mode .rate-source-tag.real {
  background: rgba(34, 197, 94, 0.15);
  color: #4ADE80;
}

.dark-mode .input-label {
  color: var(--textPrimary,#F1F5F9);
}

.dark-mode .amount-input-wrapper {
  background: var(--elevatedBg,#232d42);
  box-shadow: var(--shadowSm, 0 2px 8px rgba(0, 0, 0, 0.2));
}

.dark-mode .amount-input-wrapper:focus-within {
  border-color: var(--accentBlue,#3B82F6);
  box-shadow: 0 4px 16px rgba(59, 130, 246, 0.2);
}

.dark-mode .currency-symbol {
  color: var(--accentBlue,#60A5FA);
}

.dark-mode .amount-input {
  color: var(--textPrimary,#F1F5F9);
}

.dark-mode .amount-input::placeholder {
  color: var(--textMuted,#475569);
}

.dark-mode .selector-box {
  background: var(--elevatedBg,#232d42);
  box-shadow: var(--shadowSm, 0 2px 8px rgba(0, 0, 0, 0.2));
}

.dark-mode .selector-box:active {
  background: var(--cardBg,#1a2035);
}

.dark-mode .currency-code {
  color: var(--textPrimary,#F1F5F9);
}

.dark-mode .currency-name {
  color: var(--textSecondary,#94A3B8);
}

.dark-mode .swap-btn {
  box-shadow: 0 4px 16px rgba(59, 130, 246, 0.25);
}

.dark-mode .result-card {
  box-shadow: 0 8px 32px rgba(59, 130, 246, 0.3);
}

.dark-mode .quick-rates {
  background: var(--cardBg,#1a2035);
  box-shadow: var(--shadowCardNight, 0 4px 12px rgba(0,0,0,0.3));
}

.dark-mode .section-title {
  color: var(--textPrimary,#F1F5F9);
}

.dark-mode .rate-item {
  background: var(--elevatedBg,#232d42);
}

.dark-mode .rate-item:active {
  background: rgba(59, 130, 246, 0.1);
}

.dark-mode .rate-code {
  color: var(--textPrimary,#F1F5F9);
}

.dark-mode .rate-name {
  color: var(--textSecondary,#94A3B8);
}

.dark-mode .rate-symbol,
.dark-mode .rate-value {
  color: var(--accentBlue,#60A5FA);
}
