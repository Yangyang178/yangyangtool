page {
  background-color: var(--pageBg,#F8FAFC);
}

.tool-page {
  height: 100vh;
}

.container {
  padding: 20px;
  padding-bottom: 40px;
}

.tool-header {
  text-align: center;
  margin-bottom: 24px;
}

.icon-wrapper {
  width: 80px;
  height: 80px;
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16px;
}

.red-gradient {
  background: linear-gradient(135deg, var(--bgTipRed,#FEF2F2) 0%, var(--bgTipRed,#FEF2F2) 100%);
}

.tool-icon {
  font-size: 40px;
}

.tool-title {
  font-size: 24px;
  font-weight: 700;
  color: var(--textPrimary,#1E293B);
  display: block;
  margin-bottom: 8px;
}

.tool-desc {
  font-size: 14px;
  color: var(--textSecondary,#64748B);
}

/* е€†з±»ж ‡з­ң */
.category-tabs {
  display: flex;
  gap: 8px;
  margin-bottom: 24px;
  overflow-x: auto;
  white-space: nowrap;
  padding-bottom: 8px;
  -webkit-overflow-scrolling: touch;
}

.tab-item {
  padding: 8px 14px;
  border-radius: 16px;
  background: var(--cardBg,#FFFFFF);
  font-size: 13px;
  font-weight: 500;
  color: var(--textSecondary,#64748B);
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.tab-item.active {
  background: linear-gradient(135deg, var(--accentRed,#EF4444) 0%, var(--accentRedDark,#DC2626) 100%);
  color: var(--cardBg,#FFFFFF);
  box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
}

/* иң“е…ӨеЊғеџџ */
.input-section {
  margin-bottom: 28px;
}

.input-card, .output-card {
  background: var(--cardBg,#FFFFFF);
  border-radius: 16px;
  padding: 20px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  margin-bottom: 12px;
}

.card-label {
  font-size: 13px;
  font-weight: 600;
  color: var(--textSecondary,#64748B);
  display: block;
  margin-bottom: 12px;
}

.value-input-wrapper, .result-display {
  display: flex;
  align-items: center;
  gap: 12px;
}

.value-input {
  flex: 1;
  font-size: 20px;
  font-weight: 700;
  color: var(--textPrimary,#1E293B);
}

.result-value {
  flex: 1;
  font-size: 22px;
  font-weight: 700;
  color: var(--accentRed,#EF4444);
}

.unit-selector {
  padding: 10px 16px;
  background: var(--pageBg,#F8FAFC);
  border-radius: 12px;
  font-size: 15px;
  font-weight: 600;
  color: var(--accentBlue,#3B82F6);
  min-width: 80px;
  text-align: center;
}

.convert-arrow {
  text-align: center;
  padding: 8px 0;
}

.convert-arrow text {
  font-size: 28px;
  color: var(--textTertiary,#94A3B8);
}

/* жҚұз®—иҰ?*/
.conversion-table {
  background: var(--cardBg,#FFFFFF);
  border-radius: 16px;
  padding: 20px;
  margin-bottom: 24px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

.table-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--textPrimary,#1E293B);
  display: block;
  margin-bottom: 16px;
}

.table-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.table-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px;
  background: var(--pageBg,#F8FAFC);
  border-radius: 10px;
}

.table-from, .table-to {
  font-size: 14px;
  font-weight: 600;
  color: var(--textPrimary,#1E293B);
  flex: 1;
}

.table-equal {
  font-size: 14px;
  color: var(--textTertiary,#94A3B8);
  margin: 0 12px;
}

/* ж“ҚдҢњжЊ‰й’® */
.action-btns {
  display: flex;
  gap: 12px;
}

.primary-btn, .secondary-btn {
  flex: 1;
  height: 52px;
  border-radius: 26px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 600;
  border: none;
}

.primary-btn {
  background: linear-gradient(135deg, var(--accentRed,#EF4444) 0%, var(--accentRedDark,#DC2626) 100%);
  color: var(--cardBg,#FFFFFF);
  box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
}

.secondary-btn {
  background: var(--surfaceBg,#F1F5F9);
  color: var(--textSecondary,#64748B);
}

/* и‡Ғе®љд№‰еҚ•дҢҚйЂ‰ж‹©е™?*/
.unit-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.unit-picker-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--cardBg,#FFFFFF);
  border-radius: 24px 24px 0 0;
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.unit-picker-popup.show {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px;
  border-bottom: 1px solid var(--borderLight,#E2E8F0);
}

.picker-title {
  font-size: 17px;
  font-weight: 700;
  color: var(--textPrimary,#1E293B);
}

.picker-close {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surfaceBg,#F1F5F9);
  border-radius: 50%;
}

.picker-close text {
  font-size: 18px;
  color: var(--textSecondary,#64748B);
}

.picker-list {
  flex: 1;
  padding: 12px 0;
  max-height: 55vh;
}

.picker-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  transition: all 0.2s ease;
}

.picker-item:active {
  background: var(--pageBg,#F8FAFC);
}

.picker-item.selected {
  background: var(--bgTipBlue,#EFF6FF);
}

.picker-item-text {
  font-size: 16px;
  font-weight: 500;
  color: var(--textPrimary,#1E293B);
}

.picker-item.selected .picker-item-text {
  color: var(--accentBlue,#3B82F6);
  font-weight: 600;
}

.picker-check {
  font-size: 18px;
  color: var(--accentBlue,#3B82F6);
  font-weight: 700;
}
