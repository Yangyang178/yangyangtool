@import "../../styles/tool-common.wxss";

page { background-color: var(--pageBg,#F8FAFC); }

.tool-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.container {
  padding: var(--space-lg, 20px);
  padding-bottom: calc(var(--space-xl, 40px) + env(safe-area-inset-bottom));
}

/* ===================================
   🎯 工具头部 - 粉色主题
   =================================== */
.tool-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spaceXL, 24px) 0 var(--spaceLG, 20px);
}

.icon-wrapper {
  width: 80px;
  height: 80px;
  border-radius: var(--radiusXl, 24px);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--spaceMD, 12px);
  background: linear-gradient(135deg, var(--accentPink,#EC4899) 0%, #DB2777 100%);
  box-shadow: 0 8px 24px rgba(236, 72, 153, 0.3);
  position: relative;
  z-index: 2;
}

.icon-decoration {
  position: absolute;
  width: 100px;
  height: 100px;
  border-radius: 50%;
  background: var(--accentPink,#EC4899);
  opacity: 0.15;
  filter: blur(20px);
  z-index: 1;
}

.tool-icon {
  font-size: 40px;
  position: relative;
  z-index: 2;
}

.tool-title {
  font-size: var(--fontSizeXl, 22px);
  font-weight: var(--fontWeightBold, 700);
  color: var(--textPrimary,#1E293B);
  margin-bottom: var(--spaceSM, 6px);
}

.tool-desc {
  font-size: var(--fontSizeSm, 13px);
  color: var(--textSecondary,#64748B);
}

/* ===================================
   📥 输入区域
   =================================== */
.input-section {
  margin-top: var(--spaceSM, 10px);
}

.input-card {
  background: var(--cardBg,#FFFFFF);
  border-radius: var(--radiusLg, 16px);
  padding: var(--spaceXL, 24px);
  box-shadow: var(--shadowMd, 0 4px 12px rgba(0, 0, 0, 0.08));
}

.input-group {
  margin-bottom: var(--spaceXL, 20px);
}

.input-label {
  display: block;
  font-size: var(--fontSizeSm, 14px);
  font-weight: var(--fontWeightSemibold, 600);
  color: var(--textPrimary,#1E293B);
  margin-bottom: var(--spaceMD, 10px);
}

.date-picker-box {
  height: 48px;
  background: var(--pageBg,#F8FAFC);
  border-radius: var(--radiusMd, 10px);
  padding: 0 var(--spaceLG, 16px);
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: var(--fontSizeBase, 15px);
  color: var(--textPrimary,#1E293B);
  border: 2px solid transparent;
  transition: all var(--durationFast, 0.2s) ease;
}

.date-picker-box:active {
  border-color: var(--accentPink,#EC4899);
}

.picker-icon { font-size: 18px; }

.quick-birthdays { margin-bottom: var(--spaceXL, 24px); }

.quick-label {
  display: block;
  font-size: var(--fontSizeSm, 13px);
  color: var(--textSecondary,#64748B);
  margin-bottom: var(--spaceMD, 10px);
}

.quick-btn {
  display: inline-block;
  padding: var(--spaceSM, 6px) var(--spaceMD, 14px);
  background: var(--bgTipRed,#FEF2F2);
  border-radius: var(--radiusLg, 16px);
  font-size: var(--fontSizeXs, 12px);
  font-weight: var(--fontWeightSemibold, 600);
  color: var(--accentPink,#EC4899);
  margin-right: var(--spaceSM, 8px);
  margin-bottom: var(--spaceSM, 8px);
  transition: transform var(--durationFast, 0.2s) ease;
}

.quick-btn:active { transform: scale(0.95); }

/* ===================================
   🔘 计算按钮 - 使用统一系统
   =================================== */
.calculate-btn {
  width: 100%;
  height: 52px;
  background: linear-gradient(135deg, var(--accentPink,#EC4899) 0%, #DB2777 100%);
  border-radius: var(--radiusMd, 12px);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fontSizeBase, 16px);
  font-weight: var(--fontWeightBold, 700);
  color: white;
  box-shadow: 0 4px 12px rgba(236, 72, 153, 0.4);
}

.calculate-btn:active { transform: scale(0.98); }

/* ===================================
   📊 结果展示 - 粉色渐变主题
   =================================== */
.result-section { animation: slideUp var(--durationNormal, 0.4s) ease; }

@keyframes slideUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

.age-display-card {
  background: linear-gradient(135deg, var(--accentPink,#EC4899) 0%, #DB2777 100%);
  border-radius: var(--radiusXl, 20px);
  padding: var(--spaceXxl, 28px);
  margin-bottom: var(--spaceXL, 20px);
  box-shadow: 0 8px 24px rgba(236, 72, 153, 0.3);
}

.age-header {
  display: flex;
  align-items: center;
  gap: var(--spaceMD, 12px);
  margin-bottom: var(--spaceXL, 20px);
}

.zodiac-emoji { font-size: 40px; }

.zodiac-info { display: flex; flex-direction: column; }

.zodiac-name {
  font-size: var(--fontSizeLg, 18px);
  font-weight: var(--fontWeightBold, 700);
  color: white;
}

.constellation-name {
  font-size: var(--fontSizeSm, 13px);
  color: rgba(255, 255, 255, 0.85);
}

.age-main {
  text-align: center;
  margin-bottom: var(--spaceXL, 20px);
}

.age-number {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: var(--spaceMD, 8px);
}

.age-value {
  font-size: 64px;
  font-weight: var(--fontWeightBlack, 800);
  color: white;
  line-height: 1;
}

.age-unit {
  font-size: var(--fontSizeXl, 28px);
  font-weight: var(--fontWeightSemibold, 600);
  color: rgba(255, 255, 255, 0.9);
}

.detail-text {
  font-size: var(--fontSizeBase, 16px);
  color: rgba(255, 255, 255, 0.85);
  font-weight: var(--fontWeightMedium, 500);
}

.next-birthday-info {
  background: rgba(255, 255, 255, 0.15);
  border-radius: var(--radiusMd, 12px);
  padding: var(--spaceLG, 16px);
  text-align: center;
}

.countdown-days {
  font-size: 32px;
  font-weight: var(--fontWeightBlack, 800);
  color: var(--accentYellow,#F59E0B);
}

.life-stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--spaceMD, 12px);
  margin-bottom: var(--spaceXL, 20px);
}

.stat-card {
  background: var(--cardBg,#FFFFFF);
  border-radius: var(--radiusLg, 14px);
  padding: var(--spaceLG, 16px) var(--spaceMD, 12px);
  text-align: center;
  box-shadow: var(--shadowSm, 0 2px 8px rgba(0, 0, 0, 0.06));
}

.stat-icon {
  font-size: 24px;
  display: block;
  margin-bottom: var(--spaceSM, 6px);
}

.stat-value {
  font-size: var(--fontSizeLg, 18px);
  font-weight: var(--fontWeightBlack, 800);
  color: var(--accentPink,#EC4899);
  display: block;
  line-height: 1.2;
}

.stat-label {
  font-size: var(--fontSizeMini, 11px);
  color: var(--textTertiary,#94A3B8);
  font-weight: var(--fontWeightSemibold, 600);
  margin-top: var(--spaceXS, 4px);
  display: block;
}

/* ===================================
   🏆 里程碑 + 历史记录
   =================================== */
.milestone-section,
.history-section {
  background: var(--cardBg,#FFFFFF);
  border-radius: var(--radiusLg, 16px);
  padding: var(--spaceXL, 20px);
  box-shadow: var(--shadowSm, 0 2px 8px rgba(0, 0, 0, 0.06));
  margin-bottom: var(--spaceXL, 20px);
}

.milestone-title {
  font-size: var(--fontSizeBase, 16px);
  font-weight: var(--fontWeightBold, 700);
  color: var(--textPrimary,#1E293B);
  display: block;
  margin-bottom: var(--spaceLG, 14px);
}

.action-buttons {
  display: flex;
  gap: var(--spaceMD, 12px);
  margin-bottom: var(--spaceXL, 20px);
}

/* ===================================
   🌙 夜间模式适配 (简化版)
   =================================== */
.dark-mode page { background-color: var(--pageBgNight,#0f1419); }

.dark-mode .icon-wrapper {
  box-shadow: 0 8px 24px rgba(236, 72, 153, 0.25);
}

.dark-mode .icon-decoration { opacity: 0.1; }

.dark-mode .tool-title { color: var(--textPrimary,#F1F5F9); }

.dark-mode .input-card,
.dark-mode .stat-card,
.dark-mode .milestone-section,
.dark-mode .history-section {
  background: var(--elevatedBg,#232d42);
}

.dark-mode .input-label,
.dark-mode .milestone-title { color: var(--textPrimary,#F1F5F9); }

.dark-mode .date-picker-box { background: var(--cardBg,#1a2035); }

.dark-mode .stat-value { color: var(--accentPink,#F472B6); }
