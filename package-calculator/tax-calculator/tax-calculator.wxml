<navigation-bar title="个税计算器" back="{{true}}" color="#0f172a" background="#f8fafb"></navigation-bar>

<scroll-view class="tool-page" scroll-y enhanced show-scrollbar="{{false}}">
  <view class="container">
    <view class="hero-section">
      <view class="hero-icon">
        <view class="icon-glow"></view>
        <text class="icon-emoji">💰</text>
      </view>
      <text class="hero-title">个税计算器</text>
      <text class="hero-subtitle">2024最新税率 · 智能专项扣除</text>
    </view>

    <view class="input-section">
      <view class="salary-card">
        <view class="card-header">
          <text class="card-label">税前月薪</text>
          <text class="card-hint">输入您的月收入</text>
        </view>
        <view class="salary-input-wrapper">
          <input
            class="salary-input"
            type="digit"
            placeholder="0.00"
            placeholder-class="placeholder"
            value="{{salary}}"
            bindinput="onSalaryInput"
          />
          <view class="unit-badge">
            <text>元 / 月</text>
          </view>
        </view>
      </view>

      <view class="deduction-section">
        <view class="section-header">
          <view class="section-title-group">
            <text class="section-icon">⚡</text>
            <text class="section-title">专项附加扣除</text>
          </view>
          <text class="total-deduction">总计: {{totalDeduction}} 元</text>
        </view>

        <view class="deduction-grid">
          <view class="deduction-card" data-key="children">
            <view class="deduction-top">
              <view class="deduction-icon-wrap icon-blue">
                <text class="ded-icon">👶</text>
              </view>
              <text class="deduction-name">子女教育</text>
            </view>
            <view class="deduction-bottom">
              <input
                class="deduction-field"
                type="digit"
                value="{{deductions.children}}"
                data-key="children"
                bindinput="onDeductionChange"
                placeholder="0"
              />
              <text class="deduction-unit">元</text>
            </view>
          </view>

          <view class="deduction-card" data-key="education">
            <view class="deduction-top">
              <view class="deduction-icon-wrap icon-purple">
                <text class="ded-icon">🎓</text>
              </view>
              <text class="deduction-name">继续教育</text>
            </view>
            <view class="deduction-bottom">
              <input
                class="deduction-field"
                type="digit"
                value="{{deductions.education}}"
                data-key="education"
                bindinput="onDeductionChange"
                placeholder="0"
              />
              <text class="deduction-unit">元</text>
            </view>
          </view>

          <view class="deduction-card" data-key="housing">
            <view class="deduction-top">
              <view class="deduction-icon-wrap icon-orange">
                <text class="ded-icon">🏠</text>
              </view>
              <text class="deduction-name">住房租金</text>
            </view>
            <view class="deduction-bottom">
              <input
                class="deduction-field"
                type="digit"
                value="{{deductions.housing}}"
                data-key="housing"
                bindinput="onDeductionChange"
                placeholder="0"
              />
              <text class="deduction-unit">元</text>
            </view>
          </view>

          <view class="deduction-card" data-key="elderly">
            <view class="deduction-top">
              <view class="deduction-icon-wrap icon-green">
                <text class="ded-icon">👴</text>
              </view>
              <text class="deduction-name">赡养老人</text>
            </view>
            <view class="deduction-bottom">
              <input
                class="deduction-field"
                type="digit"
                value="{{deductions.elderly}}"
                data-key="elderly"
                bindinput="onDeductionChange"
                placeholder="0"
              />
              <text class="deduction-unit">元</text>
            </view>
          </view>

          <view class="deduction-card card-wide" data-key="other">
            <view class="deduction-top">
              <view class="deduction-icon-wrap icon-gray">
                <text class="ded-icon">➕</text>
              </view>
              <text class="deduction-name">其他扣除</text>
            </view>
            <view class="deduction-bottom">
              <input
                class="deduction-field"
                type="digit"
                value="{{deductions.other}}"
                data-key="other"
                bindinput="onDeductionChange"
                placeholder="0"
              />
              <text class="deduction-unit">元</text>
            </view>
          </view>
        </view>
      </view>

      <button class="calculate-btn" bindtap="calculate" hover-class="btn-active">
        <view class="btn-inner">
          <text class="btn-icon">◆</text>
          <text class="btn-text">计算个税</text>
        </view>
        <view class="btn-shine"></view>
      </button>
    </view>

    <view class="result-section" wx:if="{{result}}">
      <view class="result-main-card">
        <view class="result-highlight">
          <text class="result-label">税后月薪</text>
          <view class="amount-display">
            <text class="currency-symbol">¥</text>
            <text class="amount-value">{{result.afterTax}}</text>
          </view>
        </view>

        <view class="stats-row">
          <view class="stat-box stat-tax">
            <text class="stat-label">应缴个税</text>
            <text class="stat-value tax-color">{{result.tax}}<text class="stat-suffix">元</text></text>
          </view>
          <view class="stat-box stat-rate">
            <text class="stat-label">实际税率</text>
            <text class="stat-value rate-color">{{result.effectiveRate}}<text class="stat-suffix">%</text></text>
          </view>
        </view>
      </view>

      <view class="annual-card">
        <view class="annual-header">
          <text class="annual-icon">📊</text>
          <text class="annual-title">年度汇总</text>
        </view>
        <view class="annual-grid">
          <view class="annual-item">
            <text class="annual-label">年税前收入</text>
            <text class="annual-value">{{result.annualSalary}}<text class="annual-unit">元</text></text>
          </view>
          <view class="annual-item">
            <text class="annual-label">年应缴个税</text>
            <text class="annual-value annual-tax">{{result.annualTax}}<text class="annual-unit">元</text></text>
          </view>
          <view class="annual-item item-wide">
            <text class="annual-label">年税后收入</text>
            <text class="annual-value annual-after">{{result.annualAfterTax}}<text class="annual-unit">元</text></text>
          </view>
        </view>
      </view>

      <view class="detail-card" wx:if="{{breakdown.length > 0}}">
        <view class="detail-header">
          <text class="detail-icon">⬡</text>
          <text class="detail-title">计算明细</text>
        </view>
        <view class="detail-list">
          <block wx:for="{{breakdown}}" wx:key="label">
            <view class="detail-row">
              <text class="detail-label">{{item.label}}</text>
              <text class="detail-value {{item.cls}}">{{item.val}}<text class="val-unit">元</text></text>
            </view>
          </block>
        </view>
      </view>
    </view>

    <view class="info-section">
      <view class="info-card">
        <view class="info-header">
          <text class="info-icon">ℹ</text>
          <text class="info-title">使用说明</text>
        </view>
        <view class="info-content">
          <view class="info-item">
            <text class="info-bullet">●</text>
            <text class="info-text">起征点：5000元/月（6万元/年）</text>
          </view>
          <view class="info-item">
            <text class="info-bullet">●</text>
            <text class="info-text">子女教育：每子女每月2000元</text>
          </view>
          <view class="info-item">
            <text class="info-bullet">●</text>
            <text class="info-text">继续教育：学历400元/月，职业资格3600元/月</text>
          </view>
          <view class="info-item">
            <text class="info-bullet">●</text>
            <text class="info-text">住房租金：直辖市1500元，其他城市1100元/月</text>
          </view>
          <view class="info-item">
            <text class="info-bullet">●</text>
            <text class="info-text">赡养老人：独生子女2000元，非独生1000元/月</text>
          </view>
        </view>
      </view>
    </view>

    <view class="bottom-space"></view>
  </view>
</scroll-view>
