<navigation-bar title="个税计算器" back="{{true}}" color="#0f172a" background="#ffffff"></navigation-bar>

<scroll-view class="tool-page" scroll-y enhanced show-scrollbar="{{false}}">
  <view class="container">
    <view class="header">
      <text class="header-icon">💰</text>
      <text class="header-title">个税计算器</text>
      <text class="header-sub">2024最新税率 · 智能专项扣除</text>
    </view>

    <view class="form-section">
      <view class="form-item">
        <text class="form-label">税前月薪</text>
        <view class="input-row">
          <input class="form-input" type="digit" placeholder="请输入金额" value="{{salary}}" bindinput="onSalaryInput" />
          <text class="input-unit">元/月</text>
        </view>
      </view>

      <view class="divider"></view>

      <view class="deduction-header">
        <text class="deduction-title">⚡ 专项附加扣除</text>
        <text class="deduction-total">合计: {{totalDeduction}}元</text>
      </view>

      <view class="deduction-list">
        <view class="deduction-item">
          <view class="item-left">
            <text class="item-icon">👶</text>
            <text class="item-name">子女教育</text>
          </view>
          <view class="item-right">
            <input class="item-input" type="digit" value="{{deductions.children}}" data-key="children" bindinput="onDeductionChange" placeholder="0" />
            <text class="item-unit">元</text>
          </view>
        </view>

        <view class="deduction-item">
          <view class="item-left">
            <text class="item-icon">🎓</text>
            <text class="item-name">继续教育</text>
          </view>
          <view class="item-right">
            <input class="item-input" type="digit" value="{{deductions.education}}" data-key="education" bindinput="onDeductionChange" placeholder="0" />
            <text class="item-unit">元</text>
          </view>
        </view>

        <view class="deduction-item">
          <view class="item-left">
            <text class="item-icon">🏠</text>
            <text class="item-name">住房租金</text>
          </view>
          <view class="item-right">
            <input class="item-input" type="digit" value="{{deductions.housing}}" data-key="housing" bindinput="onDeductionChange" placeholder="0" />
            <text class="item-unit">元</text>
          </view>
        </view>

        <view class="deduction-item">
          <view class="item-left">
            <text class="item-icon">👴</text>
            <text class="item-name">赡养老人</text>
          </view>
          <view class="item-right">
            <input class="item-input" type="digit" value="{{deductions.elderly}}" data-key="elderly" bindinput="onDeductionChange" placeholder="0" />
            <text class="item-unit">元</text>
          </view>
        </view>

        <view class="deduction-item item-last">
          <view class="item-left">
            <text class="item-icon">➕</text>
            <text class="item-name">其他扣除</text>
          </view>
          <view class="item-right">
            <input class="item-input" type="digit" value="{{deductions.other}}" data-key="other" bindinput="onDeductionChange" placeholder="0" />
            <text class="item-unit">元</text>
          </view>
        </view>
      </view>
    </view>

    <button class="submit-btn" bindtap="calculate" hover-class="btn-hover">计算个税</button>

    <view class="result-box" wx:if="{{result}}">
      <view class="result-main">
        <text class="result-label">税后月薪</text>
        <view class="amount-row">
          <text class="currency">¥</text>
          <text class="amount-num">{{result.afterTax}}</text>
        </view>
      </view>

      <view class="result-grid">
        <view class="grid-item">
          <text class="grid-label">应缴个税</text>
          <text class="grid-value red">{{result.tax}}<text class="grid-unit">元</text></text>
        </view>
        <view class="grid-item">
          <text class="grid-label">实际税率</text>
          <text class="grid-value">{{result.effectiveRate}}<text class="grid-unit">%</text></text>
        </view>
      </view>

      <view class="annual-box">
        <text class="annual-title">📊 年度汇总</text>
        <view class="annual-list">
          <view class="annual-row">
            <text class="annual-label">年税前收入</text>
            <text class="annual-value">{{result.annualSalary}}<text class="annual-unit">元</text></text>
          </view>
          <view class="annual-row">
            <text class="annual-label">年应缴个税</text>
            <text class="annual-value red">{{result.annualTax}}<text class="annual-unit">元</text></text>
          </view>
          <view class="annual-row row-last">
            <text class="annual-label">年税后收入</text>
            <text class="annual-value bold">{{result.annualAfterTax}}<text class="annual-unit">元</text></text>
          </view>
        </view>
      </view>

      <view class="detail-box" wx:if="{{breakdown.length > 0}}">
        <text class="detail-title">⬡ 计算明细</text>
        <view class="detail-list">
          <block wx:for="{{breakdown}}" wx:key="label">
            <view class="detail-row">
              <text class="detail-label">{{item.label}}</text>
              <text class="detail-value {{item.cls}}">{{item.val}}<text class="val-unit">元</text></text>
            </view>
          </block>
        </view>
      </view>
    </view>

    <view class="tips-box">
      <text class="tips-title">💡 使用说明</text>
      <view class="tips-list">
        <text class="tip-line">• 起征点：5000元/月（6万元/年）</text>
        <text class="tip-line">• 子女教育：每子女每月2000元</text>
        <text class="tip-line">• 继续教育：学历400元/月，职业资格3600元/月</text>
        <text class="tip-line">• 住房租金：直辖市1500元，其他城市1100元/月</text>
        <text class="tip-line">• 赡养老人：独生子女2000元，非独生1000元/月</text>
      </view>
    </view>

    <view class="bottom-space"></view>
  </view>
</scroll-view>
