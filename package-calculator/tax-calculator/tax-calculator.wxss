@import "../../styles/tool-common.wxss";

page {
  background-color: #ffffff;
  height: 100vh;
}

.tool-page {
  height: 100vh;
}

.container {
  padding: 16px;
  padding-bottom: calc(60px + env(safe-area-inset-bottom));
}

/* 头部 */
.header {
  text-align: center;
  padding: 24px 0 20px;
}

.header-icon {
  font-size: 48px;
  display: block;
  margin-bottom: 8px;
}

.header-title {
  font-size: 22px;
  font-weight: 700;
  color: #1e293b;
  display: block;
  margin-bottom: 4px;
}

.header-sub {
  font-size: 13px;
  color: #94a3b8;
}

/* 表单区域 - 柔和圆角 */
.form-section {
  background: #f8fafc;
  border-radius: 24px;
  padding: 20px;
  margin-bottom: 16px;
}

.form-item {
  margin-bottom: 12px;
}

.form-label {
  font-size: 14px;
  font-weight: 600;
  color: #334155;
  display: block;
  margin-bottom: 8px;
}

.input-row {
  display: flex;
  align-items: center;
  background: #ffffff;
  border: 1px solid #e2e8f0;
  border-radius: 14px;
  padding: 0 14px;
}

.form-input {
  flex: 1;
  height: 44px;
  font-size: 20px;
  font-weight: 700;
  color: #1e293b;
  background: transparent;
  border: none;
}

.input-unit {
  font-size: 13px;
  color: #64748b;
  font-weight: 500;
  padding-left: 8px;
  white-space: nowrap;
}

.divider {
  height: 1px;
  background: #e2e8f0;
  margin: 16px 0;
}

/* 扣除项标题 */
.deduction-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.deduction-title {
  font-size: 15px;
  font-weight: 700;
  color: #1e293b;
}

.deduction-total {
  font-size: 13px;
  color: #10b981;
  font-weight: 600;
  background: #ecfdf5;
  padding: 3px 10px;
  border-radius: 12px;
}

/* 扣除项列表 - 横向布局 */
.deduction-list {
  
}

.deduction-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #f1f5f9;
}

.deduction-item.item-last {
  border-bottom: none;
}

.item-left {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
}

.item-icon {
  font-size: 22px;
  width: 32px;
  text-align: center;
}

.item-name {
  font-size: 14px;
  font-weight: 500;
  color: #334155;
  white-space: nowrap;
}

.item-right {
  display: flex;
  align-items: center;
  gap: 4px;
  flex-shrink: 0;
}

.item-input {
  width: 80px;
  height: 34px;
  font-size: 15px;
  font-weight: 600;
  color: #1e293b;
  text-align: right;
  background: #ffffff;
  border: 1px solid #e2e8f0;
  border-radius: 10px;
  padding: 0 8px;
}

.item-unit {
  font-size: 13px;
  color: #94a3b8;
  white-space: nowrap;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 50px;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border-radius: 25px;
  border: none;
  font-size: 16px;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 2px;
  box-shadow: 0 4px 14px rgba(16, 185, 129, 0.3);
  margin-top: 20px;
}

.btn-hover {
  opacity: 0.9;
  transform: scale(0.98);
}

/* 结果区域 */
.result-box {
  margin-top: 20px;
}

.result-main {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border-radius: 20px;
  padding: 24px;
  text-align: center;
}

.result-label {
  font-size: 13px;
  color: rgba(255,255,255,0.85);
  display: block;
  margin-bottom: 8px;
}

.amount-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 2px;
}

.currency {
  font-size: 22px;
  font-weight: 700;
  color: #ffffff;
}

.amount-num {
  font-size: 36px;
  font-weight: 900;
  color: #ffffff;
  letter-spacing: -1px;
}

.result-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1px;
  background: #e2e8f0;
  border-radius: 0 0 20px 20px;
  overflow: hidden;
}

.grid-item {
  background: #ffffff;
  padding: 16px 12px;
  text-align: center;
}

.grid-label {
  font-size: 12px;
  color: #64748b;
  display: block;
  margin-bottom: 4px;
}

.grid-value {
  font-size: 18px;
  font-weight: 800;
  color: #1e293b;
}

.grid-value.red {
  color: #dc2626;
}

.grid-unit {
  font-size: 12px;
  color: #94a3b8;
  font-weight: 500;
}

/* 年度汇总 */
.annual-box {
  background: #f8fafc;
  border-radius: 20px;
  padding: 20px;
  margin-top: 12px;
}

.annual-title {
  font-size: 14px;
  font-weight: 700;
  color: #1e293b;
  display: block;
  margin-bottom: 12px;
}

.annual-list {
  
}

.annual-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid #f1f5f9;
}

.annual-row.row-last {
  border-bottom: none;
}

.annual-label {
  font-size: 14px;
  color: #64748b;
}

.annual-value {
  font-size: 15px;
  font-weight: 700;
  color: #1e293b;
}

.annual-value.red {
  color: #dc2626;
}

.annual-value.bold {
  font-weight: 800;
  color: #10b981;
}

.annual-unit {
  font-size: 12px;
  color: #94a3b8;
  font-weight: 400;
  margin-left: 2px;
}

/* 计算明细 */
.detail-box {
  background: #f8fafc;
  border-radius: 20px;
  padding: 20px;
  margin-top: 12px;
}

.detail-title {
  font-size: 14px;
  font-weight: 700;
  color: #1e293b;
  display: block;
  margin-bottom: 12px;
}

.detail-list {
  
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid #f1f5f9;
}

.detail-label {
  font-size: 13px;
  color: #64748b;
}

.detail-value {
  font-size: 14px;
  font-weight: 700;
  color: #1e293b;
}

.val-unit {
  font-size: 11px;
  color: #94a3b8;
  font-weight: 400;
  margin-left: 2px;
}

/* 使用说明 */
.tips-box {
  background: #fefce8;
  border-radius: 20px;
  padding: 20px;
  margin-top: 16px;
  border-left: 3px solid #f59e0b;
}

.tips-title {
  font-size: 14px;
  font-weight: 700;
  color: #92400e;
  display: block;
  margin-bottom: 10px;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.tip-line {
  font-size: 12px;
  color: #78716c;
  line-height: 1.5;
}

.bottom-space {
  height: 40px;
}

/* 夜间模式 */
.dark-mode page {
  background-color: #0f1419;
}

.dark-mode .header-title {
  color: #F1F5F9;
}

.dark-mode .form-section {
  background: #232d42;
}

.dark-mode .form-label,
.dark-mode .deduction-title {
  color: #F1F5F9;
}

.dark-mode .input-row,
.dark-mode .item-input {
  background: #1a2035;
  border-color: #374151;
  color: #F1F5F9;
}

.dark-mode .item-name {
  color: #CBD5E1;
}

.dark-mode .divider {
  background-color: #374151;
}

.dark-mode .deduction-item {
  border-bottom-color: #374151;
}

.dark-mode .result-main {
  background: linear-gradient(135deg, #059669 0%, #047857 100%);
}

.dark-mode .grid-item {
  background: #232d42;
}

.dark-mode .grid-label {
  color: #94A3B8;
}

.dark-mode .grid-value {
  color: #F1F5F9;
}

.dark-mode .annual-box,
.dark-mode .detail-box {
  background: #232d42;
}

.dark-mode .annual-title,
.dark-mode .detail-title {
  color: #F1F5F9;
}

.dark-mode .annual-label,
.dark-mode .detail-label {
  color: #94A3B8;
}

.dark-mode .annual-value,
.dark-mode .detail-value {
  color: #F1F5F9;
}

.dark-mode .tips-box {
  background: #422006;
  border-left-color: #FBBF24;
}

.dark-mode .tips-title {
  color: #FBBF24;
}

.dark-mode .tip-line {
  color: #D4A574;
}
