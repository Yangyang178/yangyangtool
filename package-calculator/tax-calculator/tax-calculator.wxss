@import "../../styles/tool-common.wxss";

page {
  background-color: var(--pageBg,#f8fafb);
  height: 100vh;
}

.tool-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.container {
  padding: var(--space-lg, 20px);
  padding-bottom: calc(var(--space-xl, 40px) + env(safe-area-inset-bottom));
  min-height: calc(100vh - 44px);
}

/* ===================================
   🎯 工具头部 - 绿色主题
   =================================== */
.hero-section {
  text-align: center;
  padding: var(--spaceXxl, 32px) 0 var(--space-xl, 28px);
  animation: heroFadeIn var(--durationSlow, 0.7s) cubic-bezier(0.4, 0, 0.2, 1);
}

@keyframes heroFadeIn {
  from { opacity: 0; transform: translateY(-16px); }
  to { opacity: 1; transform: translateY(0); }
}

.icon-wrapper {
  width: 72px;
  height: 72px;
  margin: 0 auto var(--space-lg, 18px);
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-glow {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: var(--radiusLg, 18px);
  background: linear-gradient(135deg, var(--accentGreen,#10B981) 0%, #059669 100%);
  opacity: 0.12;
  animation: glowPulse 3s ease-in-out infinite;
}

@keyframes glowPulse {
  0%, 100% { transform: scale(1); opacity: 0.12; }
  50% { transform: scale(1.08); opacity: 0.18; }
}

.icon-emoji {
  font-size: 36px;
  position: relative;
  z-index: 1;
  filter: drop-shadow(0 2px 8px rgba(16, 185, 129, 0.35));
}

.hero-title {
  font-size: var(--fontSizeHero, 26px);
  font-weight: var(--fontWeightBlack, 800);
  color: var(--textPrimary,#0f172a);
  letter-spacing: -0.5px;
  display: block;
  margin-bottom: var(--space-sm, 8px);
}

.hero-subtitle {
  font-size: var(--fontSizeSm, 13px);
  color: var(--textSecondary,#64748b);
  font-weight: var(--fontWeightRegular, 400);
  letter-spacing: 0.5px;
}

/* ===================================
   📝 输入区域
   =================================== */
.input-section { margin-bottom: var(--space-xl, 24px); }

.salary-card,
.deduction-section {
  background: var(--cardBg,#ffffff);
  border-radius: var(--radiusXl, 18px);
  padding: var(--space-xl, 24px) var(--space-lg, 22px);
  box-shadow: var(--shadowSm, 0 2px 8px rgba(0, 0, 0, 0.04));
  border: 1px solid rgba(0, 0, 0, 0.04);
  margin-bottom: var(--space-xl, 20px);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-lg, 16px);
}

.card-label {
  font-size: var(--fontSizeBase, 15px);
  font-weight: var(--fontWeightBold, 700);
  color: var(--textPrimary,#1e293b);
  letter-spacing: 0.3px;
}

.card-hint {
  font-size: var(--fontSizeXs, 12px);
  color: var(--textTertiary,#94a3b8);
  font-weight: var(--fontWeightMedium, 500);
}

.salary-input-wrapper {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, var(--pageBg,#F8FAFC) 0%, #f1f5f9 100%);
  border-radius: var(--radiusLg, 14px);
  padding: var(--space-xs, 4px) var(--space-sm, 6px) var(--space-xs, 4px) var(--space-xl, 20px);
  border: 2px solid transparent;
  transition: all var(--durationNormal, 0.3s) cubic-bezier(0.4, 0, 0.2, 1);
}

.salary-input-wrapper:focus-within {
  border-color: var(--accentGreen,#10B981);
  box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.08);
}

.salary-input {
  flex: 1;
  font-size: var(--fontSizeHero, 28px);
  font-weight: var(--fontWeightBlack, 800);
  color: var(--textPrimary,#0f172a);
  padding: var(--space-md, 12px) 0;
  letter-spacing: -0.5px;
  background: transparent;
  border: none;
}

.unit-badge {
  background: linear-gradient(135deg, var(--accentGreen,#10B981) 0%, #059669 100%);
  padding: var(--space-md, 10px) var(--space-lg, 18px);
  border-radius: var(--radiusMd, 11px);
  flex-shrink: 0;
  margin-left: var(--space-sm, 8px);
}

.unit-badge text {
  font-size: var(--fontSizeSm, 13px);
  font-weight: var(--fontWeightBold, 700);
  color: #ffffff;
}

/* ===================================
   🔘 计算按钮
   =================================== */
.calculate-btn {
  width: 100%;
  height: 54px;
  border-radius: var(--radiusLg, 16px);
  background: linear-gradient(135deg, var(--accentGreen,#10B981) 0%, #059669 50%, #047857 100%);
  background-size: 200% 200%;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6px 20px rgba(16, 185, 129, 0.35), 0 2px 8px rgba(16, 185, 129, 0.2);
  animation: btnGradientShift 4s ease infinite;
  margin-top: var(--space-sm, 8px);
}

@keyframes btnGradientShift {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

.btn-text {
  font-size: var(--fontSizeLg, 17px);
  font-weight: var(--fontWeightBold, 700);
  color: #ffffff;
  letter-spacing: 0.5px;
}

/* ===================================
   📊 结果区域
   =================================== */
.result-section { animation: resultFadeIn var(--durationSlow, 0.6s) ease both; }

@keyframes resultFadeIn {
  from { opacity: 0; transform: translateY(24px); }
  to { opacity: 1; transform: translateY(0); }
}

.result-main-card,
.annual-card,
.detail-card {
  background: var(--cardBg,#ffffff);
  border-radius: var(--radiusXl, 20px);
  overflow: hidden;
  box-shadow: var(--shadowMd, 0 4px 16px rgba(0, 0, 0, 0.06));
  border: 1px solid rgba(0, 0, 0, 0.04);
  margin-bottom: var(--space-md, 16px);
}

.result-highlight {
  background: linear-gradient(135deg, var(--bgTipGreen,#ECFDF5) 0%, #d1fae5 100%);
  padding: var(--spaceXxl, 28px) var(--space-xl, 24px);
  text-align: center;
  border-bottom: 1px solid rgba(16, 185, 129, 0.15);
}

.amount-display {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: var(--space-xs, 4px);
}

.currency-symbol {
  font-size: var(--fontSizeXl, 24px);
  font-weight: var(--fontWeightBold, 700);
  color: #059669;
}

.amount-value {
  font-size: 44px;
  font-weight: var(--fontWeightBlack, 900);
  color: #047857;
  letter-spacing: -1.5px;
  line-height: 1;
}

.stats-row {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1px;
  background: rgba(0, 0, 0, 0.04);
}

.stat-box {
  padding: var(--spaceXL, 20px) var(--spaceLG, 18px);
  text-align: center;
  background: #ffffff;
}

.stat-label {
  font-size: var(--fontSizeXs, 12px);
  font-weight: var(--fontWeightSemibold, 600);
  color: #64748b;
  display: block;
  margin-bottom: var(--spaceMD, 8px);
}

.stat-value {
  font-size: var(--fontSizeXl, 22px);
  font-weight: var(--fontWeightBlack, 800);
  color: #1e293b;
  letter-spacing: -0.3px;
}

.tax-color { color: #dc2626; }

/* ===================================
   💡 信息区域
   =================================== */
.info-section { animation: infoSlideUp var(--durationSlow, 0.7s) ease both; }

@keyframes infoSlideUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

.info-card {
  background: linear-gradient(135deg, #fefce8 0%, #fef3c7 100%);
  border-radius: var(--radiusXl, 18px);
  padding: var(--spaceXL, 22px) var(--spaceLG, 20px);
  border-left: 4px solid var(--accentYellow,#f59e0b);
  box-shadow: 0 4px 12px rgba(245, 158, 11, 0.1);
}

.info-title {
  font-size: var(--fontSizeBase, 15px);
  font-weight: var(--fontWeightBold, 700);
  color: #92400e;
  letter-spacing: 0.2px;
}

.info-text {
  font-size: var(--fontSizeSm, 12px);
  color: #78716c;
  line-height: 1.65;
  font-weight: var(--fontWeightMedium, 500);
}

.bottom-space {
  height: 60px;
  flex-shrink: 0;
}

/* ===================================
   🌙 夜间模式适配 (简化版)
   =================================== */
.dark-mode page {
  background-color: var(--pageBgNight,#0f1419);
}

.dark-mode .salary-card,
.dark-mode .deduction-section,
.dark-mode .result-main-card,
.dark-mode .annual-card,
.dark-mode .detail-card {
  background: var(--elevatedBg,#232d42);
  border-color: var(--borderDark,rgba(71,85,105,0.25));
}

.dark-mode .hero-title,
.dark-mode .card-label,
.dark-mode .section-title {
  color: var(--textPrimary,#F1F5F9);
}

.dark-mode .salary-input {
  color: var(--textPrimary,#F1F5F9);
}

.dark-mode .stat-label {
  color: var(--textSecondary,#94A3B8);
}

.dark-mode .stat-value {
  color: var(--textPrimary,#F1F5F9);
}
