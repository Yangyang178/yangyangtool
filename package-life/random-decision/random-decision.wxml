<navigation-bar title="随机决定" back="{{true}}" color="black" background="#F8FAFC"></navigation-bar>

<scroll-view class="tool-page" scroll-y>
  <view class="container">
    <!-- 工具头部 -->
    <view class="tool-header">
      <view class="icon-wrapper orange-gradient">
        <view class="icon-decoration"></view>
        <text class="tool-icon">🎲</text>
      </view>
      <text class="tool-title">随机决定助手</text>
      <text class="tool-desc">选择困难？让命运帮你做决定！</text>
    </view>

    <!-- 添加选项 -->
    <view class="input-section">
      <text class="section-label">添加选项（至少2个）</text>
      
      <view class="option-list">
        <view 
          wx:for="{{options}}" 
          wx:key="index"
          class="option-item {{selectedIndex === index ? 'selected' : ''}} {{resultIndex === index ? 'winner' : ''}}"
          data-index="{{index}}"
          bindtap="selectOption"
        >
          <text class="option-index">{{index + 1}}</text>
          <text class="option-text">{{item}}</text>
          <button class="delete-btn" catchtap="deleteOption" data-index="{{index}}">✕</button>
        </view>
      </view>

      <view class="add-option-wrapper">
        <input 
          class="add-input"
          type="text"
          placeholder="输入新选项..."
          value="{{newOption}}"
          bindinput="onNewOptionInput"
          confirm-type="done"
          bindconfirm="addOption"
        />
        <button class="add-btn" bindtap="addOption" disabled="{{!newOption}}">
          <text>＋添加</text>
        </button>
      </view>

      <!-- 快速添加常用 -->
      <view class="quick-add-section">
        <text class="quick-label">快速添加：</text>
        <view class="quick-options">
          <text class="quick-tag" bindtap="quickAdd" data-options="吃饭,睡觉,打游戏,学习">🍜 生活</text>
          <text class="quick-tag" bindtap="quickAdd" data-options="去A地,去B地,待在家">📍 出行</text>
          <text class="quick-tag" bindtap="quickAdd" data-options="同意,反对,弃权">🗳 投票</text>
          <text class="quick-tag" bindtap="quickAdd" data-options="红色,蓝色,绿色,黄色">🎨 颜色</text>
        </view>
      </view>
    </view>

    <!-- 开始抽取按钮 -->
    <button 
      class="roll-btn {{isRolling ? 'rolling' : ''}} {{options.length >= 2 ? 'active' : ''}}" 
      bindtap="startRoll"
      disabled="{{options.length < 2 || isRolling}}"
    >
      <text>{{isRolling ? '🎰 抽取中...' : '🎲 开始随机抽取'}}</text>
    </button>

    <!-- 结果显示区域 -->
    <view class="result-section" wx:if="{{showResult && !isRolling}}">
      <view class="result-card">
        <view class="result-icon-wrapper">
          <text class="result-emoji">🎉</text>
        </view>
        
        <text class="result-title">命运的选择是</text>
        
        <view class="result-answer">
          <text class="answer-text">{{selectedAnswer}}</text>
        </view>

        <text class="result-hint">希望这个结果能帮到你！</text>
      </view>

      <view class="action-row">
        <button class="again-btn" bindtap="startRoll">
          <text>🔄 再抽一次</text>
        </button>
        <button class="share-btn" bindtap="shareResult">
          <text>📤 分享结果</text>
        </button>
      </view>
    </view>

    <!-- 抽取历史 -->
    <view class="history-section" wx:if="{{historyList.length > 0}}">
      <text class="history-title">📋 抽取历史</text>
      <scroll-view class="history-list" scroll-y enhanced show-scrollbar="{{false}}">
        <view class="history-item" wx:for="{{historyList}}" wx:key="index">
          <text class="history-time">{{item.time}}</text>
          <text class="history-result">{{item.result}}</text>
        </view>
      </scroll-view>
      <button class="clear-history-btn" bindtap="clearHistory">清空历史</button>
    </view>

    <!-- 使用说明 -->
    <view class="tips-section">
      <text class="tips-title">💡 使用技巧</text>
      <view class="tips-content">
        <text class="tip-item">• 添加2个以上选项即可开始抽取</text>
        <text class="tip-item">• 点击选项可手动选中（不随机）</text>
        <text class="tip-item">• 支持快速添加常用场景选项组</text>
        <text class="tip-item">• 所有结果完全随机，公平公正</text>
      </view>
    </view>
  </view>
</scroll-view>
