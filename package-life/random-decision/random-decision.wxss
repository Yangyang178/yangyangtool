@import "../../styles/tool-common.wxss";

page { background-color: var(--pageBg,#F8FAFC); }
.tool-page { height: 100vh; }
.container { padding: 20px; padding-bottom: 40px; }

/* 工具头部 */
.tool-header { text-align: center; margin-bottom: 24px; }
.icon-wrapper { width: 80px; height: 80px; border-radius: 24px; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; background: linear-gradient(135deg, var(--bgTipRed,#FEF2F2) 0%, var(--bgTipRed,#FEF2F2) 100%); }
.orange-gradient { background: linear-gradient(135deg, var(--accentYellow,#F59E0B) 0%, #EA580C 100%); }
.tool-icon { font-size: 40px; }
.tool-title { font-size: 24px; font-weight: 700; color: var(--textPrimary,#1E293B); display: block; margin-bottom: 8px; }
.tool-desc { font-size: 14px; color: var(--textSecondary,#64748B); }

/* 输入区域 */
.input-section { background: var(--cardBg,#FFFFFF); border-radius: 20px; padding: 20px; box-shadow: 0 2px 12px rgba(0,0,0,0.04); margin-bottom: 20px; }
.section-label { font-size: 15px; font-weight: 600; color: var(--textPrimary,#1E293B); display: block; margin-bottom: 14px; }

.option-list { display: flex; flex-direction: column; gap: 10px; margin-bottom: 14px; min-height: 60px; }
.option-item { display: flex; align-items: center; padding: 14px 16px; background: var(--pageBg,#F8FAFC); border-radius: 12px; transition: all 0.2s ease; border: 2px solid transparent; }
.option-item.selected { background: linear-gradient(135deg, var(--bgTipYellowDeep,#FEF3C7) 0%, #FDE68A 100%); border-color: var(--accentYellow,#F59E0B); }
.option-item.winner { background: linear-gradient(135deg, var(--bgTipGreen,#ECFDF5) 0%, #A7F3D0 100%); border-color: var(--accentGreen,#10B981); animation: winner-pulse 0.6s ease; }
@keyframes winner-pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.03); }
}
.option-index { width: 28px; height: 28px; border-radius: 50%; background: var(--borderLight,#E2E8F0); display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 700; color: var(--textSecondary,#64748B); flex-shrink: 0; margin-right: 12px; }
.option-item.winner .option-index { background: var(--accentGreen,#10B981); color: var(--cardBg,#FFFFFF); }
.option-text { flex: 1; font-size: 15px; font-weight: 500; color: var(--textPrimary,#1E293B); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.delete-btn { width: 28px; height: 28px; border-radius: 50%; background: none; display: flex; align-items: center; justify-content: center; font-size: 16px; color: var(--textTertiary,#94A3B8); padding: 0; line-height: 1; margin-left: 12px; }
.delete-btn:active { color: var(--accentRed,#EF4444); background: var(--bgTipRed,#FEF2F2); }

.add-option-wrapper { display: flex; gap: 10px; margin-bottom: 14px; }
.add-input { flex: 1; height: 46px; background: var(--pageBg,#F8FAFC); border-radius: 12px; padding: 0 16px; font-size: 15px; color: var(--textPrimary,#1E293B); border: 2px solid transparent; transition: all 0.2s ease; }
.add-input:focus { border-color: var(--accentYellow,#F59E0B); background: var(--cardBg,#FFFFFF); }
.add-btn { height: 46px; padding: 0 18px; border-radius: 12px; background: linear-gradient(135deg, var(--accentYellow,#F59E0B) 0%, #EA580C 100%); color: var(--cardBg,#FFFFFF); font-size: 14px; font-weight: 600; border: none; white-space: nowrap; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 12px rgba(249, 115, 22, 0.25); }
.add-btn[disabled] { opacity: 0.5; }

.quick-add-section { padding-top: 14px; border-top: 1px solid var(--surfaceBg,#F1F5F9); }
.quick-label { font-size: 13px; color: var(--textSecondary,#64748B); display: block; margin-bottom: 10px; }
.quick-options { display: flex; gap: 8px; flex-wrap: wrap; }
.quick-tag { padding: 8px 14px; background: #FFF7ED; border-radius: 16px; font-size: 13px; color: #C2410C; font-weight: 500; border: 1px solid var(--gradientOrangeStart,#FED7AA); }
.quick-tag:active { transform: scale(0.95); }

/* 抽取按钮 */
.roll-btn { width: 100%; height: 58px; border-radius: 29px; display: flex; align-items: center; justify-content: center; font-size: 18px; font-weight: 700; border: none; margin-bottom: 24px; transition: all 0.3s ease; background: var(--borderLight,#E2E8F0); color: var(--textTertiary,#94A3B8); }
.roll-btn.active { background: linear-gradient(135deg, var(--accentYellow,#F59E0B) 0%, #EA580C 100%); color: var(--cardBg,#FFFFFF); box-shadow: 0 6px 24px rgba(249, 115, 22, 0.4); }
.roll-btn.rolling { background: linear-gradient(135deg, #FB923C 0%, var(--accentYellow,#F59E0B) 50%, #EA580C 100%); background-size: 200% 200%; animation: rolling-gradient 1s ease infinite; box-shadow: 0 8px 28px rgba(249, 115, 22, 0.5); }
@keyframes rolling-gradient {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}
.roll-btn:active:not(:disabled) { transform: scale(0.98); }

/* 结果区域 */
.result-section { margin-bottom: 24px; }
.result-card { background: linear-gradient(135deg, var(--accentGreen,#10B981) 0%, var(--accentGreen,#10B981) 100%); border-radius: 24px; padding: 36px 24px; text-align: center; box-shadow: 0 8px 32px rgba(16, 185, 129, 0.35); margin-bottom: 16px; }
.result-icon-wrapper { width: 72px; height: 72px; border-radius: 50%; background: rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; }
.result-emoji { font-size: 40px; }
.result-title { font-size: 16px; color: rgba(255,255,255,0.9); display: block; margin-bottom: 12px; }
.result-answer { background: rgba(255,255,255,0.15); border-radius: 16px; padding: 18px; margin-bottom: 12px; }
.answer-text { font-size: 26px; font-weight: 700; color: var(--cardBg,#FFFFFF); display: block; line-height: 1.4; word-break: break-all; }
.result-hint { font-size: 13px; color: rgba(255,255,255,0.75); }

.action-row { display: flex; gap: 12px; }
.again-btn, .share-btn { flex: 1; height: 48px; border-radius: 24px; display: flex; align-items: center; justify-content: center; font-size: 15px; font-weight: 600; border: none; }
.again-btn { background: linear-gradient(135deg, var(--accentGreen,#10B981) 0%, var(--accentGreen,#10B981) 100%); color: var(--cardBg,#FFFFFF); box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3); }
.share-btn { background: var(--surfaceBg,#F1F5F9); color: var(--textSecondary,#64748B); }

/* 历史记录 */
.history-section { background: var(--cardBg,#FFFFFF); border-radius: 20px; padding: 20px; box-shadow: 0 2px 12px rgba(0,0,0,0.04); margin-bottom: 20px; }
.history-title { font-size: 16px; font-weight: 700; color: var(--textPrimary,#1E293B); display: block; margin-bottom: 14px; }
.history-list { max-height: 180px; margin-bottom: 12px; }
.history-item { display: flex; justify-content: space-between; align-items: center; padding: 11px 0; border-bottom: 1px solid var(--pageBg,#F8FAFC); }
.history-item:last-child { border-bottom: none; }
.history-time { font-size: 13px; color: var(--textTertiary,#94A3B8); }
.history-result { font-size: 14px; font-weight: 600; color: var(--accentYellow,#F59E0B); max-width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.clear-history-btn { width: 100%; height: 42px; border-radius: 21px; background: var(--bgTipRed,#FEF2F2); color: var(--accentRed,#EF4444); font-size: 14px; font-weight: 500; border: none; display: flex; align-items: center; justify-content: center; }

/* 提示区域 */
.tips-section { background: linear-gradient(135deg, #FFF7ED 0%, #FFEDD5 100%); border-radius: 16px; padding: 18px; border-left: 4px solid var(--accentYellow,#F59E0B); }
.tips-title { font-size: 15px; font-weight: 600; color: #9A3412; display: block; margin-bottom: 12px; }
.tips-content { display: flex; flex-direction: column; gap: 6px; }
.tip-item { font-size: 13px; color: #9A3412; line-height: 1.5; }

/* ===================================
   🌙 夜间模式完整适配 - 橙色主题
   =================================== */
.dark-mode page {
  background-color: var(--pageBgNight,#0f1419);
}

.dark-mode .icon-wrapper {
  box-shadow: 0 8px 24px rgba(249, 115, 22, 0.25);
}

.dark-mode .tool-title {
  color: var(--textPrimary,#F1F5F9);
}

.dark-mode .tool-desc {
  color: var(--textSecondary,#94A3B8);
}

.dark-mode .section-label {
  color: var(--textPrimary,#F1F5F9);
}

.dark-mode .option-item {
  background: var(--cardBg,#1a2035);
  border-color: var(--borderLight,#374151);
}

.dark-mode .option-item.selected {
  background: rgba(249, 115, 22, 0.15);
  border-color: var(--accentOrange,#FB923C);
}

.dark-mode .option-item.winner {
  background: rgba(16, 185, 129, 0.15);
  border-color: var(--accentGreen,#34D399);
}

.dark-mode .option-index {
  background: var(--elevatedBg,#232d42);
  color: var(--textSecondary,#94A3B8);
}

.dark-mode .option-text {
  color: var(--textPrimary,#F1F5F9);
}

.dark-mode .add-input {
  background: var(--cardBg,#1a2035);
  color: var(--textPrimary,#F1F5F9);
  border-color: var(--borderLight,#374151);
}

.dark-mode .add-btn {
  background: linear-gradient(135deg, var(--accentOrange,#F97316) 0%, #EA580C 100%);
  box-shadow: 0 4px 12px rgba(249, 115, 22, 0.3);
}

.dark-mode .quick-tag {
  background: rgba(249, 115, 22, 0.12);
  color: var(--accentOrange,#FB923C);
}

.dark-mode .roll-btn.active {
  background: linear-gradient(135deg, var(--accentOrange,#F97316) 0%, #EA580C 100%);
  box-shadow: 0 6px 20px rgba(249, 115, 22, 0.35);
}

.dark-mode .result-card {
  background: linear-gradient(135deg, rgba(249, 115, 22, 0.15) 0%, var(--elevatedBg,#232d42) 100%);
  box-shadow: 0 8px 24px rgba(249, 115, 22, 0.2);
}

.dark-mode .result-title {
  color: var(--textSecondary,#94A3B8);
}

.dark-mode .answer-text {
  color: var(--accentOrange,#FB923C);
}

.dark-mode .result-hint {
  color: var(--textMuted,#475569);
}

.dark-mode .again-btn {
  background: var(--cardBg,#1a2035);
  color: var(--textSecondary,#94A3B8);
  border: 1px solid var(--borderLight,#374151);
}

.dark-mode .share-btn {
  background: linear-gradient(135deg, var(--accentOrange,#F97316) 0%, #EA580C 100%);
  box-shadow: 0 4px 12px rgba(249, 115, 22, 0.25);
}

.dark-mode .history-title {
  color: var(--textPrimary,#F1F5F9);
}

.dark-mode .history-item {
  border-bottom-color: var(--borderLight,#374151);
}

.dark-mode .history-time {
  color: var(--textMuted,#475569);
}

.dark-mode .history-result {
  color: var(--accentOrange,#FB923C);
}

.dark-mode .clear-history-btn {
  background: rgba(239, 68, 68, 0.15);
  color: var(--accentRed,#F87171);
}

.dark-mode .tips-section {
  background: rgba(245, 158, 11, 0.1);
  border-left-color: var(--accentYellow,#FBBF24);
}

.dark-mode .tips-title {
  color: var(--accentYellow,#FBBF24);
}

.dark-mode .tip-item {
  color: var(--textSecondary,#94A3B8);
}
