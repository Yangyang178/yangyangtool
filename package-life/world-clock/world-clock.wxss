@import "../../styles/tool-common.wxss";

page { background-color: var(--pageBg,#F8FAFC); }

.tool-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.container {
  padding: 20px;
}

.tool-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24px 0 20px;
}

.icon-wrapper {
  width: 72px;
  height: 72px;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12px;
}

.tool-icon {
  font-size: 36px;
}

.tool-title {
  font-size: 22px;
  font-weight: 700;
  color: var(--textPrimary,#1E293B);
  margin-bottom: 6px;
}

.tool-desc {
  font-size: 13px;
  color: var(--textSecondary,#64748B);
}

.local-time-card {
  background: linear-gradient(135deg, var(--accentPurple,#8B5CF6) 0%, var(--accentPurpleDark,#7C3AED) 100%);
  border-radius: 20px;
  padding: 28px;
  margin-bottom: 24px;
  box-shadow: 0 8px 24px rgba(139, 92, 246, 0.3);
}

.local-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 16px;
}

.local-icon {
  font-size: 18px;
}

.local-label {
  font-size: 14px;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
}

.local-time {
  text-align: center;
  margin-bottom: 12px;
}

.time-text {
  font-size: 52px;
  font-weight: 800;
  color: white;
  line-height: 1.1;
  letter-spacing: -2px;
}

.date-text {
  font-size: 16px;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8px;
  display: block;
}

.local-info {
  display: flex;
  justify-content: center;
  gap: 16px;
}

.timezone,
.weekday {
  padding: 4px 12px;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12px;
  font-size: 13px;
  font-weight: 600;
  color: white;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.section-title {
  font-size: 17px;
  font-weight: 700;
  color: var(--textPrimary,#1E293B);
}

.add-btn {
  padding: 8px 16px;
  background: linear-gradient(135deg, var(--accentPurple,#8B5CF6) 0%, var(--accentPurpleDark,#7C3AED) 100%);
  border-radius: 10px;
  font-size: 13px;
  font-weight: 600;
  color: white;
  box-shadow: 0 4px 12px rgba(139, 92, 246, 0.3);
}

.add-btn:active {
  transform: scale(0.96);
}

.city-list {
  margin-bottom: 24px;
}

.city-card {
  background: white;
  border-radius: 16px;
  padding: 20px;
  margin-bottom: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  transition: transform 0.2s ease;
}

.city-card:active {
  transform: scale(0.98);
}

.city-main {
  display: flex;
  align-items: center;
  margin-bottom: 14px;
}

.city-emoji {
  font-size: 32px;
  margin-right: 12px;
}

.city-info {
  flex: 1;
}

.city-name {
  font-size: 17px;
  font-weight: 700;
  color: var(--textPrimary,#1E293B);
  display: block;
}

.country-name {
  font-size: 13px;
  color: var(--textTertiary,#94A3B8);
  margin-top: 2px;
}

.timezone-badge {
  padding: 4px 10px;
  background: linear-gradient(135deg, var(--gradientPurpleStart,#DDD6FE) 0%, var(--gradientPurpleStart,#DDD6FE) 100%);
  border-radius: 8px;
  font-size: 12px;
  font-weight: 700;
  color: var(--accentPurpleDark,#7C3AED);
}

.city-time-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 44px;
}

.city-time {
  font-size: 28px;
  font-weight: 800;
  color: var(--textPrimary,#1E293B);
  line-height: 1;
}

.city-date {
  font-size: 13px;
  color: var(--textSecondary,#64748B);
  margin-left: 12px;
}

.diff-badge {
  padding: 4px 10px;
  border-radius: 8px;
  font-size: 11px;
  font-weight: 700;
}

.diff-badge.ahead {
  background: var(--bgTipGreen,#ECFDF5);
  color: var(--accentGreen,#10B981);
}

.diff-badge.behind {
  background: var(--bgTipRed,#FEF2F2);
  color: var(--accentRedDark,#DC2626);
}

.diff-badge.same {
  background: var(--gradientPurpleStart,#DDD6FE);
  color: var(--accentPurpleDark,#7C3AED);
}

.empty-state {
  text-align: center;
  padding: 50px 0;
}

.empty-icon {
  font-size: 56px;
  display: block;
  margin-bottom: 12px;
}

.empty-text {
  font-size: 15px;
  color: var(--textTertiary,#94A3B8);
}

.picker-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.picker-modal {
  width: 100%;
  max-height: 80vh;
  background: white;
  border-radius: 24px 24px 0 0;
  padding: 20px;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.picker-title {
  font-size: 18px;
  font-weight: 700;
  color: var(--textPrimary,#1E293B);
}

.picker-close {
  font-size: 24px;
  color: var(--textTertiary,#94A3B8);
  padding: 4px;
}

.search-box {
  display: flex;
  align-items: center;
  background: var(--pageBg,#F8FAFC);
  border-radius: 12px;
  padding: 12px 16px;
  margin-bottom: 16px;
}

.search-icon {
  font-size: 16px;
  margin-right: 10px;
}

.search-input {
  flex: 1;
  font-size: 14px;
  color: var(--textPrimary,#1E293B);
}

.city-picker-list {
  max-height: 400px;
}

.picker-city-item {
  display: flex;
  align-items: center;
  padding: 14px;
  border-radius: 12px;
  margin-bottom: 8px;
  transition: background 0.2s ease;
}

.picker-city-item:active {
  background: var(--pageBg,#F8FAFC);
}

.picker-emoji {
  font-size: 24px;
  margin-right: 12px;
}

.picker-city-name {
  font-size: 15px;
  font-weight: 600;
  color: var(--textPrimary,#1E293B);
  flex: 1;
}

.picker-country {
  font-size: 12px;
  color: var(--textTertiary,#94A3B8);
  margin-right: 12px;
}

.picker-timezone {
  font-size: 11px;
  font-weight: 700;
  color: var(--accentPurpleDark,#7C3AED);
  padding: 4px 8px;
  background: var(--gradientPurpleStart,#DDD6FE);
  border-radius: 6px;
}

.no-result {
  text-align: center;
  padding: 40px;
  color: var(--textTertiary,#94A3B8);
  font-size: 14px;
}

.popular-cities {
  background: white;
  border-radius: 16px;
  padding: 20px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.popular-title {
  font-size: 15px;
  font-weight: 700;
  color: var(--textPrimary,#1E293B);
  display: block;
  margin-bottom: 14px;
}

.popular-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.popular-tag {
  padding: 8px 14px;
  background: linear-gradient(135deg, var(--gradientPurpleStart,#DDD6FE) 0%, var(--gradientPurpleStart,#DDD6FE) 100%);
  border-radius: 16px;
  font-size: 13px;
  font-weight: 600;
  color: var(--accentPurpleDark,#7C3AED);
  transition: transform 0.2s ease;
}

.popular-tag:active {
  transform: scale(0.95);
}