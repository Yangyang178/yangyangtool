<navigation-bar title="垃圾分类查询" back="{{true}}" color="black" background="#F8FAFC"></navigation-bar>

<scroll-view class="tool-page" scroll-y>
  <view class="container">
    <view class="tool-header">
      <view class="icon-wrapper" style="background: linear-gradient(135deg, #10B98133 0%, #10B98166 100%);">
        <view class="icon-decoration"></view>
        <text class="tool-icon">♻️</text>
      </view>
      <text class="tool-title">垃圾分类查询</text>
      <text class="tool-desc">智能识别垃圾类型，轻松分类</text>
    </view>

    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input" 
        placeholder="输入垃圾名称搜索..." 
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        confirm-type="search"
        bindconfirm="onSearch"
      />
      <view class="search-btn" bindtap="onSearch">
        <text>搜索</text>
      </view>
    </view>

    <view class="category-tabs">
      <view 
        class="category-tab {{currentCategory === 'all' ? 'active' : ''}}" 
        style="--cat-color: #64748B;"
        data-category="all"
        bindtap="switchCategory"
      >
        <text>全部</text>
      </view>
      <view 
        class="category-tab {{currentCategory === 'recyclable' ? 'active' : ''}}" 
        style="--cat-color: #3B82F6;"
        data-category="recyclable"
        bindtap="switchCategory"
      >
        <text>可回收</text>
      </view>
      <view 
        class="category-tab {{currentCategory === 'hazardous' ? 'active' : ''}}" 
        style="--cat-color: #EF4444;"
        data-category="hazardous"
        bindtap="switchCategory"
      >
        <text>有害</text>
      </view>
      <view 
        class="category-tab {{currentCategory === 'kitchen' ? 'active' : ''}}" 
        style="--cat-color: #10B981;"
        data-category="kitchen"
        bindtap="switchCategory"
      >
        <text>厨余</text>
      </view>
      <view 
        class="category-tab {{currentCategory === 'other' ? 'active' : ''}}" 
        style="--cat-color: #F97316;"
        data-category="other"
        bindtap="switchCategory"
      >
        <text>其他</text>
      </view>
    </view>

    <view wx:if="{{showResult}}" class="result-card">
      <view class="result-header">
        <text class="result-label">查询结果</text>
      </view>
      <view class="result-content">
        <view class="result-item-name">
          <text>{{resultItem.name}}</text>
        </view>
        <view class="result-category-badge {{resultItem.category}}">
          <text>{{resultItem.categoryText}}</text>
        </view>
        <view class="result-desc">
          <text>{{resultItem.desc}}</text>
        </view>
        <view class="result-tip">
          <text class="tip-icon">💡</text>
          <text class="tip-text">{{resultItem.tip}}</text>
        </view>
      </view>
    </view>

    <view class="items-section">
      <view class="section-header">
        <text class="section-title">{{currentCategory === 'all' ? '常见垃圾' : categoryTitle}}</text>
        <text class="section-count">共{{filteredItems.length}}项</text>
      </view>
      
      <view class="items-grid">
        <view 
          class="item-card {{item.category}}" 
          wx:for="{{filteredItems}}" 
          wx:key="name"
          bindtap="onItemClick"
          data-item="{{item}}"
        >
          <view class="item-emoji">{{item.emoji}}</view>
          <text class="item-name">{{item.name}}</text>
          <view class="item-tag {{item.category}}">
            <text>{{item.categoryShort}}</text>
          </view>
        </view>
      </view>

      <view wx:if="{{filteredItems.length === 0}}" class="empty-state">
        <text class="empty-icon">🔍</text>
        <text class="empty-text">未找到相关物品</text>
      </view>
    </view>

    <view wx:if="{{historyList.length > 0}}" class="history-section">
      <view class="section-header">
        <text class="section-title">查询历史</text>
        <text class="clear-history" bindtap="clearHistory">清空</text>
      </view>
      <view class="history-list">
        <view 
          class="history-item" 
          wx:for="{{historyList}}" 
          wx:key="time"
          bindtap="onHistoryClick"
          data-item="{{item}}"
        >
          <text class="history-name">{{item.name}}</text>
          <view class="history-tag {{item.category}}">
            <text>{{item.categoryText}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</scroll-view>