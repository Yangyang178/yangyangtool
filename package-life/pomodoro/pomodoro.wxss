@import "../../styles/tool-common.wxss";

page { background-color: var(--pageBg,#F8FAFC); }
.tool-page { min-height: 100vh; padding-bottom: 40px; }
.container { padding: 20px; }

.tool-header { text-align: center; margin-bottom: 28px; }
.icon-wrapper { width: 80px; height: 80px; border-radius: 24px; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; background: linear-gradient(135deg, var(--gradientOrangeStart,#FED7AA) 0%, var(--gradientOrangeEnd,#FDBA74) 100%); }
.red-gradient { background: linear-gradient(135deg, var(--accentRed,#EF4444) 0%, var(--accentRedDark,#DC2626) 100%); }
.tool-icon { font-size: 40px; }
.tool-title { font-size: 24px; font-weight: 700; color: var(--textPrimary,#1E293B); display: block; margin-bottom: 8px; }
.tool-desc { font-size: 14px; color: var(--textSecondary,#64748B); }

.timer-section { background: var(--cardBg,#FFFFFF); border-radius: 24px; padding: 32px 20px; box-shadow: 0 4px 20px rgba(239, 68, 68, 0.15); margin-bottom: 20px; text-align: center; }

.progress-ring-wrapper { width: 240px; height: 240px; position: relative; margin: 0 auto 24px; display: flex; align-items: center; justify-content: center; }
.progress-canvas { width: 240px; height: 240px; position: absolute; top: 0; left: 0; z-index: 1; }

.timer-display { z-index: 10; text-align: center; }
.time-text { font-size: 56px; font-weight: 700; color: var(--textPrimary,#1E293B); display: block; letter-spacing: -2px; font-variant-numeric: tabular-nums; }
.status-text { font-size: 16px; color: var(--textSecondary,#64748B); margin-top: 4px; display: block; }
.status-text.working { color: var(--accentRed,#EF4444); font-weight: 600; }
.status-text.breaking { color: var(--accentGreen,#10B981); font-weight: 600; }

.stats-row { display: flex; justify-content: space-around; align-items: center; padding-top: 20px; border-top: 1px solid var(--borderFaint,#F1F5F9); }
.stat-item { text-align: center; }
.stat-value { font-size: 26px; font-weight: 700; color: var(--accentRed,#EF4444); display: block; }
.stat-label { font-size: 12px; color: var(--textSecondary,#64748B); margin-top: 4px; display: block; }
.stat-divider { width: 1px; height: 36px; background: var(--borderLight,#E2E8F0); }

.control-btns { display: flex; gap: 12px; margin-bottom: 24px; }
.main-control-btn { flex: 2; height: 56px; border-radius: 28px; display: flex; align-items: center; justify-content: center; font-size: 17px; font-weight: 700; border: none; background: linear-gradient(135deg, var(--accentRed,#EF4444) 0%, var(--accentRedDark,#DC2626) 100%); color: var(--textOnAccent,#FFFFFF); box-shadow: 0 5px 18px rgba(239, 68, 68, 0.35); transition: all 0.2s ease; }
.main-control-btn.running { background: linear-gradient(135deg, var(--accentYellow,#F59E0B) 0%, var(--accentYellow,#F59E0B) 100%); box-shadow: 0 5px 18px rgba(245, 158, 11, 0.35); }
.main-control-btn:active { transform: scale(0.98); }

.secondary-control-btn, .skip-btn { flex: 1; height: 56px; border-radius: 28px; display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: 600; border: none; background: var(--surfaceBg,#F1F5F9); color: var(--textSecondary,#64748B); }
.skip-btn { background: var(--bgTipRed,#FEF2F2); color: var(--accentRed,#EF4444); }

.settings-section { background: var(--cardBg,#FFFFFF); border-radius: 20px; padding: 20px; box-shadow: 0 2px 12px rgba(0,0,0,0.04); margin-bottom: 20px; }
.settings-title { font-size: 16px; font-weight: 700; color: var(--textPrimary,#1E293B); display: block; margin-bottom: 16px; }

.setting-item { display: flex; justify-content: space-between; align-items: center; padding: 14px 0; border-bottom: 1px solid var(--borderFaint,#F1F5F9); }
.setting-item:last-child { border-bottom: none; }
.setting-label { font-size: 15px; color: var(--textPrimary,#1E293B); font-weight: 500; flex-shrink: 0; margin-right: 12px; }
.setting-picker { font-size: 15px; color: var(--accentRed,#EF4444); font-weight: 600; padding: 6px 12px; background: var(--bgTipRed,#FEF2F2); border-radius: 10px; flex-shrink: 0; }

.round-selector { display: flex; gap: 5px; flex-wrap: nowrap; flex-shrink: 0; }
.round-btn { width: 32px; height: 28px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 600; border: 1.5px solid var(--borderLight,#E2E8F0); background: var(--cardBg,#FFFFFF); color: var(--textSecondary,#64748B); line-height: 1; box-sizing: border-box; padding: 0; }
.round-btn.active { background: linear-gradient(135deg, var(--accentRed,#EF4444) 0%, var(--accentRedDark,#DC2626) 100%); color: var(--textOnAccent,#FFFFFF); border-color: var(--accentRed,#EF4444); }

.history-section { background: var(--cardBg,#FFFFFF); border-radius: 20px; padding: 20px; box-shadow: 0 2px 12px rgba(0,0,0,0.04); }
.history-title { font-size: 16px; font-weight: 700; color: var(--textPrimary,#1E293B); display: block; margin-bottom: 14px; }
.record-list { max-height: 200px; overflow-y: auto; }
.record-item { display: flex; align-items: center; padding: 10px 0; border-bottom: 1px solid var(--pageBg,#F8FAFC); }
.record-item:last-child { border-bottom: none; }
.record-icon { font-size: 20px; margin-right: 12px; }
.record-time { flex: 1; font-size: 13px; color: var(--textSecondary,#64748B); }
.record-duration { font-size: 14px; font-weight: 600; color: var(--textPrimary,#1E293B); }
