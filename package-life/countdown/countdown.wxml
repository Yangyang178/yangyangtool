<navigation-bar title="倒计时" back="{{true}}" color="black" background="#F8FAFC"></navigation-bar>

<scroll-view class="tool-page" scroll-y>
  <view class="container">
    <view class="tool-header">
      <view class="icon-wrapper" style="background: linear-gradient(135deg, #3B82F633 0%, #3B82F666 100%);">
        <view class="icon-decoration"></view>
        <text class="tool-icon">⏰</text>
      </view>
      <text class="tool-title">倒计时</text>
      <text class="text-desc">重要日期倒计时提醒</text>
    </view>

    <view wx:if="{{!hasEvent}}" class="create-section">
      <view class="input-card">
        <view class="input-group">
          <text class="input-label">📝 事件名称</text>
          <input 
            class="text-input" 
            placeholder="例如：春节、生日、考试..." 
            value="{{eventName}}"
            bindinput="onEventNameInput"
            maxlength="20"
          />
        </view>

        <view class="input-group">
          <text class="input-label">📅 目标日期</text>
          <picker mode="date" value="{{targetDate}}" start="{{today}}" end="2099-12-31" bindchange="onDateChange">
            <view class="date-picker-box">
              <text>{{targetDate || '请选择日期'}}</text>
              <text class="picker-icon">📅</text>
            </view>
          </picker>
        </view>

        <view class="input-group">
          <text class="input-label">⏰ 目标时间（可选）</text>
          <picker mode="time" value="{{targetTime}}" bindchange="onTimeChange">
            <view class="date-picker-box">
              <text>{{targetTime || '00:00'}}</text>
              <text class="picker-icon">🕐</text>
            </view>
          </picker>
        </view>

        <view class="quick-events">
          <text class="quick-label">快捷添加：</text>
          <view class="event-tag" wx:for="{{quickEvents}}" wx:key="name" data-event="{{item}}" bindtap="addQuickEvent">
            <text>{{item.icon}} {{item.name}}</text>
          </view>
        </view>

        <view class="create-btn" bindtap="createCountdown">
          <text>✨ 创建倒计时</text>
        </view>
      </view>
    </view>

    <view wx:if="{{hasEvent}}" class="countdown-display">
      <canvas canvas-id="progressCanvas" class="progress-canvas"></canvas>

      <view class="event-info">
        <text class="event-name">{{currentEvent.name}}</text>
        <text class="event-target-date">{{currentEvent.date}} {{currentEvent.time || ''}}</text>
      </view>

      <view class="time-display">
        <view wx:if="{{!isExpired}}" class="time-grid">
          <view class="time-block">
            <text class="time-number">{{timeLeft.days}}</text>
            <text class="time-unit">天</text>
          </view>
          <view class="time-separator">:</view>
          <view class="time-block">
            <text class="time-number">{{timeLeft.hours}}</text>
            <text class="time-unit">时</text>
          </view>
          <view class="time-separator">:</view>
          <view class="time-block">
            <text class="time-number">{{timeLeft.minutes}}</text>
            <text class="time-unit">分</text>
          </view>
          <view class="time-separator">:</view>
          <view class="time-block">
            <text class="time-number">{{timeLeft.seconds}}</text>
            <text class="time-unit">秒</text>
          </view>
        </view>

        <view wx:if="{{isExpired}}" class="expired-display">
          <text class="expired-icon">🎉</text>
          <text class="expired-text">时间已到！</text>
          <text class="expired-sub">{{currentEvent.name}} 已到来</text>
        </view>
      </view>

      <view class="progress-info">
        <text class="progress-text">已过 {{passedPercent}}%</text>
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{passedPercent}}%"></view>
        </view>
      </view>

      <view class="action-buttons">
        <view class="action-btn edit" bindtap="editEvent">
          <text>✏️ 编辑</text>
        </view>
        <view class="action-btn delete" bindtap="deleteEvent">
          <text>🗑️ 删除</text>
        </view>
        <view class="action-btn share" bindtap="shareEvent">
          <text>📤 分享</text>
        </view>
      </view>

      <view wx:if="{{savedEvents.length > 1}}" class="events-list">
        <text class="list-title">其他倒计时</text>
        <view 
          class="event-item {{item.id === currentEvent.id ? 'active' : ''}}"
          wx:for="{{savedEvents}}"
          wx:key="id"
          bindtap="switchEvent"
          data-event="{{item}}"
        >
          <text class="item-name">{{item.name}}</text>
          <text class="item-date">{{item.date}}</text>
          <text class="item-days-left">{{item.daysLeft}}天</text>
        </view>
      </view>
    </view>
  </view>
</scroll-view>