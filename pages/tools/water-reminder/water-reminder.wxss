page { background-color: #F8FAFC; }
.tool-page { min-height: 100vh; padding-bottom: 40px; }
.container { padding: 20px; }

/* 工具头部 */
.tool-header { text-align: center; margin-bottom: 24px; }
.icon-wrapper { width: 80px; height: 80px; border-radius: 24px; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; background: linear-gradient(135deg, #BAE6FD 0%, #7DD3FC 100%); }
.blue-gradient { background: linear-gradient(135deg, #06B6D4 0%, #0891B2 100%); }
.tool-icon { font-size: 40px; }
.tool-title { font-size: 24px; font-weight: 700; color: #1E293B; display: block; margin-bottom: 8px; }
.tool-desc { font-size: 14px; color: #64748B; }

/* 统计卡片 */
.stats-card { background: linear-gradient(135deg, #06B6D4 0%, #0891B2 100%); border-radius: 24px; padding: 28px; display: flex; align-items: center; gap: 20px; margin-bottom: 24px; box-shadow: 0 8px 24px rgba(6, 182, 212, 0.35); }
.water-icon-large { position: relative; width: 80px; height: 80px; flex-shrink: 0; }
.water-emoji { font-size: 48px; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); }
.water-count { position: absolute; bottom: -4px; right: -4px; background: #FFFFFF; border-radius: 12px; padding: 2px 8px; font-size: 18px; font-weight: 700; color: #06B6D4; z-index: 10; }
.water-unit { position: absolute; bottom: -2px; right: -18px; font-size: 11px; color: #FFFFFF; font-weight: 600; }
.stats-info { flex: 1; color: #FFFFFF; }
.stats-title { font-size: 22px; font-weight: 700; display: block; margin-bottom: 4px; }
.stats-target { font-size: 14px; opacity: 0.9; display: block; margin-bottom: 12px; }
.progress-bar-wrapper { width: 100%; height: 8px; background: rgba(255,255,255,0.3); border-radius: 4px; overflow: hidden; margin-bottom: 6px; }
.progress-bar { height: 100%; background: #FFFFFF; border-radius: 4px; transition: width 0.5s ease; }
.progress-text { font-size: 13px; opacity: 0.9; }

/* 设置区域 */
.settings-section { background: #FFFFFF; border-radius: 20px; padding: 20px; box-shadow: 0 2px 12px rgba(0,0,0,0.04); margin-bottom: 20px; }
.section-title { font-size: 16px; font-weight: 700; color: #1E293B; display: block; margin-bottom: 16px; }
.interval-options { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
.interval-btn { background: #F8FAFC; border-radius: 14px; padding: 16px 10px; text-align: center; border: 2px solid transparent; transition: all 0.2s ease; }
.interval-btn.active { background: linear-gradient(135deg, #06B6D4 0%, #0891B2 100%); border-color: #06B6D4; box-shadow: 0 4px 12px rgba(6, 182, 212, 0.25); }
.interval-btn.active .interval-value, .interval-btn.active .interval-unit { color: #FFFFFF !important; }
.interval-value { font-size: 26px; font-weight: 700; color: #1E293B; display: block; line-height: 1; }
.interval-unit { font-size: 12px; color: #64748B; margin-top: 4px; display: block; }

/* 控制区域 */
.control-section { background: #FFFFFF; border-radius: 20px; padding: 24px; box-shadow: 0 2px 12px rgba(0,0,0,0.04); margin-bottom: 20px; text-align: center; }
.start-btn { width: 100%; height: 56px; border-radius: 28px; display: flex; align-items: center; justify-content: center; font-size: 17px; font-weight: 700; border: none; background: linear-gradient(135deg, #06B6D4 0%, #0891B2 100%); color: #FFFFFF; box-shadow: 0 5px 18px rgba(6, 182, 212, 0.35); margin-bottom: 20px; transition: all 0.2s ease; }
.start-btn.running { background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%); box-shadow: 0 5px 18px rgba(245, 158, 11, 0.35); }
.start-btn:active { transform: scale(0.98); }

.status-display { margin-top: 16px; }
.countdown-ring { width: 140px; height: 140px; position: relative; margin: 0 auto 12px; display: flex; align-items: center; justify-content: center; }
.countdown-canvas { width: 140px; height: 140px; position: absolute; top: 0; left: 0; }
.countdown-text { font-size: 32px; font-weight: 700; color: #06B6D4; z-index: 10; position: relative; }
.status-label { font-size: 14px; color: #64748B; }

.stopped-status { padding: 32px 0; }
.stopped-icon { font-size: 48px; display: block; margin-bottom: 12px; opacity: 0.5; }
.stopped-text { font-size: 18px; font-weight: 600; color: #64748B; display: block; margin-bottom: 8px; }
.stopped-hint { font-size: 14px; color: #94A3B8; }

/* 记录区域 */
.records-section { background: #FFFFFF; border-radius: 20px; padding: 20px; box-shadow: 0 2px 12px rgba(0,0,0,0.04); margin-bottom: 20px; }
.records-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
.records-title { font-size: 16px; font-weight: 700; color: #1E293B; }
.clear-btn { font-size: 13px; color: #EF4444; background: none; border: none; padding: 6px 12px; }
.records-list { max-height: 200px; }
.record-item { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid #F8FAFC; }
.record-item:last-child { border-bottom: none; }
.record-time { font-size: 14px; color: #64748B; }
.record-cup { font-size: 14px; font-weight: 600; color: #06B6D4; }

/* 健康提示 */
.tips-section { background: linear-gradient(135deg, #ECFEFF 0%, #CFFAFE 100%); border-radius: 16px; padding: 18px; border-left: 4px solid #06B6D4; }
.tips-title { font-size: 15px; font-weight: 600; color: #0E7490; display: block; margin-bottom: 12px; }
.tips-content { display: flex; flex-direction: column; gap: 6px; }
.tip-item { font-size: 13px; color: #155E75; line-height: 1.5; }
