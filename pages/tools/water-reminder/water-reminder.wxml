<navigation-bar title="喝水提醒" back="{{true}}" color="black" background="#F8FAFC"></navigation-bar>

<view class="tool-page">
  <view class="container">
    <!-- 工具头部 -->
    <view class="tool-header">
      <view class="icon-wrapper blue-gradient">
        <text class="tool-icon">💧</text>
      </view>
      <text class="tool-title">健康饮水助手</text>
      <text class="tool-desc">定时提醒，保持身体水分充足</text>
    </view>

    <!-- 今日统计卡片 -->
    <view class="stats-card">
      <view class="water-icon-large">
        <text class="water-emoji">💧</text>
        <text class="water-count">{{todayCount}}</text>
        <text class="water-unit">杯</text>
      </view>
      
      <view class="stats-info">
        <text class="stats-title">今日饮水</text>
        <text class="stats-target">目标: {{targetCups}} 杯/天</text>
        
        <view class="progress-bar-wrapper">
          <view class="progress-bar" style="width: {{progressPercent}}%"></view>
        </view>
        
        <text class="progress-text">{{progressPercent}}% 完成</text>
      </view>
    </view>

    <!-- 提醒间隔设置 -->
    <view class="settings-section">
      <text class="section-title">⏰ 提醒间隔设置</text>
      
      <view class="interval-options">
        <view 
          wx:for="{{intervalOptions}}" 
          wx:key="value"
          class="interval-btn {{selectedInterval === item.value ? 'active' : ''}}"
          data-value="{{item.value}}"
          bindtap="selectInterval"
        >
          <text class="interval-value">{{item.value}}</text>
          <text class="interval-unit">{{item.unit}}</text>
        </view>
      </view>
    </view>

    <!-- 控制按钮 -->
    <view class="control-section">
      <button 
        class="start-btn {{isRunning ? 'running' : ''}}" 
        bindtap="toggleReminder"
      >
        <text>{{isRunning ? '⏸ 暂停提醒' : '▶ 开始提醒'}}</text>
      </button>

      <view class="status-display" wx:if="{{isRunning}}">
        <view class="countdown-ring">
          <canvas canvas-id="countdownRing" class="countdown-canvas"></canvas>
          <text class="countdown-text">{{nextRemainTime}}</text>
        </view>
        <text class="status-label">下次提醒倒计时</text>
      </view>

      <view class="stopped-status" wx:if="{{!isRunning}}">
        <text class="stopped-icon">⏸️</text>
        <text class="stopped-text">提醒已停止</text>
        <text class="stopped-hint">点击上方按钮开始定时提醒</text>
      </view>
    </view>

    <!-- 今日记录 -->
    <view class="records-section" wx:if="{{records.length > 0}}">
      <view class="records-header">
        <text class="records-title">📋 今日饮水记录</text>
        <button class="clear-btn" bindtap="clearRecords">清空</button>
      </view>
      
      <scroll-view class="records-list" scroll-y enhanced show-scrollbar="{{false}}">
        <view class="record-item" wx:for="{{records}}" wx:key="index">
          <text class="record-time">{{item.time}}</text>
          <text class="record-cup">💧 第{{item.cup}}杯</text>
        </view>
      </scroll-view>
    </view>

    <!-- 健康提示 -->
    <view class="tips-section">
      <text class="tips-title">💡 健康饮水小贴士</text>
      <view class="tips-content">
        <text class="tip-item">• 成人每天建议饮水量: 1500-2000ml (约8杯)</text>
        <text class="tip-item">• 最佳饮水时间: 早起、餐前30分钟、运动后</text>
        <text class="tip-item">• 不要等到口渴才喝水，要少量多次</text>
        <text class="tip-item">• 颜色淡黄=水分充足，深黄=需要补水</text>
      </view>
    </view>
  </view>
</view>
