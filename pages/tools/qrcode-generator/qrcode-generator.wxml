<navigation-bar title="二维码生成器" back="{{true}}" color="black" background="#F8FAFC"></navigation-bar>

<scroll-view class="tool-page" scroll-y>
  <view class="container">
    <!-- 工具头部 -->
    <view class="tool-header">
      <view class="icon-wrapper purple-gradient">
        <text class="tool-icon">📱</text>
      </view>
      <text class="tool-title">二维码生成器</text>
      <text class="tool-desc">输入文本或链接，一键生成二维码</text>
    </view>

    <!-- 输入区域 -->
    <view class="input-section">
      <text class="section-label">输入内容</text>
      <textarea 
        class="content-input"
        placeholder="请输入文本、网址或任何内容..."
        value="{{inputContent}}"
        bindinput="onInput"
        maxlength="500"
        auto-height
      ></textarea>
      <view class="input-footer">
        <text class="char-count">{{inputContent.length}}/500</text>
        <button class="clear-btn" wx:if="{{inputContent}}" bindtap="clearInput">清空</button>
      </view>
    </view>

    <!-- 生成按钮 -->
    <button class="generate-btn {{inputContent ? 'active' : ''}}" bindtap="generateQRCode" disabled="{{!inputContent}}">
      <text>🎨 生成二维码</text>
    </button>

    <!-- 二维码显示区域 -->
    <view class="qrcode-section" wx:if="{{showQRCode}}">
      <view class="qrcode-wrapper">
        <canvas canvas-id="qrcodeCanvas" class="qrcode-canvas"></canvas>
        
        <!-- 如果canvas不显示，用文字提示 -->
        <view class="qrcode-placeholder" wx:if="{{!canvasReady}}">
          <text class="placeholder-text">二维码已生成</text>
          <text class="placeholder-sub">{{inputContent.length > 20 ? inputContent.substring(0, 20) + '...' : inputContent}}</text>
        </view>
      </view>

      <view class="qrcode-info">
        <text class="info-label">内容预览：</text>
        <text class="info-content">{{inputContent}}</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-btns" wx:if="{{showQRCode}}">
      <button class="primary-btn" bindtap="saveToAlbum">
        <text>💾 保存到相册</text>
      </button>
      <button class="secondary-btn" bindtap="shareQRCode">
        <text>📤 分享</text>
      </button>
    </view>

    <!-- 使用说明 -->
    <view class="tips-section">
      <text class="tips-title">💡 使用技巧</text>
      <view class="tips-list">
        <text class="tip-item">• 支持文本、网址、电话号码等多种内容</text>
        <text class="tip-item">• 生成的二维码可保存到手机相册</text>
        <text class="tip-item">• 可用于分享链接、名片、WiFi密码等</text>
      </view>
    </view>
  </view>
</scroll-view>
