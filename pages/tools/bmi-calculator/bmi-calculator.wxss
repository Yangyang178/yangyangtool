page { background-color: var(--pageBg,#F8FAFC); }
.tool-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}
.container { padding: 20px; }

.tool-header { text-align: center; margin-bottom: 24px; }
.icon-wrapper { width: 80px; height: 80px; border-radius: 24px; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; background: linear-gradient(135deg, var(--gradientGreenStart,#D1FAE5) 0%, var(--gradientGreenEnd,#A7F3D0) 100%); }
.tool-icon { font-size: 40px; }
.tool-title { font-size: 24px; font-weight: 700; color: var(--textPrimary,#1E293B); display: block; margin-bottom: 8px; }
.tool-desc { font-size: 14px; color: var(--textSecondary,#64748B); }

.result-card { background: var(--cardBg,#FFFFFF); border-radius: 20px; padding: 28px 20px; margin-bottom: 20px; box-shadow: 0 4px 20px rgba(16,185,129,0.12); text-align: center; }
.bmi-value { font-size: 56px; font-weight: 700; display: block; margin-bottom: 4px; font-variant-numeric: tabular-nums; }
.bmi-label { font-size: 16px; font-weight: 600; display: block; margin-bottom: 12px; }
.bmi-status { display: inline-block; padding: 6px 20px; border-radius: 20px; font-size: 14px; font-weight: 600; margin-bottom: 14px; }
.status-underweight { background: var(--bgTipBlue,#EFF6FF); color: var(--accentBlue,#3B82F6); }
.status-normal { background: var(--bgTipGreen,#ECFDF5); color: var(--accentGreen,#10B981); }
.status-overweight { background: var(--bgTipYellowDeep,#FEF3C7); color: var(--accentYellow,#F59E0B); }
.status-obese { background: var(--bgTipRed,#FEF2F2); color: var(--accentRed,#EF4444); }

.bmi-scale { position: relative; height: 10px; border-radius: 5px; background: linear-gradient(90deg, #3B82F6 0%, #3B82F6 25%, #10B981 25%, #10B981 50%, #F59E0B 50%, #F59E0B 75%, #EF4444 75%, #EF4444 100%); margin-bottom: 8px; }
.scale-labels { display: flex; justify-content: space-between; font-size: 11px; color: var(--textTertiary,#94A3B8); }
.bmi-pointer { width: 8px; height: 8px; border-radius: 50%; background: var(--textPrimary,#1E293B); border: 2px solid var(--cardBg,#FFFFFF); box-shadow: 0 0 0 2px rgba(0,0,0,0.15); transition: all 0.3s ease; position: absolute; top: -4px; transform: translateX(-50%); }

.input-card { background: var(--cardBg,#FFFFFF); border-radius: 20px; padding: 20px; box-shadow: 0 2px 12px rgba(0,0,0,0.04); margin-bottom: 20px; }
.section-title { font-size: 15px; font-weight: 700; color: var(--textPrimary,#1E293B); display: block; margin-bottom: 14px; }

.input-row { display: flex; gap: 12px; margin-bottom: 18px; }
.input-group { flex: 1; }
.input-label { font-size: 13px; color: var(--textSecondary,#64748B); display: block; margin-bottom: 8px; font-weight: 500; }
.input-box { background: var(--pageBg,#F8FAFC); border-radius: 12px; padding: 14px 16px; display: flex; align-items: center; }
.input-field { flex: 1; font-size: 22px; font-weight: 600; color: var(--textPrimary,#1E293B); text-align: center; }
.input-unit { font-size: 14px; color: var(--textTertiary,#94A3B8); font-weight: 500; margin-left: 4px; }

.unit-toggle { display: flex; background: var(--pageBg,#F8FAFC); border-radius: 10px; padding: 4px; margin-bottom: 18px; }
.unit-option { flex: 1; padding: 8px; text-align: center; border-radius: 8px; font-size: 13px; font-weight: 600; color: var(--textSecondary,#64748B); transition: all 0.2s ease; }
.unit-option.active { background: var(--cardBg,#FFFFFF); color: var(--accentGreen,#10B981); box-shadow: 0 1px 4px rgba(0,0,0,0.08); }

.calc-btn { width: 100%; height: 52px; border-radius: 26px; font-size: 17px; font-weight: 700; color: var(--cardBg,#FFFFFF); border: none; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, var(--accentGreen,#10B981) 0%, var(--accentTeal,#14B8A6) 100%); box-shadow: 0 6px 20px rgba(16,185,129,0.35); margin-top: 8px; transition: all 0.2s ease; }
.calc-btn:active { transform: scale(0.97); }

.info-card { background: var(--cardBg,#FFFFFF); border-radius: 20px; padding: 20px; box-shadow: 0 2px 12px rgba(0,0,0,0.04); margin-bottom: 20px; }
.info-title { font-size: 15px; font-weight: 700; color: var(--textPrimary,#1E293B); display: block; margin-bottom: 14px; }
.info-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }
.info-item { background: var(--pageBg,#F8FAFC); border-radius: 10px; padding: 12px; text-align: center; }
.info-item-label { font-size: 11px; color: var(--textTertiary,#94A3B8); display: block; margin-bottom: 4px; }
.info-item-value { font-size: 16px; font-weight: 700; color: var(--textPrimary,#1E293B); }

.advice-card { background: var(--bgTipGreen,#ECFDF5); border-radius: 12px; padding: 14px 16px; border-left: 4px solid var(--accentGreen,#10B981); margin-top: 16px; }
.advice-title { font-size: 14px; font-weight: 600; color: var(--accentGreen,#10B981); display: block; margin-bottom: 8px; }
.advice-text { font-size: 13px; color: var(--textSecondary,#64748B); line-height: 1.6; display: block; }
