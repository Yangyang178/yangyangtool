page { background-color: #F8FAFC; }
.tool-page { height: 100vh; }
.container { padding: 20px; padding-bottom: 40px; }

/* 工具头部 */
.tool-header { text-align: center; margin-bottom: 24px; }
.icon-wrapper { width: 80px; height: 80px; border-radius: 24px; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; background: linear-gradient(135deg, #FECDD3 0%, #FDA4AF 100%); }
.orange-gradient { background: linear-gradient(135deg, #F97316 0%, #EA580C 100%); }
.tool-icon { font-size: 40px; }
.tool-title { font-size: 24px; font-weight: 700; color: #1E293B; display: block; margin-bottom: 8px; }
.tool-desc { font-size: 14px; color: #64748B; }

/* 输入区域 */
.input-section { background: #FFFFFF; border-radius: 20px; padding: 20px; box-shadow: 0 2px 12px rgba(0,0,0,0.04); margin-bottom: 20px; }
.section-label { font-size: 15px; font-weight: 600; color: #1E293B; display: block; margin-bottom: 14px; }

.option-list { display: flex; flex-direction: column; gap: 10px; margin-bottom: 14px; min-height: 60px; }
.option-item { display: flex; align-items: center; padding: 14px 16px; background: #F8FAFC; border-radius: 12px; transition: all 0.2s ease; border: 2px solid transparent; }
.option-item.selected { background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%); border-color: #F59E0B; }
.option-item.winner { background: linear-gradient(135deg, #D1FAE5 0%, #A7F3D0 100%); border-color: #10B981; animation: winner-pulse 0.6s ease; }
@keyframes winner-pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.03); }
}
.option-index { width: 28px; height: 28px; border-radius: 50%; background: #E2E8F0; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 700; color: #64748B; flex-shrink: 0; margin-right: 12px; }
.option-item.winner .option-index { background: #10B981; color: #FFFFFF; }
.option-text { flex: 1; font-size: 15px; font-weight: 500; color: #1E293B; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.delete-btn { width: 28px; height: 28px; border-radius: 50%; background: none; display: flex; align-items: center; justify-content: center; font-size: 16px; color: #94A3B8; padding: 0; line-height: 1; margin-left: 12px; }
.delete-btn:active { color: #EF4444; background: #FEF2F2; }

.add-option-wrapper { display: flex; gap: 10px; margin-bottom: 14px; }
.add-input { flex: 1; height: 46px; background: #F8FAFC; border-radius: 12px; padding: 0 16px; font-size: 15px; color: #1E293B; border: 2px solid transparent; transition: all 0.2s ease; }
.add-input:focus { border-color: #F97316; background: #FFFFFF; }
.add-btn { height: 46px; padding: 0 18px; border-radius: 12px; background: linear-gradient(135deg, #F97316 0%, #EA580C 100%); color: #FFFFFF; font-size: 14px; font-weight: 600; border: none; white-space: nowrap; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 12px rgba(249, 115, 22, 0.25); }
.add-btn[disabled] { opacity: 0.5; }

.quick-add-section { padding-top: 14px; border-top: 1px solid #F1F5F9; }
.quick-label { font-size: 13px; color: #64748B; display: block; margin-bottom: 10px; }
.quick-options { display: flex; gap: 8px; flex-wrap: wrap; }
.quick-tag { padding: 8px 14px; background: #FFF7ED; border-radius: 16px; font-size: 13px; color: #C2410C; font-weight: 500; border: 1px solid #FED7AA; }
.quick-tag:active { transform: scale(0.95); }

/* 抽取按钮 */
.roll-btn { width: 100%; height: 58px; border-radius: 29px; display: flex; align-items: center; justify-content: center; font-size: 18px; font-weight: 700; border: none; margin-bottom: 24px; transition: all 0.3s ease; background: #E2E8F0; color: #94A3B8; }
.roll-btn.active { background: linear-gradient(135deg, #F97316 0%, #EA580C 100%); color: #FFFFFF; box-shadow: 0 6px 24px rgba(249, 115, 22, 0.4); }
.roll-btn.rolling { background: linear-gradient(135deg, #FB923C 0%, #F97316 50%, #EA580C 100%); background-size: 200% 200%; animation: rolling-gradient 1s ease infinite; box-shadow: 0 8px 28px rgba(249, 115, 22, 0.5); }
@keyframes rolling-gradient {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}
.roll-btn:active:not(:disabled) { transform: scale(0.98); }

/* 结果区域 */
.result-section { margin-bottom: 24px; }
.result-card { background: linear-gradient(135deg, #10B981 0%, #059669 100%); border-radius: 24px; padding: 36px 24px; text-align: center; box-shadow: 0 8px 32px rgba(16, 185, 129, 0.35); margin-bottom: 16px; }
.result-icon-wrapper { width: 72px; height: 72px; border-radius: 50%; background: rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; }
.result-emoji { font-size: 40px; }
.result-title { font-size: 16px; color: rgba(255,255,255,0.9); display: block; margin-bottom: 12px; }
.result-answer { background: rgba(255,255,255,0.15); border-radius: 16px; padding: 18px; margin-bottom: 12px; }
.answer-text { font-size: 26px; font-weight: 700; color: #FFFFFF; display: block; line-height: 1.4; word-break: break-all; }
.result-hint { font-size: 13px; color: rgba(255,255,255,0.75); }

.action-row { display: flex; gap: 12px; }
.again-btn, .share-btn { flex: 1; height: 48px; border-radius: 24px; display: flex; align-items: center; justify-content: center; font-size: 15px; font-weight: 600; border: none; }
.again-btn { background: linear-gradient(135deg, #10B981 0%, #059669 100%); color: #FFFFFF; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3); }
.share-btn { background: #F1F5F9; color: #64748B; }

/* 历史记录 */
.history-section { background: #FFFFFF; border-radius: 20px; padding: 20px; box-shadow: 0 2px 12px rgba(0,0,0,0.04); margin-bottom: 20px; }
.history-title { font-size: 16px; font-weight: 700; color: #1E293B; display: block; margin-bottom: 14px; }
.history-list { max-height: 180px; margin-bottom: 12px; }
.history-item { display: flex; justify-content: space-between; align-items: center; padding: 11px 0; border-bottom: 1px solid #F8FAFC; }
.history-item:last-child { border-bottom: none; }
.history-time { font-size: 13px; color: #94A3B8; }
.history-result { font-size: 14px; font-weight: 600; color: #F97316; max-width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.clear-history-btn { width: 100%; height: 42px; border-radius: 21px; background: #FEF2F2; color: #EF4444; font-size: 14px; font-weight: 500; border: none; display: flex; align-items: center; justify-content: center; }

/* 提示区域 */
.tips-section { background: linear-gradient(135deg, #FFF7ED 0%, #FFEDD5 100%); border-radius: 16px; padding: 18px; border-left: 4px solid #F97316; }
.tips-title { font-size: 15px; font-weight: 600; color: #9A3412; display: block; margin-bottom: 12px; }
.tips-content { display: flex; flex-direction: column; gap: 6px; }
.tip-item { font-size: 13px; color: #9A3412; line-height: 1.5; }
