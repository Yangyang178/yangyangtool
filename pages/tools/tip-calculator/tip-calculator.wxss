page { background-color: #F8FAFC; }
.tool-page { height: 100vh; }
.container { padding: 20px; padding-bottom: 40px; }

.tool-header { text-align: center; margin-bottom: 28px; }
.icon-wrapper { width: 80px; height: 80px; border-radius: 24px; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%); }
.yellow-gradient { background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%); }
.tool-icon { font-size: 40px; }
.tool-title { font-size: 24px; font-weight: 700; color: #1E293B; display: block; margin-bottom: 8px; }
.tool-desc { font-size: 14px; color: #64748B; }

.section-label { font-size: 15px; font-weight: 600; color: #1E293B; display: block; margin-bottom: 12px; }

.input-section, .tip-section, .split-section { margin-bottom: 24px; }

.amount-input-wrapper { background: #FFFFFF; border-radius: 16px; padding: 18px 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.04); display: flex; align-items: center; border: 2px solid transparent; transition: all 0.2s ease; }
.amount-input-wrapper:focus-within { border-color: #F59E0B; }
.currency-symbol { font-size: 32px; font-weight: 700; color: #F59E0B; margin-right: 10px; }
.amount-input { flex: 1; font-size: 32px; font-weight: 600; color: #1E293B; }

.tip-options { display: flex; gap: 10px; flex-wrap: wrap; }
.tip-option { width: calc(25% - 8px); height: 52px; border-radius: 14px; background: #FFFFFF; display: flex; align-items: center; justify-content: center; box-shadow: 0 1px 4px rgba(0,0,0,0.04); transition: all 0.2s ease; border: 2px solid transparent; }
.tip-option.active { background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%); border-color: #F59E0B; }
.tip-option.active .tip-value { color: #FFFFFF; }
.tip-value { font-size: 16px; font-weight: 600; color: #64748B; }

.custom-tip-input { margin-top: 12px; display: flex; align-items: center; background: #FFFFFF; border-radius: 12px; padding: 14px 16px; box-shadow: 0 1px 4px rgba(0,0,0,0.04); }
.custom-tip-input input { flex: 1; font-size: 18px; color: #1E293B; }
.percent-sign { font-size: 18px; font-weight: 600; color: #F59E0B; margin-left: 8px; }

.people-selector { display: flex; align-items: center; justify-content: center; gap: 20px; background: #FFFFFF; border-radius: 16px; padding: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.04); }
.minus-btn, .plus-btn { width: 44px; height: 44px; border-radius: 50%; background: #F8FAFC; display: flex; align-items: center; justify-content: center; font-size: 24px; color: #64748B; border: none; line-height: 1; }
.minus-btn:active, .plus-btn:active { background: #F59E0B; color: #FFFFFF; }
.people-count { font-size: 28px; font-weight: 700; color: #1E293B; min-width: 60px; text-align: center; }

.result-section { margin-bottom: 24px; }
.result-card { background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%); border-radius: 20px; padding: 28px; text-align: center; margin-bottom: 16px; box-shadow: 0 8px 24px rgba(245, 158, 11, 0.3); }
.result-title { font-size: 15px; color: rgba(255,255,255,0.9); display: block; margin-bottom: 8px; }
.result-amount { font-size: 48px; font-weight: 700; color: #FFFFFF; }

.result-details { background: #FFFFFF; border-radius: 16px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.04); }
.detail-item { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid #F1F5F9; }
.detail-item:last-child { border-bottom: none; }
.detail-label { font-size: 15px; color: #64748B; }
.detail-value { font-size: 18px; font-weight: 700; color: #1E293B; }
.tip-color { color: #F59E0B !important; }
.total-color { color: #DC2626 !important; font-size: 22px !important; }
.total-row { padding-top: 16px; margin-top: 8px; border-top: 2px solid #E2E8F0 !important; border-bottom: none !important; }

.action-buttons { display: flex; gap: 12px; }
.copy-btn, .reset-btn { flex: 1; height: 52px; border-radius: 26px; display: flex; align-items: center; justify-content: center; font-size: 16px; font-weight: 600; border: none; }
.copy-btn { background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%); color: #FFFFFF; box-shadow: 0 4px 12px rgba(245, 158, 11, 0.3); }
.reset-btn { background: #F1F5F9; color: #64748B; }
