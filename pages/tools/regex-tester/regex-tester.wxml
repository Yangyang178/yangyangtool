<navigation-bar title="正则表达式测试" back="{{true}}" color="black" background="#F8FAFC"></navigation-bar>

<scroll-view class="tool-page" scroll-y>
  <view class="container">
    <view class="tool-header">
      <view class="icon-wrapper" style="background: linear-gradient(135deg, #8B5CF633 0%, #8B5CF666 100%);">
        <text class="tool-icon">🔍</text>
      </view>
      <text class="tool-title">正则表达式测试</text>
      <text class="tool-desc">实时测试、调试正则表达式</text>
    </view>

    <view class="regex-input-section">
      <view class="section-header-row">
        <text class="section-label">⚡ 正则表达式</text>
        <view class="regex-actions">
          <view class="action-tag sample" bindtap="loadSampleRegex">
            <text>📄 示例</text>
          </view>
          <view class="action-tag clear" bindtap="clearRegex">
            <text>🗑️ 清空</text>
          </view>
        </view>
      </view>
      
      <view class="regex-input-wrapper">
        <text class="regex-slash">/</text>
        <input 
          class="regex-input"
          placeholder="输入正则表达式"
          value="{{regexPattern}}"
          bindinput="onRegexInput"
        />
        <text class="regex-slash">/</text>
        <view class="flags-display">{{currentFlags}}</view>
      </view>

      <view class="flags-section">
        <text class="flags-label">标志位：</text>
        <view 
          class="flag-btn {{flags.g ? 'active' : ''}}"
          data-flag="g"
          bindtap="toggleFlag"
        >
          <text class="flag-name">g</text>
          <text class="flag-desc">全局</text>
        </view>
        <view 
          class="flag-btn {{flags.i ? 'active' : ''}}"
          data-flag="i"
          bindtap="toggleFlag"
        >
          <text class="flag-name">i</text>
          <text class="flag-desc">忽略大小写</text>
        </view>
        <view 
          class="flag-btn {{flags.m ? 'active' : ''}}"
          data-flag="m"
          bindtap="toggleFlag"
        >
          <text class="flag-name">m</text>
          <text class="flag-desc">多行模式</text>
        </view>
      </view>

      <view wx:if="{{errorMsg}}" class="error-msg">
        <text class="error-icon">❌</text>
        <text class="error-text">{{errorMsg}}</text>
      </view>
    </view>

    <view class="test-text-section">
      <view class="section-header-row">
        <text class="section-label">📝 测试文本</text>
        <view class="test-actions">
          <view class="action-tag paste" bindtap="pasteText">
            <text>📋 粘贴</text>
          </view>
        </view>
      </view>

      <textarea 
        class="test-textarea"
        placeholder="在此输入要匹配的文本..."
        value="{{testText}}"
        bindinput="onTextInput"
        auto-height
        maxlength="-1"
      ></textarea>

      <view class="text-stats">
        <text class="stat-item">字符数: {{textLength}}</text>
        <text class="stat-item">行数: {{lineCount}}</text>
      </view>
    </view>

    <view class="action-buttons">
      <view class="main-btn test" bindtap="testRegex">
        <text>🔍 测试匹配</text>
      </view>
      <view class="main-btn replace" bindtap="showReplacePanel">
        <text>🔄 替换</text>
      </view>
    </view>

    <view wx:if="{{showReplace}}" class="replace-section">
      <view class="replace-input-group">
        <text class="replace-label">替换为：</text>
        <input 
          class="replace-input"
          placeholder="替换后的文本"
          value="{{replaceText}}"
          bindinput="onReplaceInput"
        />
      </view>
      <view class="replace-btn" bindtap="executeReplace">
        <text>✨ 执行替换</text>
      </view>
    </view>

    <view wx:if="{{matchResult}}" class="result-section">
      <view class="result-header">
        <text class="result-title">🎯 匹配结果</text>
        <view class="match-stats">
          <view class="stat-badge success">
            <text>✅ {{matchCount}} 个匹配</text>
          </view>
        </view>
      </view>

      <view class="highlighted-text">
        <rich-text nodes="{{highlightedText}}"></rich-text>
      </view>

      <view wx:if="{{matches.length > 0}}" class="matches-list">
        <text class="matches-title">匹配详情</text>
        <view 
          class="match-item"
          wx:for="{{matches}}"
          wx:key="index"
        >
          <view class="match-index">
            <text>#{{index + 1}}</text>
          </view>
          <view class="match-content">
            <text class="match-value">"{{item.match}}"</text>
            <text class="match-position">位置: {{item.index}}</text>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{!matchResult && hasTested}}" class="no-match-section">
      <text class="no-match-icon">😕</text>
      <text class="no-match-text">未找到匹配项</text>
    </view>

    <view class="library-section">
      <text class="library-title">📚 常用正则表达式</text>
      <view class="library-grid">
        <view 
          class="library-item"
          wx:for="{{commonRegexes}}"
          wx:key="name"
          data-regex="{{item}}"
          bindtap="selectLibraryRegex"
        >
          <text class="library-name">{{item.name}}</text>
          <text class="library-pattern">{{item.pattern}}</text>
          <text class="library-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>

    <view class="tips-section">
      <text class="tips-title">💡 快捷参考</text>
      <view class="tips-grid">
        <view class="tip-card">
          <text class="tip-pattern">\d</text>
          <text class="tip-meaning">数字</text>
        </view>
        <view class="tip-card">
          <text class="tip-pattern">\w</text>
          <text class="tip-meaning">单词字符</text>
        </view>
        <view class="tip-card">
          <text class="tip-pattern">\s</text>
          <text class="tip-meaning">空白符</text>
        </view>
        <view class="tip-card">
          <text class="tip-pattern">.</text>
          <text class="tip-meaning">任意字符</text>
        </view>
        <view class="tip-card">
          <text class="tip-pattern">*</text>
          <text class="tip-meaning">0次或多次</text>
        </view>
        <view class="tip-card">
          <text class="tip-pattern">+</text>
          <text class="tip-meaning">1次或多次</text>
        </view>
        <view class="tip-card">
          <text class="tip-pattern">?</text>
          <text class="tip-meaning">0次或1次</text>
        </view>
        <view class="tip-card">
          <text class="tip-pattern">{n}</text>
          <text class="tip-meaning">恰好n次</text>
        </view>
      </view>
    </view>
  </view>
</scroll-view>