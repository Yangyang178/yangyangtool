<navigation-bar title="大小写转换" back="{{true}}" color="black" background="#F8FAFC"></navigation-bar>

<scroll-view class="tool-page" scroll-y>
  <view class="container">
    <view class="tool-header">
      <view class="icon-wrapper" style="background: linear-gradient(135deg, #FCE7F3 0%, #FBCFE8 100%);">
        <text class="tool-icon">🔤</text>
      </view>
      <text class="tool-title">大小写转换</text>
      <text class="tool-desc">英文大小写一键切换，5种模式任选</text>
    </view>

    <!-- 转换模式选择 -->
    <view class="mode-section">
      <text class="section-label">选择转换模式</text>
      <view class="modes-grid">
        <view 
          wx:for="{{modes}}" 
          wx:key="id"
          class="mode-item {{currentMode === item.id ? 'active' : ''}}"
          data-mode="{{item.id}}"
          bindtap="selectMode"
        >
          <text class="mode-icon">{{item.icon}}</text>
          <text class="mode-name">{{item.name}}</text>
        </view>
      </view>
    </view>

    <!-- 输入区域 -->
    <view class="input-section">
      <text class="section-label">输入文本</text>
      <textarea 
        class="text-area"
        placeholder="请输入需要转换的英文文本..."
        value="{{inputText}}"
        bindinput="onInput"
        auto-height
      ></textarea>
    </view>

    <!-- 转换结果 -->
    <view class="output-section" wx:if="{{outputText}}">
      <text class="section-label">转换结果</text>
      <view class="result-box">
        <text class="result-text">{{outputText}}</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-btns">
      <button class="primary-btn" bindtap="copyResult">
        <text>📋 复制结果</text>
      </button>
      <button class="secondary-btn" bindtap="clearAll">
        <text>🗑️ 清空</text>
      </button>
    </view>
  </view>
</scroll-view>
