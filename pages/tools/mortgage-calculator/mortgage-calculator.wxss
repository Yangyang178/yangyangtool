page { background-color: var(--pageBg,#F8FAFC); }
.tool-page { height: 100vh; box-sizing: border-box; overflow-x: hidden; }
.container { padding: 16px; padding-bottom: 40px; box-sizing: border-box; width: 100%; }

.tool-header { text-align: center; margin-bottom: 24px; }
.icon-wrapper { width: 72px; height: 72px; border-radius: 20px; display: flex; align-items: center; justify-content: center; margin: 0 auto 14px; background: linear-gradient(135deg, var(--bgTipGreen,#ECFDF5) 0%, #A7F3D0 100%); }
.green-gradient { background: linear-gradient(135deg, var(--accentGreen,#10B981) 0%, var(--accentGreen,#10B981) 100%); }
.tool-icon { font-size: 36px; }
.tool-title { font-size: 22px; font-weight: 700; color: var(--textPrimary,#1E293B); display: block; margin-bottom: 6px; }
.tool-desc { font-size: 13px; color: var(--textSecondary,#64748B); }

.form-section { background: var(--cardBg,#FFFFFF); border-radius: 18px; padding: 20px; box-shadow: 0 2px 12px rgba(0,0,0,0.04); margin-bottom: 20px; }

.input-group { margin-bottom: 18px; }
.input-group:last-child { margin-bottom: 0; }

.label-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; flex-wrap: wrap; gap: 4px; }
.label { font-size: 14px; font-weight: 600; color: var(--textPrimary,#1E293B); display: block; margin-bottom: 10px; }
.unit-hint { font-size: 11px; color: var(--textTertiary,#94A3B8); font-weight: 400; white-space: nowrap; }

.input { width: 100%; height: 46px; background: var(--pageBg,#F8FAFC); border-radius: 12px; padding: 0 14px; font-size: 15px; color: var(--textPrimary,#1E293B); border: 2px solid transparent; transition: all 0.2s ease; box-sizing: border-box; }
.input:focus { border-color: var(--accentGreen,#10B981); background: var(--cardBg,#FFFFFF); }

.picker-value { height: 46px; background: var(--pageBg,#F8FAFC); border-radius: 12px; padding: 0 14px; display: flex; align-items: center; font-size: 15px; color: var(--textPrimary,#1E293B); box-sizing: border-box; }

.rate-tips { display: flex; gap: 6px; margin-top: 8px; flex-wrap: wrap; }
.tip-item { padding: 5px 12px; background: var(--bgTipGreen,#ECFDF5); border-radius: 14px; font-size: 12px; color: var(--accentGreen,#10B981); font-weight: 500; }

.type-selector { display: flex; gap: 10px; }
.type-btn { flex: 1; height: 52px; border-radius: 12px; display: flex; flex-direction: column; align-items: center; justify-content: center; background: var(--pageBg,#F8FAFC); border: 2px solid transparent; transition: all 0.2s ease; box-sizing: border-box; }
.type-btn text:first-child { font-size: 14px; color: var(--textSecondary,#64748B); font-weight: 600; }
.type-desc { font-size: 10px; color: var(--textTertiary,#94A3B8); margin-top: 2px; }
.type-btn.active { background: linear-gradient(135deg, var(--accentGreen,#10B981) 0%, var(--accentGreen,#10B981) 100%); }
.type-btn.active text:first-child { color: var(--cardBg,#FFFFFF); }
.type-btn.active .type-desc { color: rgba(255,255,255,0.85); }

.action-btns { display: flex; gap: 10px; margin-bottom: 20px; }
.primary-btn, .secondary-btn { flex: 1; height: 50px; border-radius: 25px; display: flex; align-items: center; justify-content: center; font-size: 15px; font-weight: 600; border: none; box-sizing: border-box; }
.primary-btn { background: linear-gradient(135deg, var(--accentGreen,#10B981) 0%, var(--accentGreen,#10B981) 100%); color: var(--cardBg,#FFFFFF); box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3); }
.secondary-btn { background: var(--surfaceBg,#F1F5F9); color: var(--textSecondary,#64748B); }

.result-section { margin-bottom: 20px; }
.result-card { background: linear-gradient(135deg, var(--accentGreen,#10B981) 0%, var(--accentGreen,#10B981) 100%); border-radius: 18px; padding: 24px 20px; text-align: center; margin-bottom: 14px; box-shadow: 0 8px 24px rgba(16, 185, 129, 0.3); }
.main-result { padding: 28px 20px; }
.result-label { font-size: 14px; color: rgba(255,255,255,0.9); display: block; margin-bottom: 6px; }
.result-value { font-size: 38px; font-weight: 700; color: var(--cardBg,#FFFFFF); display: block; word-break: break-all; }
.result-unit { font-size: 14px; color: rgba(255,255,255,0.85); display: block; margin-top: 4px; }
.amount-info { font-size: 11px; color: rgba(255,255,255,0.7); display: block; margin-top: 8px; }

.result-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }
.result-item { background: var(--cardBg,#FFFFFF); border-radius: 12px; padding: 14px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.04); box-sizing: border-box; }
.item-label { font-size: 12px; color: var(--textSecondary,#64748B); display: block; margin-bottom: 4px; }
.item-value { font-size: 17px; font-weight: 700; color: var(--textPrimary,#1E293B); word-break: break-all; }
.item-value.interest { color: var(--accentRed,#EF4444); }
.item-unit { font-size: 10px; color: var(--textTertiary,#94A3B8); display: block; margin-top: 2px; }

.extra-info { background: var(--bgTipGreen,#ECFDF5); border-radius: 12px; padding: 14px; margin-top: 14px; border-left: 4px solid var(--accentGreen,#10B981); }
.info-row { display: flex; justify-content: space-between; align-items: center; padding: 6px 0; }
.info-row + .info-row { border-top: 1px solid var(--bgTipGreen,#ECFDF5); }
.info-label { font-size: 13px; color: #065F46; font-weight: 500; }
.info-value { font-size: 14px; font-weight: 700; color: #047857; }
.info-row.highlight .info-label { color: #047857; font-weight: 700; }
.info-row.highlight .info-value { color: var(--accentRedDark,#DC2626); font-size: 15px; }

.compare-section { background: #FFFBEB; border-radius: 12px; padding: 14px; margin-top: 14px; border-left: 4px solid var(--accentYellow,#F59E0B); }
.compare-title { font-size: 13px; font-weight: 600; color: var(--textPrimary,#1E293B); display: block; margin-bottom: 8px; }
.compare-item { padding: 4px 0; }
.compare-text { font-size: 12px; color: var(--textSecondary,#64748B); line-height: 1.5; }
.compare-num { color: var(--accentYellow,#F59E0B); font-weight: 700; }

.tips-section { background: var(--bgTipBlue,#EFF6FF); border-radius: 12px; padding: 14px; border-left: 4px solid var(--accentBlue,#3B82F6); }
.tips-title { font-size: 13px; font-weight: 600; color: var(--accentBlue,#3B82F6); display: block; margin-bottom: 8px; }
.tips-list { display: flex; flex-direction: column; gap: 4px; }
.tip-item { font-size: 11px; color: var(--accentBlue,#3B82F6); line-height: 1.45; word-break: break-all; }
