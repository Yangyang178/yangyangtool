page {
  height: 100vh;
  background-color: var(--pageBg,#F8FAFC);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.main-scroll {
  flex: 1;
  height: 100vh;
}

.page-container {
  padding: 0 20px;
  padding-bottom: 100px;
  min-height: calc(100vh - 100px);
}

/* 用户信息区 */
.user-section {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 28px 0 24px;
}

.user-section:active {
  opacity: 0.8;
}

.user-avatar {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  background: linear-gradient(135deg, #DBEAFE 0%, #BFDBFE 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
  position: relative;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-icon {
  font-size: 32px;
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 4px;
  flex: 1;
}

.user-name-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.user-nickname {
  font-size: 20px;
  font-weight: 700;
  color: var(--textPrimary,#1E293B);
}

.edit-icon {
  font-size: 14px;
  opacity: 0.5;
}

.user-stats {
  font-size: 13px;
  color: var(--textSecondary,#64748B);
}

/* 区块通用 */
.section-block {
  background: var(--cardBg,#FFFFFF);
  border-radius: 16px;
  padding: 18px 16px;
  margin-bottom: 14px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.03);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14px;
}

.section-title-row {
  display: flex;
  align-items: center;
  gap: 6px;
}

.section-icon {
  font-size: 16px;
}

.section-title {
  font-size: 16px;
  font-weight: 700;
  color: var(--textPrimary,#1E293B);
}

.section-subtitle {
  font-size: 12px;
  color: var(--textTertiary,#94A3B8);
}

/* 最近使用列表 */
.recent-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.recent-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 8px;
  border-radius: 10px;
  transition: background 0.15s ease;
}

.recent-item-hover {
  background: var(--surfaceBg,#F1F5F9);
}

.recent-icon-wrapper {
  width: 42px;
  height: 42px;
  border-radius: 11px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.recent-icon {
  font-size: 22px;
}

.recent-content {
  flex: 1;
  min-width: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.recent-name {
  font-size: 14px;
  font-weight: 600;
  color: var(--textPrimary,#1E293B);
}

.recent-time {
  font-size: 12px;
  color: var(--textTertiary,#94A3B8);
  flex-shrink: 0;
  margin-left: 8px;
}

/* 收藏预览 */
.fav-preview {
  padding: 6px 0;
}

.fav-names {
  font-size: 13px;
  color: var(--textSecondary,#64748B);
  line-height: 1.7;
}

/* 空状态小版 */
.empty-mini {
  text-align: center;
  padding: 12px 0;
}

.empty-mini text {
  font-size: 13px;
  color: var(--textTertiary,#94A3B8);
}

/* 查看全部按钮 */
.see-all-btn {
  margin-top: 12px;
  text-align: center;
  padding-top: 12px;
  border-top: 1px solid var(--borderFaint,#F1F5F9);
}

.see-all-btn text {
  font-size: 13px;
  color: var(--accentBlue,#3B82F6);
  font-weight: 500;
}

/* 设置列表 */
.settings-list {
  display: flex;
  flex-direction: column;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 4px;
  border-bottom: 1px solid var(--borderFaint,#F1F5F9);
  transition: background 0.15s ease;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-hover {
  background: var(--surfaceBg,#F1F5F9);
  border-radius: 8px;
}

.setting-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

.setting-icon {
  font-size: 18px;
}

.setting-name {
  font-size: 14px;
  font-weight: 500;
  color: var(--textPrimary,#1E293B);
}

.setting-right {
  display: flex;
  align-items: center;
  gap: 6px;
}

.setting-value {
  font-size: 12px;
  color: var(--textTertiary,#94A3B8);
}

.setting-arrow {
  font-size: 18px;
  color: var(--textTertiary,#CBD5E1);
  font-weight: 300;
}

/* Banner广告位 */
.banner-ad {
  background: linear-gradient(135deg, #F1F5F9 0%, #E2E8F0 100%);
  border-radius: 12px;
  padding: 32px 20px;
  text-align: center;
  border: 2px dashed var(--borderLight,#CBD5E1);
  margin-top: 4px;
}

.banner-text {
  font-size: 14px;
  color: var(--textTertiary,#94A3B8);
  font-weight: 500;
}

.bottom-safe-area {
  height: 40px;
}

/* ==================== 编辑资料弹窗 ==================== */
.profile-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 998;
}

.profile-panel {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: white;
  border-radius: 24px 24px 0 0;
  padding: 24px 20px 40px;
  z-index: 999;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.profile-panel.show {
  transform: translateY(0);
}

.profile-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24px;
}

.profile-title {
  font-size: 18px;
  font-weight: 700;
  color: var(--textPrimary,#1E293B);
}

.profile-close {
  font-size: 22px;
  color: var(--textSecondary,#64748B);
  padding: 4px;
}

.profile-avatar-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  margin-bottom: 24px;
}

.profile-avatar-preview {
  width: 90px;
  height: 90px;
  border-radius: 50%;
  background: linear-gradient(135deg, #DBEAFE 0%, #BFDBFE 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: 3px solid var(--borderLight,#E2E8F0);
}

.avatar-img-large {
  width: 90px;
  height: 90px;
  border-radius: 50%;
}

.avatar-img-large-wrap {
  width: 90px;
  height: 90px;
  display: block;
}

.avatar-placeholder-large {
  font-size: 36px;
}

.avatar-hint {
  font-size: 12px;
  color: var(--accentBlue,#3B82F6);
  font-weight: 500;
}

.profile-input-group {
  margin-bottom: 20px;
}

.profile-input-label {
  display: block;
  font-size: 14px;
  font-weight: 600;
  color: var(--textPrimary,#1E293B);
  margin-bottom: 10px;
}

.profile-input {
  width: 100%;
  height: 48px;
  background: var(--surfaceBg,#F1F5F9);
  border-radius: 12px;
  padding: 0 16px;
  font-size: 16px;
  color: var(--textPrimary,#1E293B);
  box-sizing: border-box;
}

.profile-color-section {
  margin-bottom: 28px;
}

.color-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 10px;
}

.color-option {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3px solid transparent;
  transition: all 0.2s ease;
  position: relative;
}

.color-option.selected {
  border-color: var(--accentBlue,#3B82F6);
  transform: scale(1.1);
}

.check-mark {
  color: white;
  font-size: 18px;
  font-weight: 700;
  text-shadow: 0 1px 2px rgba(0,0,0,0.3);
}

.save-profile-btn {
  width: 100%;
  height: 50px;
  border-radius: 25px;
  font-size: 17px;
  font-weight: 700;
  color: white;
  background: linear-gradient(135deg, var(--accentBlue,#3B82F6) 0%, #2563EB 100%);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 14px rgba(59,130,246,0.3);
}

/* ==================== 意见反馈弹窗 ==================== */
.feedback-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 998;
}

.feedback-panel {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: white;
  border-radius: 24px 24px 0 0;
  padding: 24px 20px 40px;
  z-index: 999;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 85vh;
}

.feedback-panel.show {
  transform: translateY(0);
}

.feedback-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24px;
}

.feedback-title {
  font-size: 18px;
  font-weight: 700;
  color: var(--textPrimary,#1E293B);
}

.feedback-close {
  font-size: 22px;
  color: var(--textSecondary,#64748B);
  padding: 4px;
}

.feedback-form {
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.form-label {
  font-size: 14px;
  font-weight: 600;
  color: var(--textPrimary,#1E293B);
}

.required {
  color: #EF4444;
  font-size: 12px;
}

.type-options {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.type-option {
  padding: 10px 16px;
  border-radius: 12px;
  border: 2px solid var(--borderLight,#E2E8F0);
  background: var(--surfaceBg,#F8FAFC);
  font-size: 13px;
  font-weight: 500;
  color: var(--textSecondary,#64748B);
  transition: all 0.2s ease;
}

.type-option.active {
  border-color: var(--accentBlue,#3B82F6);
  background: rgba(59,130,246,0.08);
  color: var(--accentBlue,#3B82F6);
  font-weight: 600;
}

.form-input {
  width: 100%;
  height: 46px;
  background: var(--surfaceBg,#F1F5F9);
  border-radius: 12px;
  padding: 0 16px;
  font-size: 15px;
  color: var(--textPrimary,#1E293B);
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 120px;
  max-height: 200px;
  background: var(--surfaceBg,#F1F5F9);
  border-radius: 12px;
  padding: 14px 16px;
  font-size: 15px;
  color: var(--textPrimary,#1E293B);
  box-sizing: border-box;
  line-height: 1.6;
}

.char-count {
  text-align: right;
  font-size: 12px;
  color: var(--textTertiary,#94A3B8);
  margin-top: -8px;
}

.submit-feedback-btn {
  width: 100%;
  height: 50px;
  border-radius: 25px;
  font-size: 17px;
  font-weight: 700;
  color: white;
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 14px rgba(16,185,129,0.3);
  margin-top: 8px;
}

.submit-feedback-btn.disabled {
  opacity: 0.6;
}
