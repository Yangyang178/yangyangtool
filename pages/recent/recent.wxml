<navigation-bar title="我的" back="{{false}}" color="{{isDarkMode ? 'white' : 'black'}}" background="{{isDarkMode ? '#0F172A' : '#F8FAFC'}}"></navigation-bar>

<scroll-view class="main-scroll {{isDarkMode ? 'dark-mode' : ''}}" scroll-y enhanced show-scrollbar="{{false}}" bounces="{{false}}">
  <view class="page-container">

    <!-- 用户信息区 -->
    <view class="user-section" bindtap="openEditProfile">
      <view class="user-avatar" style="{{userInfo.avatarBg ? 'background:' + userInfo.avatarBg : ''}}">
        <image wx:if="{{userInfo.avatarUrl}}" class="avatar-img" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
        <text wx:else class="avatar-icon">👤</text>
      </view>
      <view class="user-info">
        <view class="user-name-row">
          <text class="user-nickname">{{userInfo.nickname}}</text>
          <text class="edit-icon">✏️</text>
        </view>
        <text class="user-stats">{{funStats.levelIcon}} {{funStats.efficiencyLevel}} · 已节省 {{funStats.savedTime}}</text>
      </view>
    </view>

    <!-- 趣味化统计卡片 -->
    <view class="fun-stats-card">
      <view class="stats-header">
        <text class="stats-title">⚡ 效率统计</text>
        <text class="stats-subtitle">累计数据</text>
      </view>
      
      <view class="stats-main">
        <view class="stat-item highlight">
          <text class="stat-number">{{funStats.operationCount}}</text>
          <text class="stat-label">次操作</text>
        </view>
        
        <view class="stat-divider"></view>
        
        <view class="stat-item">
          <text class="stat-number">{{funStats.savedTime}}</text>
          <text class="stat-label">已节省</text>
        </view>
        
        <view class="stat-divider"></view>
        
        <view class="stat-item">
          <text class="stat-icon-large">{{funStats.levelIcon}}</text>
          <text class="stat-label">{{funStats.efficiencyLevel}}</text>
        </view>
      </view>

      <view class="progress-section">
        <view class="progress-label">
          <text>效率进度</text>
          <text>{{funStats.progressPercent}}%</text>
        </view>
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{funStats.progressPercent}}%"></view>
        </view>
      </view>
    </view>

    <!-- 使用足迹图表 -->
    <view class="section-block footprint-section">
      <view class="section-header">
        <view class="section-title-row">
          <text class="section-icon">📊</text>
          <text class="section-title">使用足迹</text>
        </view>
        <text class="section-subtitle">(本周)</text>
      </view>

      <!-- 图表区域 -->
      <view class="chart-container">
        <view class="chart-y-axis">
          <text class="y-label">{{weeklyData.maxValue}}</text>
          <text class="y-label">{{Math.floor(weeklyData.maxValue * 0.5)}}</text>
          <text class="y-label">0</text>
        </view>
        
        <view class="chart-bars">
          <view 
            wx:for="{{weeklyData.labels}}" 
            wx:key="index"
            class="bar-wrapper"
          >
            <view class="bar-container">
              <view 
                class="bar {{item === weeklyData.mostUsedDay ? 'active' : ''}}"
                style="height: {{weeklyData.values[index] > 0 ? (weeklyData.values[index] / weeklyData.maxValue * 100) : 2}}%"
              ></view>
              <text class="bar-value" wx:if="{{weeklyData.values[index] > 0}}">{{weeklyData.values[index]}}</text>
            </view>
            <text class="x-label {{item === weeklyData.mostUsedDay ? 'active' : ''}}">{{item}}</text>
          </view>
        </view>
      </view>

      <!-- 统计摘要 -->
      <view class="footprint-summary">
        <view class="summary-item">
          <text class="summary-value">{{weeklyData.totalWeekUsage}}</text>
          <text class="summary-label">本周总次数</text>
        </view>
        <view class="summary-item">
          <text class="summary-value">{{weeklyData.averageDaily}}</text>
          <text class="summary-label">日均使用</text>
        </view>
        <view class="summary-item">
          <text class="summary-value">{{weeklyData.mostUsedDay}}</text>
          <text class="summary-label">最活跃日</text>
        </view>
      </view>
    </view>

    <!-- 编辑用户信息弹窗 -->
    <view class="profile-mask" wx:if="{{showEditProfile}}" bindtap="closeEditProfile"></view>
    <view class="profile-panel {{showEditProfile ? 'show' : ''}}">
      <view class="profile-header">
        <text class="profile-title">✏️ 编辑资料</text>
        <text class="profile-close" bindtap="closeEditProfile">✕</text>
      </view>

      <!-- 头像选择 -->
      <view class="profile-avatar-area" bindtap="chooseAvatar">
        <view class="profile-avatar-preview" style="{{userInfo.avatarBg ? 'background:' + userInfo.avatarBg : ''}}">
          <image wx:if="{{tempAvatarUrl}}" class="avatar-img-large" src="{{tempAvatarUrl}}" mode="aspectFill"></image>
          <text wx:elif="{{userInfo.avatarUrl}}" class="avatar-img-large-wrap"><image class="avatar-img-large" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image></text>
          <text wx:else class="avatar-placeholder-large">📷</text>
        </view>
        <text class="avatar-hint">点击更换头像</text>
      </view>

      <!-- 昵称输入 -->
      <view class="profile-input-group">
        <text class="profile-input-label">昵称</text>
        <input class="profile-input" value="{{editNickname}}" placeholder="请输入昵称" maxlength="12" bindinput="onNicknameInput"/>
      </view>

      <!-- 头像背景色选择 -->
      <view class="profile-color-section">
        <text class="profile-input-label">头像背景色</text>
        <view class="color-options">
          <view wx:for="{{avatarColors}}" wx:key="color"
            class="color-option {{selectedAvatarColor === item.color ? 'selected' : ''}}"
            style="background: {{item.color}}"
            data-color="{{item.color}}"
            data-bg="{{item.bg}}"
            bindtap="selectAvatarColor">
            <text wx:if="{{selectedAvatarColor === item.color}}" class="check-mark">✓</text>
          </view>
        </view>
      </view>

      <!-- 保存按钮 -->
      <button class="save-profile-btn" bindtap="saveProfile" hover-class="btn-hover">
        保存
      </button>
    </view>

    <!-- 意见反馈弹窗 -->
    <view class="feedback-mask" wx:if="{{showFeedback}}" bindtap="closeFeedback"></view>
    <view class="feedback-panel {{showFeedback ? 'show' : ''}}">
      <view class="feedback-header">
        <text class="feedback-title">💬 意见反馈</text>
        <text class="feedback-close" bindtap="closeFeedback">✕</text>
      </view>

      <view class="feedback-form">
        <!-- 反馈类型 -->
        <view class="form-group">
          <text class="form-label">反馈类型</text>
          <view class="type-options">
            <view wx:for="{{feedbackTypes}}" wx:key="value"
              class="type-option {{feedbackType === item.value ? 'active' : ''}}"
              data-value="{{item.value}}"
              bindtap="selectFeedbackType">
              <text>{{item.label}}</text>
            </view>
          </view>
        </view>

        <!-- 联系方式（可选） -->
          <view class="form-group">
          <text class="form-label">联系方式（选填）</text>
          <input class="form-input" value="{{contactInfo}}" placeholder="微信号/邮箱，方便我们回复您"
            maxlength="50" bindinput="onContactInput" placeholder-class="form-placeholder"/>
        </view>

        <!-- 反馈内容 -->
          <view class="form-group">
          <text class="form-label">反馈内容 <text class="required">*</text></text>
          <textarea class="form-textarea" value="{{feedbackContent}}" placeholder="请详细描述您的问题或建议..."
            maxlength="500" auto-height bindinput="onFeedbackInput" placeholder-class="form-placeholder"></textarea>
          <text class="char-count">{{feedbackContent.length}}/500</text>
        </view>
      </view>

      <!-- 提交按钮 -->
      <button class="submit-feedback-btn {{isSubmitting ? 'disabled' : ''}}"
        bindtap="submitFeedback" disabled="{{isSubmitting}}">
        {{isSubmitting ? '提交中...' : '提交反馈'}}
      </button>
    </view>

    <!-- 缓存清理弹窗 -->
    <view class="cache-mask" wx:if="{{showClearCache}}" bindtap="closeClearCache"></view>
    <view class="cache-panel {{showClearCache ? 'show' : ''}}">
      <view class="cache-header">
        <text class="cache-title">🗑️ 清理缓存</text>
        <text class="cache-close" bindtap="closeClearCache">✕</text>
      </view>

      <view class="cache-overview">
        <view class="cache-total">
          <text class="total-label">总缓存大小</text>
          <text class="total-value">{{cacheInfo.total}}</text>
        </view>
      </view>

      <view class="cache-items">
        <view class="cache-item">
          <view class="item-left">
            <text class="item-icon">💾</text>
            <view class="item-info">
              <text class="item-name">数据缓存</text>
              <text class="item-desc">用户设置、收藏、使用记录等</text>
            </view>
          </view>
          <view class="item-right">
            <text class="item-size">{{cacheInfo.data}}</text>
            <text class="item-action" catchtap="clearUserData">清空</text>
          </view>
        </view>

        <view class="cache-item">
          <view class="item-left">
            <text class="item-icon">🖼️</text>
            <view class="item-info">
              <text class="item-name">图片缓存</text>
              <text class="item-desc">头像、工具图标等临时图片</text>
            </view>
          </view>
          <view class="item-right">
            <text class="item-size">{{cacheInfo.images}}</text>
            <text class="item-action" catchtap="clearImageCache">清空</text>
          </view>
        </view>

        <view class="cache-item">
          <view class="item-left">
            <text class="item-icon">📜</text>
            <view class="item-info">
              <text class="item-name">历史记录</text>
              <text class="item-desc">最近使用、收藏夹、反馈历史</text>
            </view>
          </view>
          <view class="item-right">
            <text class="item-size">{{cacheInfo.history}}</text>
            <text class="item-action" catchtap="clearHistoryData">清空</text>
          </view>
        </view>

        <view class="cache-item">
          <view class="item-left">
            <text class="item-icon">📋</text>
            <view class="item-info">
              <text class="item-name">剪贴板暂存</text>
              <text class="item-desc">反馈内容临时存储</text>
            </view>
          </view>
          <view class="item-right">
            <text class="item-action" bindtap="clearClipboardTemp">清空</text>
          </view>
        </view>
      </view>

      <view class="cache-actions">
        <button class="cache-btn secondary" bindtap="clearHistoryData">清理历史</button>
        <button class="cache-btn danger" bindtap="clearAllData">全部清理</button>
      </view>
    </view>

    <!-- 最近使用 -->
    <view class="section-block">
      <view class="section-header">
        <view class="section-title-row">
          <text class="section-icon">📌</text>
          <text class="section-title">最近使用</text>
        </view>
        <text class="section-subtitle">(最近7条)</text>
      </view>

      <view class="recent-list" wx:if="{{recentTools.length > 0}}">
        <view
          wx:for="{{recentTools}}"
          wx:key="id"
          wx:if="{{index < 7}}"
          class="recent-item"
          data-tool="{{item}}"
          bindtap="onToolClick"
          hover-class="recent-item-hover"
          hover-stay-time="100"
        >
          <view class="recent-icon-wrapper" style="background: {{item.iconBg}}">
            <text class="recent-icon">{{item.icon}}</text>
          </view>
          <view class="recent-content">
            <text class="recent-name">{{item.name}}</text>
            <text class="recent-time">{{item.timeText}}</text>
          </view>
        </view>
      </view>

      <view class="empty-mini" wx:if="{{recentTools.length === 0}}">
        <text>暂无使用记录，去首页试试吧~</text>
      </view>

      <view class="see-all-btn" bindtap="goToRecentFull" wx:if="{{recentTools.length > 0}}">
        <text>查看全部最近使用 ></text>
      </view>
    </view>

    <!-- 我的收藏 -->
    <view class="section-block">
      <view class="section-header">
        <view class="section-title-row">
          <text class="section-icon">⭐</text>
          <text class="section-title">我的收藏</text>
        </view>
        <text class="section-subtitle">({{favoriteTools.length}}个)</text>
      </view>

      <view class="fav-preview" wx:if="{{favoriteTools.length > 0}}">
        <text class="fav-names">{{favoritePreviewNames}}</text>
      </view>
      <view class="empty-mini" wx:else>
        <text>还没有收藏工具哦</text>
      </view>

      <view class="see-all-btn" bindtap="goToFavorites">
        <text>查看全部收藏 ></text>
      </view>
    </view>

    <!-- 设置 -->
    <view class="section-block settings-section">
      <view class="section-header">
        <view class="section-title-row">
          <text class="section-icon">⚙️</text>
          <text class="section-title">设置</text>
        </view>
      </view>

      <view class="settings-list">
        <view class="setting-item" bindtap="toggleDarkMode" hover-class="setting-hover">
          <view class="setting-left">
            <text class="setting-icon">{{darkModeSetting === 'dark' ? '🌙' : darkModeSetting === 'light' ? '☀️' : '🔄'}}</text>
            <text class="setting-name">外观模式</text>
          </view>
          <view class="setting-right">
            <text class="setting-value">{{darkModeSetting === 'system' ? '跟随系统' : darkModeSetting === 'dark' ? '夜间模式' : '白天模式'}}</text>
            <text class="setting-arrow">›</text>
          </view>
        </view>

        <view class="setting-item" bindtap="clearCache" hover-class="setting-hover">
          <view class="setting-left">
            <text class="setting-icon">🗑️</text>
            <text class="setting-name">清理缓存</text>
          </view>
          <view class="setting-right">
            <text class="setting-value">{{cacheSize}}</text>
            <text class="setting-arrow">›</text>
          </view>
        </view>

        <view class="setting-item" bindtap="onFeedback" hover-class="setting-hover">
          <view class="setting-left">
            <text class="setting-icon">💬</text>
            <text class="setting-name">意见反馈</text>
          </view>
          <view class="setting-right">
            <text class="setting-arrow">›</text>
          </view>
        </view>
      </view>
    </view>

    <!-- UGC需求收集入口 -->
    <view class="ugc-entry" bindtap="openToolRequest" hover-class="ugc-hover">
      <view class="ugc-icon-wrapper">
        <text class="ugc-icon">💡</text>
      </view>
      <view class="ugc-content">
        <text class="ugc-title">想增加什么工具？</text>
        <text class="ugc-subtitle">告诉我们你的需求，我们来实现 ✨</text>
      </view>
      <text class="ugc-arrow">→</text>
    </view>

    <!-- UGC需求收集弹窗 -->
    <view class="ugc-mask" wx:if="{{showToolRequest}}" bindtap="closeToolRequest"></view>
    <view class="ugc-panel {{showToolRequest ? 'show' : ''}}" style="padding-top: {{menuButtonInfo.top + menuButtonInfo.height + 16}}px;">
      <view class="ugc-header">
        <text class="ugc-panel-title">💡 工具需求建议</text>
        <text class="ugc-close" bindtap="closeToolRequest">✕</text>
      </view>

      <view class="ugc-form">
        <!-- 快速分类选择 -->
        <view class="ugc-category-section">
          <text class="ugc-form-label">工具类型（选填）</text>
          <view class="category-chips">
            <view 
              wx:for="{{toolCategories}}" 
              wx:key="value"
              class="chip {{selectedCategory === item.value ? 'active' : ''}}"
              data-value="{{item.value}}"
              bindtap="selectToolCategory"
            >
              <text>{{item.icon}} {{item.label}}</text>
            </view>
          </view>
        </view>

        <!-- 需求描述 -->
        <view class="ugc-input-group">
          <text class="ugc-form-label">需求描述 <text class="required">*</text></text>
          <textarea 
            class="ugc-textarea" 
            value="{{toolRequestContent}}" 
            placeholder="请详细描述您希望添加的工具功能...&#10;例如：我想一个可以计算房贷利率对比的工具"
            maxlength="300" 
            auto-height
            bindinput="onToolRequestInput"
          ></textarea>
          <text class="char-count">{{toolRequestContent.length}}/300</text>
        </view>

        <!-- 优先级 -->
        <view class="ugc-priority-section">
          <text class="ugc-form-label">优先级</text>
          <view class="priority-options">
            <view 
              wx:for="{{priorityLevels}}" 
              wx:key="value"
              class="priority-option {{selectedPriority === item.value ? 'active' : ''}}"
              data-value="{{item.value}}"
              bindtap="selectPriority"
            >
              <text>{{item.icon}}</text>
              <text>{{item.label}}</text>
            </view>
          </view>
        </view>

        <!-- 联系方式（可选） -->
        <view class="ugc-input-group">
          <text class="ugc-form-label">联系方式（选填）</text>
          <input 
            class="ugc-input" 
            value="{{toolRequestContact}}" 
            placeholder="微信号/邮箱，方便我们联系您"
            maxlength="50"
            bindinput="onToolRequestContactInput"
          />
        </view>
      </view>

      <!-- 提交按钮 -->
      <button 
        class="submit-ugc-btn {{isSubmittingUGC ? 'disabled' : ''}}" 
        bindtap="submitToolRequest" 
        disabled="{{isSubmittingUGC}}"
      >
        {{isSubmittingUGC ? '提交中...' : '提交需求 💪'}}
      </button>

      <!-- 备用关闭按钮 -->
      <view class="close-ugc-bottom" bindtap="closeToolRequest">
        <text class="close-ugc-text">关闭</text>
      </view>

      <!-- 已提交的需求列表 -->
      <view class="submitted-list" wx:if="{{submittedRequests.length > 0}}">
        <view class="submitted-header">
          <text class="submitted-title">我已提交 ({{submittedRequests.length}})</text>
        </view>
        <view 
          wx:for="{{submittedRequests}}" 
          wx:key="id"
          class="submitted-item"
        >
          <view class="submitted-left">
            <text class="status-dot {{item.status === 'pending' ? 'pending' : 'done'}}"></text>
            <view class="submitted-info">
              <text class="submitted-content">{{item.content}}</text>
              <text class="submitted-time">{{item.time}}</text>
            </view>
          </view>
          <text class="status-tag">{{item.status === 'pending' ? '审核中' : '已采纳'}}</text>
        </view>
      </view>
    </view>

    <view class="bottom-safe-area"></view>
  </view>
</scroll-view>
