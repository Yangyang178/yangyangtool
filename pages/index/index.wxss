page {
  height: 100vh;
  background-color: var(--pageBg,#F8FAFC);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.main-scroll {
  flex: 1;
  height: 100vh;
  background: linear-gradient(180deg, var(--gradientHeaderStart,#EFF6FF) 0%, var(--gradientHeaderEnd,#F8FAFC) 200px);
  position: relative;
}

.page-container {
  padding: 0 20px;
  padding-bottom: 100px;
  min-height: calc(100vh - 100px);
  position: relative;
  box-sizing: border-box;
}

.nav-placeholder {
  height: 28px;
  flex-shrink: 0;
}

.header-section {
  padding: 24px 0 24px;
  position: relative;
  z-index: 1;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.app-title {
  font-size: 28px;
  font-weight: 700;
  color: var(--textPrimary,#1E293B);
  letter-spacing: -0.5px;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 12px;
}

.greeting-text {
  font-size: 14px;
  color: var(--textSecondary,#64748B);
}

.more-icon {
  width: 32px;
  height: 32px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 3px;
  padding: 4px;
}

.dot {
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background-color: var(--textSecondary,#64748B);
}

.slogan {
  font-size: 13px;
  color: var(--textTertiary,#94A3B8);
  letter-spacing: 0.5px;
}

.search-bar {
  margin-bottom: 16px;
  position: relative;
  z-index: 10;
}

/* 搜索面板 */
.search-panel {
  margin-top: 8px;
  background: var(--cardBg,#FFFFFF);
  border-radius: 16px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  padding: 16px;
  animation: slideDown 0.2s ease-out;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.search-section {
  margin-bottom: 16px;
}

.search-section:last-child {
  margin-bottom: 0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}

.section-title {
  font-size: 14px;
  font-weight: 600;
  color: var(--textPrimary,#1E293B);
}

.clear-history {
  font-size: 12px;
  color: var(--accentBlue,#3B82F6);
}

.history-tags, .hot-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.history-tag, .hot-tag {
  padding: 6px 14px;
  background: var(--surfaceBg,#F1F5F9);
  border-radius: 16px;
  font-size: 13px;
  color: var(--textPrimary,#1E293B);
  display: flex;
  align-items: center;
  gap: 4px;
}

.history-tag:active, .hot-tag:active {
  opacity: 0.7;
  background: var(--accentBlue,#3B82F6);
  color: white;
}

.hot-icon {
  font-size: 12px;
}

.hot-tag {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  color: #92400E;
}

.hot-tag:nth-child(1), .hot-tag:nth-child(2), .hot-tag:nth-child(3) {
  background: linear-gradient(135deg, #FEE2E2 0%, #FECACA 100%);
  color: #991B1B;
}

.search-input-wrapper {
  background: var(--cardBg,#FFFFFF);
  border-radius: 25px;
  padding: 14px 20px;
  display: flex;
  align-items: center;
  box-shadow: 0 2px 12px rgba(59, 130, 246, 0.08);
}

.search-icon {
  font-size: 18px;
  margin-right: 10px;
}

.search-input {
  flex: 1;
  font-size: 15px;
  color: var(--textPrimary,#1E293B);
}

.search-placeholder {
  color: var(--textTertiary,#94A3B8);
}

.clear-btn {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: var(--borderLight,#E2E8F0);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transform: scale(0.8);
  transition: all 0.2s ease;
}

.clear-btn.show {
  opacity: 1;
  transform: scale(1);
}

.clear-btn text {
  font-size: 12px;
  color: var(--textSecondary,#64748B);
}

.category-tabs {
  margin-bottom: 20px;
  white-space: nowrap;
}

.tabs-container {
  display: inline-flex;
  gap: 8px;
  padding: 4px 0;
}

.tab-item {
  padding: 8px 16px;
  border-radius: 20px;
  background: transparent;
  transition: all 0.2s ease;
}

.tab-item.active {
  background: var(--accentBlue,#3B82F6);
}

.tab-text {
  font-size: 14px;
  color: var(--textSecondary,#64748B);
  font-weight: 500;
}

.tab-item.active .tab-text {
  color: var(--textOnAccent,#FFFFFF);
}

.tools-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
  min-height: 300px;
}

.tool-card {
  background: var(--cardBg,#FFFFFF);
  border-radius: 20px;
  padding: 20px 16px;
  box-shadow: 0 4px 12px var(--shadowCard, rgba(0, 0, 0, 0.03));
  position: relative;
  transition: all 0.15s ease;
  overflow: hidden;
  height: fit-content;
}

.tool-card-hover {
  transform: scale(0.98);
  opacity: 0.95;
  box-shadow: 0 2px 8px var(--shadowFloat, rgba(0, 0, 0, 0.06));
}

.card-favorite {
  position: absolute;
  top: 12px;
  right: 12px;
  z-index: 10;
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-favorite text {
  font-size: 18px;
  color: var(--textMuted,#CBD5E1);
}

.tool-card.favorite .card-favorite text {
  color: #FBBF24;
}

.card-icon-wrapper {
  width: 56px;
  height: 56px;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14px;
  background: linear-gradient(135deg, var(--gradientBlueStart,#DBEAFE) 0%, var(--gradientBlueEnd,#BFDBFE) 100%);
}

.card-icon {
  font-size: 28px;
}

.card-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--textPrimary,#1E293B);
  display: block;
  margin-bottom: 6px;
}

.card-desc {
  font-size: 12px;
  color: var(--textSecondary,#64748B);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-badge {
  position: absolute;
  top: 12px;
  left: 12px;
  background: linear-gradient(135deg, var(--gradientRedStart,#EF4444) 0%, var(--gradientRedEnd,#DC2626) 100%);
  padding: 3px 8px;
  border-radius: 10px;
}

.card-badge text {
  font-size: 10px;
  color: var(--textOnAccent,#FFFFFF);
  font-weight: 600;
}

.empty-state {
  grid-column: 1 / -1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
}

.empty-icon {
  font-size: 64px;
  margin-bottom: 16px;
  opacity: 0.5;
}

.empty-text {
  font-size: 16px;
  font-weight: 600;
  color: var(--textPrimary,#1E293B);
  margin-bottom: 8px;
}

.empty-subtext {
  font-size: 14px;
  color: var(--textTertiary,#94A3B8);
}

.bottom-safe-area {
  height: 80px;
  flex-shrink: 0;
}

/* ==================== 夜间模式搜索面板优化 ==================== */
.main-scroll.dark-mode .search-panel {
  background: #1E293B;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
  border: 1px solid rgba(51, 65, 85, 0.6);
}

.main-scroll.dark-mode .section-title {
  color: #F1F5F9;
  font-weight: 700;
}

.main-scroll.dark-mode .clear-history {
  color: #60A5FA;
}

.main-scroll.dark-mode .history-tag,
.main-scroll.dark-mode .hot-tag {
  background: rgba(51, 65, 85, 0.8);
  color: #E2E8F0;
  border: 1px solid rgba(71, 85, 105, 0.6);
}

.main-scroll.dark-mode .history-tag:active,
.main-scroll.dark-mode .hot-tag:active {
  background: rgba(59, 130, 246, 0.3);
  color: #93C5FD;
}

.main-scroll.dark-mode .hot-icon {
  filter: brightness(1.2);
}