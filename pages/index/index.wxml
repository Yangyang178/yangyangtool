<navigation-bar title="" back="{{false}}" color="{{isDarkMode ? 'white' : 'black'}}" background="{{isDarkMode ? '#0F172A' : '#F8FAFC'}}"></navigation-bar>

<canvas type="2d" id="shareCanvas" style="position:fixed;left:-9999px;top:-9999px;width:500px;height:400px;"></canvas>

<guide-overlay show="{{showGuide}}" bindclose="onGuideClose"></guide-overlay>

<skeleton show="{{isLoading}}" type="tools" dark="{{isDarkMode}}"></skeleton>

<scroll-view class="main-scroll {{isDarkMode ? 'dark-mode' : ''}}" scroll-y enhanced show-scrollbar="{{false}}" bounces="{{false}}" refresher-enabled="{{!isEditMode}}" refresher-triggered="{{isRefreshing}}" bindrefresherrefresh="onPullDownRefresh" scroll-top="{{scrollTop}}" bindscrolltoupper="onScrollToUpper" bindscroll="onPageScroll" lower-threshold="0">
  <view class="page-container">
    <!-- 应用头部 - Hero Section v2 -->
    <view class="header-section">
      <!-- 品牌标识区 -->
      <view class="header-brand">
        <text class="brand-logo">🧰</text>
        <view class="brand-text">
          <text class="brand-title">百宝工具箱</text>
          <view class="version-badge">
            <text>v2.0</text>
          </view>
        </view>
      </view>

      <!-- 价值主张 -->
      <view class="value-proposition">
        <text class="slogan">{{isEditMode ? '点击卡片选中，再点击目标位置交换' : '25+ 实用小工具，即用即走'}}</text>
      </view>

      <!-- Top 3 快捷入口 -->
      <view class="quick-access" wx:if="{{topTools.length > 0 && !isEditMode}}">
        <view
          wx:for="{{topTools}}"
          wx:key="id"
          class="quick-tool-item"
          data-tool="{{item}}"
          bindtap="onToolClick"
        >
          <view class="quick-icon" style="background: {{item.iconBg}}">
            <text>{{item.icon}}</text>
          </view>
          <text class="quick-name">{{item.name}}</text>
        </view>
      </view>

      <!-- 数据信任条 -->
      <view class="trust-bar" wx:if="{{!isEditMode}}">
        <view class="trust-item">
          <text class="trust-number">25+</text>
          <text class="trust-label">实用工具</text>
        </view>
        <view class="trust-divider"></view>
        <view class="trust-item">
          <text class="trust-number">{{totalUsageDisplay}}</text>
          <text class="trust-label">累计使用</text>
        </view>
        <view class="trust-divider"></view>
        <view class="trust-item">
          <text class="trust-number">100%</text>
          <text class="trust-label">免费使用</text>
        </view>
      </view>

      <!-- 右侧操作区域 -->
      <view class="header-right" bindtap="{{isEditMode ? '' : 'showMoreMenu'}}">
        <text class="greeting-text">{{greetingText}}</text>
        <view class="edit-mode-btn {{isEditMode ? 'active' : ''}}" catchtap="toggleEditMode" wx:if="{{!isEditMode}}">
          <text class="edit-icon">✏️</text>
        </view>
        <view class="more-icon" wx:if="{{!isEditMode}}">
          <text class="dot"></text>
          <text class="dot"></text>
          <text class="dot"></text>
        </view>
        <view class="edit-actions" wx:if="{{isEditMode}}">
          <view class="edit-row-top">
            <view class="edit-action-btn done-btn" catchtap="toggleEditMode">
              <text>完成</text>
            </view>
            <view class="edit-action-btn reset-btn" catchtap="resetLayout">
              <text>重置</text>
            </view>
          </view>
          <view class="edit-row-bottom">
            <view class="edit-action-btn undo-btn {{canUndo ? 'can-undo' : ''}}" catchtap="undoLastAction">
              <text>↩️ 撤销上一步</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 编辑模式提示条 -->
      <view class="edit-tip-bar {{isEditMode ? 'show' : ''}}" wx:if="{{isEditMode}}">
        <text class="tip-text">👆 点击选中交换 · 👁️ 隐藏/显示 · 👇 下方恢复已隐藏</text>
      </view>
    </view>

    <!-- 搜索栏 v2 - Task B3 增强 -->
    <view class="search-bar {{showSearchPanel ? 'active' : ''}}">
      <view class="search-input-wrapper">
        <input
          class="search-input"
          type="text"
          placeholder="搜索 25+ 实用工具..."
          placeholder-class="search-placeholder"
          value="{{searchKeyword}}"
          bindinput="onSearchInput"
          bindfocus="onSearchFocus"
          bindblur="onSearchBlur"
          confirm-type="search"
        />
        <view class="clear-btn {{searchKeyword ? 'show' : ''}}" bindtap="clearSearch">
          <text>✕</text>
        </view>
      </view>

      <!-- 搜索面板 v2 -->
      <view class="search-panel" wx:if="{{showSearchPanel}}">
        <!-- 搜索历史 -->
        <view class="search-section" wx:if="{{searchHistory.length > 0}}">
          <view class="section-header">
            <view class="section-title-wrapper">
              <text class="section-icon">🕐</text>
              <text class="section-title">最近搜索</text>
            </view>
            <text class="clear-history-btn" bindtap="clearSearchHistory">
              <text class="clear-history-icon">🗑️</text>
              <text>清空</text>
            </text>
          </view>
          <scroll-view class="history-scroll" scroll-x enhanced show-scrollbar="{{false}}">
            <view class="history-tags">
              <view class="history-tag" wx:for="{{searchHistory}}" wx:key="index" bindtap="onHistoryClick" data-word="{{item}}">
                <text class="history-tag-text">{{item}}</text>
                <text class="history-tag-arrow">→</text>
              </view>
            </view>
          </scroll-view>
        </view>

        <!-- 热门搜索 -->
        <view class="search-section">
          <view class="section-header">
            <view class="section-title-wrapper">
              <text class="section-icon">🔥</text>
              <text class="section-title">热门推荐</text>
            </view>
          </view>
          <view class="hot-tags">
            <view 
              class="hot-tag {{index < 3 ? 'top-hot' : ''}}" 
              wx:for="{{hotSearchWords}}" 
              wx:key="index" 
              bindtap="onHotSearchClick" 
              data-word="{{item}}"
            >
              <view class="hot-tag-rank" wx:if="{{index < 3}}">
                <text>{{index + 1}}</text>
              </view>
              <text class="hot-tag-text">{{item}}</text>
              <text class="hot-tag-fire" wx:if="{{index < 3}}">🔥</text>
            </view>
          </view>
        </view>

        <!-- 快捷提示 -->
        <view class="search-tip">
          <text class="tip-text">💡 提示：支持中英文、拼音首字母搜索</text>
        </view>
      </view>
    </view>

    <!-- 分类快捷标签栏 -->
    <scroll-view class="category-tabs" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="tabs-container">
        <view 
          wx:for="{{categories}}" 
          wx:key="id"
          class="tab-item {{currentCategory === item.id ? 'active' : ''}}"
          data-id="{{item.id}}"
          bindtap="onCategoryChange"
        >
          <text class="tab-text">{{item.name}}</text>
        </view>
      </view>
    </scroll-view>

    <!-- 工具网格区域 -->
    <view class="tools-grid {{isEditMode ? 'edit-mode' : ''}}">
      <view 
        wx:for="{{filteredTools}}" 
        wx:key="id"
        class="tool-card {{item.isFavorite ? 'favorite' : ''}} {{selectedToolIndex === index ? 'selected' : ''}}"
        data-tool="{{item}}"
        data-index="{{index}}"
        bindtap="{{isEditMode ? 'onEditToolClick' : 'onToolClick'}}"
        hover-class="{{isEditMode ? 'tool-card-edit-hover' : 'tool-card-hover'}}"
        hover-stay-time="100"
      >
        <view class="card-favorite" catchtap="toggleFavorite" data-id="{{item.id}}" wx:if="{{!isEditMode}}">
          <text>{{item.isFavorite ? '★' : '☆'}}</text>
        </view>

        <!-- 编辑模式：显示/隐藏按钮 -->
        <view
          class="card-visibility {{hiddenTools.indexOf(item.id) !== -1 ? 'hidden-tool' : ''}}"
          catchtap="toggleToolVisibility"
          data-id="{{item.id}}"
          wx:if="{{isEditMode}}"
        >
          <text>{{hiddenTools.indexOf(item.id) !== -1 ? '👁️‍🗨️' : '👁️'}}</text>
        </view>

        <!-- 选中标记 -->
        <view class="selected-overlay" wx:if="{{isEditMode && selectedToolIndex === index}}">
          <view class="selected-ring"></view>
          <view class="selected-badge">
            <text>✓ 已选中</text>
          </view>
          <view class="selected-hint">
            <text>点击另一个交换</text>
          </view>
        </view>

        <view class="card-icon-wrapper" style="background: {{item.iconBg}}">
          <text class="card-icon">{{item.icon}}</text>
        </view>

        <text class="card-title">{{item.name}}</text>
        <text class="card-desc">{{item.description}}</text>

        <view class="card-badge" wx:if="{{item.isHot}}">
          <text>热门</text>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{filteredTools.length === 0}}">
        <text class="empty-icon">🔍</text>
        <text class="empty-text">没有找到相关工具</text>
        <text class="empty-subtext">试试其他关键词</text>
      </view>
    </view>

    <!-- 已隐藏工具管理区 -->
    <view class="hidden-tools-section {{isEditMode && hiddenTools.length > 0 ? 'show' : ''}}" wx:if="{{isEditMode}}">
      <view class="hidden-header">
        <text class="hidden-title">👁️‍🗨️ 已隐藏 ({{hiddenToolsList.length}})</text>
        <text class="hidden-hint">点击可恢复显示</text>
      </view>
      
      <scroll-view class="hidden-tools-scroll" scroll-x enhanced show-scrollbar="{{false}}" wx:if="{{hiddenToolsList.length > 0}}">
        <view class="hidden-tools-list">
          <view 
            wx:for="{{hiddenToolsList}}" 
            wx:key="id"
            class="hidden-tool-item"
            data-id="{{item.id}}"
            catchtap="restoreHiddenTool"
          >
            <view class="hidden-icon-wrapper" style="background: {{item.iconBg}}">
              <text class="hidden-icon">{{item.icon}}</text>
            </view>
            <text class="hidden-name">{{item.name}}</text>
            <view class="restore-badge">
              <text>恢复</text>
            </view>
          </view>
        </view>
      </scroll-view>
      
      <view class="no-hidden-tools" wx:if="{{hiddenToolsList.length === 0}}">
        <text>暂无隐藏的工具</text>
      </view>
    </view>

    <!-- 底部安全区域占位 -->
    <view class="bottom-safe-area"></view>
  </view>
</scroll-view>