<navigation-bar title="收藏夹" back="{{false}}" color="{{isDarkMode ? 'white' : 'black'}}" background="{{isDarkMode ? '#0F172A' : '#F8FAFC'}}"></navigation-bar>

<scroll-view class="main-scroll {{isDarkMode ? 'dark-mode' : ''}}" scroll-y enhanced show-scrollbar="{{false}}" bounces="{{false}}">
  <view class="page-container">
    <view class="header-section">
      <text class="page-title">我的收藏</text>
      <text class="page-subtitle">{{favoriteTools.length}} 个工具</text>
    </view>

    <!-- 收藏列表 -->
    <view class="tools-list" wx:if="{{favoriteTools.length > 0}}">
      <view 
        wx:for="{{favoriteTools}}" 
        wx:key="id"
        class="tool-item"
        data-tool="{{item}}"
        bindtap="onToolClick"
        hover-class="tool-item-hover"
        hover-stay-time="100"
      >
        <view class="item-icon-wrapper" style="background: {{item.iconBg}}">
          <text class="item-icon">{{item.icon}}</text>
        </view>
        
        <view class="item-content">
          <text class="item-name">{{item.name}}</text>
          <text class="item-desc">{{item.description}}</text>
        </view>

        <view class="item-action" catchtap="removeFavorite" data-id="{{item.id}}">
          <text>取消收藏</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{favoriteTools.length === 0}}">
      <text class="empty-icon">⭐</text>
      <text class="empty-text">还没有收藏工具</text>
      <text class="empty-subtext">在首页点击星标收藏常用工具</text>
      <view class="empty-btn" bindtap="goToHome">
        <text>去浏览工具</text>
      </view>
    </view>

    <!-- 收藏提示 -->
    <view class="favorite-tip">
      <text class="tip-icon">💡</text>
      <text class="tip-text">提示：在首页的工具卡片里点击星标进行收藏！</text>
    </view>

    <view class="bottom-safe-area"></view>
  </view>
</scroll-view>
