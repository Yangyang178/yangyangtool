page { background-color: var(--pageBg,#F8FAFC); }
.tool-page { height: 100vh; }
.container { padding: 20px; padding-bottom: 40px; }

.tool-header { text-align: center; margin-bottom: 24px; }
.icon-wrapper { width: 80px; height: 80px; border-radius: 24px; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; background: linear-gradient(135deg, var(--gradientPurpleStart,#DDD6FE) 0%, var(--gradientPurpleEnd,#C4B5FD) 100%); }
.tool-icon { font-size: 40px; }
.tool-title { font-size: 24px; font-weight: 700; color: var(--textPrimary,#1E293B); display: block; margin-bottom: 8px; }
.tool-desc { font-size: 14px; color: var(--textSecondary,#64748B); }

.input-area { background: var(--cardBg,#FFFFFF); border-radius: 20px; padding: 20px; box-shadow: 0 2px 12px rgba(0,0,0,0.04); margin-bottom: 24px; }
.text-input { width: 100%; min-height: 200px; font-size: 15px; line-height: 1.6; color: var(--textPrimary,#1E293B); border: none; outline: none; }
.input-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--surfaceBg,#F1F5F9); }
.char-hint { font-size: 13px; color: var(--textTertiary,#94A3B8); }
.clear-btn { font-size: 13px; color: var(--accentRed,#EF4444); background: none; border: none; padding: 6px 12px; }

.stats-section { margin-bottom: 24px; }
.main-stat-card { background: linear-gradient(135deg, var(--accentPurple,#8B5CF6) 0%, var(--accentPurpleDark,#7C3AED) 100%); border-radius: 20px; padding: 32px; text-align: center; margin-bottom: 16px; box-shadow: 0 8px 24px rgba(99, 102, 241, 0.3); }
.big-number { font-size: 56px; font-weight: 700; color: var(--cardBg,#FFFFFF); display: block; }
.stat-label { font-size: 15px; color: rgba(255,255,255,0.9); margin-top: 8px; display: block; }

.stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 16px; }
.stat-item { background: var(--cardBg,#FFFFFF); border-radius: 14px; padding: 18px 10px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.04); }
.stat-value { font-size: 28px; font-weight: 700; display: block; margin-bottom: 4px; }
.stat-value.purple { color: var(--accentPurple,#8B5CF6); }
.stat-value.blue { color: var(--accentBlue,#3B82F6); }
.stat-value.green { color: var(--accentGreen,#10B981); }
.stat-value.orange { color: var(--accentYellow,#F59E0B); }
.stat-name { font-size: 12px; color: var(--textSecondary,#64748B); }

.detail-list { background: var(--cardBg,#FFFFFF); border-radius: 16px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.04); }
.detail-row { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid var(--surfaceBg,#F1F5F9); }
.detail-row:last-child { border-bottom: none; }
.detail-label { font-size: 14px; color: var(--textSecondary,#64748B); }
.detail-value { font-size: 16px; font-weight: 600; color: var(--textPrimary,#1E293B); }

.action-btns { display: flex; gap: 12px; }
.primary-btn, .secondary-btn { flex: 1; height: 52px; border-radius: 26px; display: flex; align-items: center; justify-content: center; font-size: 15px; font-weight: 600; border: none; }
.primary-btn { background: linear-gradient(135deg, var(--accentPurple,#8B5CF6) 0%, var(--accentPurpleDark,#7C3AED) 100%); color: var(--cardBg,#FFFFFF); box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3); }
.secondary-btn { background: var(--surfaceBg,#F1F5F9); color: var(--textSecondary,#64748B); }
