<navigation-bar title="Base64编解码" back="{{true}}" color="black" background="#F8FAFC"></navigation-bar>

<scroll-view class="tool-page" scroll-y>
  <view class="container">
    <!-- 工具头部 -->
    <view class="tool-header">
      <view class="icon-wrapper teal-gradient">
        <view class="icon-decoration"></view>
        <text class="tool-icon">🔐</text>
      </view>
      <text class="tool-title">Base64 编解码</text>
      <text class="tool-desc">快速进行 Base64 编码和解码操作</text>
    </view>

    <!-- 模式切换 -->
    <view class="mode-switcher">
      <view class="mode-btn {{mode === 'encode' ? 'active' : ''}}" data-mode="encode" bindtap="switchMode">
        <text>📝 编码</text>
      </view>
      <view class="mode-btn {{mode === 'decode' ? 'active' : ''}}" data-mode="decode" bindtap="switchMode">
        <text>🔓 解码</text>
      </view>
    </view>

    <!-- 输入区域 -->
    <view class="input-section">
      <view class="section-header">
        <text class="section-label">{{mode === 'encode' ? '原始文本' : 'Base64 编码'}}</text>
        <button class="paste-btn" bindtap="pasteFromClipboard">粘贴</button>
      </view>
      
      <textarea 
        class="content-input"
        placeholder="{{mode === 'encode' ? '请输入要编码的文本...' : '请输入要解码的Base64字符串...'}}"
        value="{{inputContent}}"
        bindinput="onInput"
        maxlength="-1"
        auto-height
      ></textarea>
      
      <view class="input-footer">
        <text class="char-count">{{inputContent.length}} 字符</text>
        <button class="clear-btn" wx:if="{{inputContent}}" bindtap="clearInput">清空</button>
      </view>
    </view>

    <!-- 操作按钮 -->
    <button class="action-btn {{inputContent ? 'active' : ''}}" bindtap="processBase64" disabled="{{!inputContent}}">
      <text>{{mode === 'encode' ? '🔒 编码为 Base64' : '🔓 解码为文本'}}</text>
    </button>

    <!-- 结果显示 -->
    <view class="result-section" wx:if="{{showResult}}">
      <view class="result-header">
        <text class="result-label">{{mode === 'encode' ? '编码结果' : '解码结果'}}</text>
        <view class="result-actions">
          <button class="copy-result-btn" bindtap="copyResult">复制</button>
          <button class="swap-btn" bindtap="swapContent">↓ 使用此结果</button>
        </view>
      </view>
      
      <view class="result-content">
        <text class="result-text">{{outputContent}}</text>
      </view>

      <view class="result-info" wx:if="{{mode === 'encode'}}">
        <text class="info-item">原始长度：{{inputContent.length}} 字符</text>
        <text class="info-item">编码长度：{{outputContent.length}} 字符</text>
        <text class="info-item">膨胀率：{{expansionRate}}%</text>
      </view>

      <view class="error-message" wx:if="{{errorMessage}}">
        <text class="error-icon">⚠️</text>
        <text class="error-text">{{errorMessage}}</text>
      </view>
    </view>

    <!-- 常用示例 -->
    <view class="examples-section">
      <text class="examples-title">💡 快速示例</text>
      <view class="example-list">
        <view class="example-item" bindtap="useExample" data-text="Hello World">
          <text class="example-label">英文文本</text>
          <text class="example-value">Hello World</text>
        </view>
        <view class="example-item" bindtap="useExample" data-text="你好世界">
          <text class="example-label">中文文本</text>
          <text class="example-value">你好世界</text>
        </view>
        <view class="example-item" bindtap="useExample" data-text='{"name":"test","value":123}'>
          <text class="example-label">JSON数据</text>
          <text class="example-value">{"name":"test"}</text>
        </view>
      </view>
    </view>
  </view>
</scroll-view>
