.skeleton-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFFFF;
  z-index: 1000;
}

.dark-mode .skeleton-mask,
.skeleton-mask.dark {
  background: #0F172A;
}

.sk-container {
  padding: 20rpx 32rpx;
  padding-top: 180rpx;
}

.sk-header {
  margin-bottom: 24rpx;
}

.sk-title {
  width: 240rpx;
  height: 48rpx;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #E2E8F0 25%, #F1F5F9 50%, #E2E8F0 75%);
  background-size: 200% 100%;
  animation: sk-shimmer 1.5s infinite;
  margin-bottom: 12rpx;
}

.sk-subtitle {
  width: 180rpx;
  height: 28rpx;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #E2E8F0 25%, #F1F5F9 50%, #E2E8F0 75%);
  background-size: 200% 100%;
  animation: sk-shimmer 1.5s infinite;
}

.sk-search-bar {
  display: flex;
  align-items: center;
  background: #F1F5F9;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 32rpx;
  gap: 16rpx;
}

.sk-circle {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: linear-gradient(90deg, #E2E8F0 25%, #F1F5F9 50%, #E2E8F0 75%);
  background-size: 200% 100%;
  animation: sk-shimmer 1.5s infinite;
  flex-shrink: 0;
}

.sk-input {
  flex: 1;
  height: 36rpx;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #E2E8F0 25%, #F1F5F9 50%, #E2E8F0 75%);
  background-size: 200% 100%;
  animation: sk-shimmer 1.5s infinite;
}

.sk-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.sk-card {
  width: calc((100% - 40rpx) / 3);
  background: #F8FAFC;
  border-radius: 20rpx;
  padding: 28rpx 20rpx 24rpx;
  box-sizing: border-box;
}

.sk-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #DBEAFE 0%, #BFDBFE 100%);
  margin-bottom: 16rpx;
  background-size: 200% 200%;
  animation: sk-shimmer 1.5s infinite;
}

.sk-lines {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.sk-name {
  width: 80%;
  height: 26rpx;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #E2E8F0 25%, #F1F5F9 50%, #E2E8F0 75%);
  background-size: 200% 100%;
  animation: sk-shimmer 1.5s infinite;
}

.sk-desc {
  width: 60%;
  height: 22rpx;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #E2E8F0 25%, #F1F5F9 50%, #E2E8F0 75%);
  background-size: 200% 100%;
  animation: sk-shimmer 1.5s infinite;
}

.sk-list-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.sk-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #DBEAFE 0%, #BFDBFE 100%);
  flex-shrink: 0;
  background-size: 200% 200%;
  animation: sk-shimmer 1.5s infinite;
}

.sk-list-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.sk-list-title {
  width: 70%;
  height: 30rpx;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #E2E8F0 25%, #F1F5F9 50%, #E2E8F0 75%);
  background-size: 200% 100%;
  animation: sk-shimmer 1.5s infinite;
}

.sk-list-subtitle {
  width: 45%;
  height: 24rpx;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #E2E8F0 25%, #F1F5F9 50%, #E2E8F0 75%);
  background-size: 200% 100%;
  animation: sk-shimmer 1.5s infinite;
}

.sk-detail-header {
  width: 100%;
  height: 300rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #DBEAFE 0%, #BFDBFE 100%);
  margin-bottom: 32rpx;
  background-size: 200% 200%;
  animation: sk-shimmer 1.5s infinite;
}

.sk-detail-body {
  padding: 0 16rpx;
}

.sk-d-title {
  width: 60%;
  height: 36rpx;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #E2E8F0 25%, #F1F5F9 50%, #E2E8F0 75%);
  background-size: 200% 100%;
  animation: sk-shimmer 1.5s infinite;
  margin-bottom: 20rpx;
}

.sk-d-text {
  width: 90%;
  height: 28rpx;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #E2E8F0 25%, #F1F5F9 50%, #E2E8F0 75%);
  background-size: 200% 100%;
  animation: sk-shimmer 1.5s infinite;
  margin-bottom: 16rpx;
}

.sk-d-text.short {
  width: 50%;
}

.sk-d-block {
  width: 100%;
  height: 160rpx;
  border-radius: 16rpx;
  background: linear-gradient(90deg, #E2E8F0 25%, #F1F5F9 50%, #E2E8F0 75%);
  background-size: 200% 100%;
  animation: sk-shimmer 1.5s infinite;
  margin-bottom: 24rpx;
}

.sk-btn-row {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.sk-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 42rpx;
  background: linear-gradient(90deg, #3B82F6 25%, #60A5FA 50%, #3B82F6 75%);
  background-size: 200% 100%;
  animation: sk-shimmer 1.5s infinite;
}

@keyframes sk-shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.dark-mode .sk-title,
.dark-mode .sk-subtitle,
.dark-mode .sk-input,
.dark-mode .sk-name,
.dark-mode .sk-desc,
.dark-mode .sk-list-title,
.dark-mode .sk-list-subtitle,
.dark-mode .sk-d-title,
.dark-mode .sk-d-text,
.skeleton-mask.dark .sk-title,
.skeleton-mask.dark .sk-subtitle,
.skeleton-mask.dark .sk-input,
.skeleton-mask.dark .sk-name,
.skeleton-mask.dark .sk-desc,
.skeleton-mask.dark .sk-list-title,
.skeleton-mask.dark .sk-list-subtitle,
.skeleton-mask.dark .sk-d-title,
.skeleton-mask.dark .sk-d-text {
  background: linear-gradient(90deg, #1E293B 25%, #334155 50%, #1E293B 75%);
  background-size: 200% 100%;
  animation: sk-shimmer-dark 1.5s infinite;
}

@keyframes sk-shimmer-dark {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.dark-mode .sk-icon-box,
.dark-mode .sk-avatar,
.dark-mode .sk-detail-header,
.dark-mode .sk-d-block,
.dark-mode .sk-circle,
.dark-mode .sk-btn,
.skeleton-mask.dark .sk-icon-box,
.skeleton-mask.dark .sk-avatar,
.skeleton-mask.dark .sk-detail-header,
.skeleton-mask.dark .sk-d-block,
.skeleton-mask.dark .sk-circle,
.skeleton-mask.dark .sk-btn {
  background: linear-gradient(135deg, #1E293B 0%, #334155 100%);
  background-size: 200% 200%;
  animation: sk-shimmer-dark 1.5s infinite;
}

.dark-mode .sk-card,
.dark-mode .sk-search-bar,
.skeleton-mask.dark .sk-card,
.skeleton-mask.dark .sk-search-bar {
  background: #1E293B;
}